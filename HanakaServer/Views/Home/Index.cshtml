@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tournaments";
}

 <!-- Begin Page Content -->
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Tournaments</h1>
        <button class="btn btn-primary btn-sm shadow-sm"
                data-toggle="modal"
                data-target="#modalTournament">
            <i class="fas fa-plus fa-sm text-white-50"></i> Create
            Tournament
        </button>
    </div>

    <!-- List -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">
                Tournament List
            </h6>
            <div class="d-flex" style="gap: 8px">
                <select class="form-control form-control-sm">
                    <option>All Status</option>
                    <option>OPEN</option>
                    <option>CLOSED</option>
                    <option>DRAFT</option>
                </select>
                <button class="btn btn-sm btn-outline-primary">Filter</button>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered"
                       width="100%"
                       cellspacing="0">
                    <thead>
                        <tr>
                            <th>Banner</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Start</th>
                            <th>Deadline</th>
                            <th>GameType</th>
                            <th>Teams</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>
                                <img class="banner-thumb"
                                     src="https://images.unsplash.com/photo-1521412644187-c49fa049e84d?w=600&q=80" />
                            </td>
                            <td>
                                <div class="font-weight-bold text-gray-900">
                                    Hanaka Cup 2026
                                </div>
                                <div class="small text-gray-500">
                                    Hà Nội • Single/Double
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-success badge-status">OPEN</span>
                            </td>
                            <td>2026-06-20 08:00</td>
                            <td>2026-06-15 23:59</td>
                            <td>DOUBLE</td>
                            <td>32</td>
                            <td style="white-space: nowrap">
                                <button class="btn btn-sm btn-outline-info"
                                        data-toggle="modal"
                                        data-target="#modalTournament">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-warning">
                                    <i class="fas fa-lock"></i> CLOSE
                                </button>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="registrations.html">
                                    <i class="fas fa-list"></i>
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <img class="banner-thumb"
                                     src="https://images.unsplash.com/photo-1517649763962-0c623066013b?w=600&q=80" />
                            </td>
                            <td>
                                <div class="font-weight-bold text-gray-900">
                                    Beginner Open
                                </div>
                                <div class="small text-gray-500">Hồ Chí Minh</div>
                            </td>
                            <td>
                                <span class="badge badge-secondary badge-status">DRAFT</span>
                            </td>
                            <td>—</td>
                            <td>—</td>
                            <td>SINGLE</td>
                            <td>16</td>
                            <td style="white-space: nowrap">
                                <button class="btn btn-sm btn-outline-info"
                                        data-toggle="modal"
                                        data-target="#modalTournament">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-success">
                                    <i class="fas fa-unlock"></i> OPEN
                                </button>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="groups-schedule.html">
                                    <i class="fas fa-stream"></i>
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<!-- /.container-fluid -->