@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Người dùng";
}

<style>
    .users-page-toolbar {
        gap: 8px;
    }

    .users-filter-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        width: 100%;
    }

        .users-filter-toolbar .filter-keyword {
            flex: 1 1 260px;
            min-width: 220px;
        }

        .users-filter-toolbar .filter-verified,
        .users-filter-toolbar .filter-active {
            flex: 0 0 140px;
            min-width: 140px;
        }

        .users-filter-toolbar .filter-action {
            flex: 0 0 auto;
        }

    .user-avatar-lg {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
    }

    .user-avatar-sm {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
    }

    .user-avatar-fallback {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px dashed #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        font-weight: 700;
    }

    @@media (max-width: 991.98px) {
        .users-card-header-responsive {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
        }

            .users-card-header-responsive h6 {
                margin-bottom: 0;
            }

        .users-filter-toolbar .filter-keyword,
        .users-filter-toolbar .filter-verified,
        .users-filter-toolbar .filter-active,
        .users-filter-toolbar .filter-action {
            flex: 1 1 100%;
            min-width: 100%;
        }

        .users-filter-toolbar .btn {
            width: 100%;
        }
    }

    @@media (max-width: 575.98px) {
        .users-page-title-bar {
            gap: 12px;
        }

            .users-page-title-bar > div:last-child {
                width: 100%;
            }

        .users-page-toolbar {
            display: flex;
            flex-wrap: wrap;
            width: 100%;
        }

            .users-page-toolbar > * {
                flex: 1 1 100%;
            }
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 users-page-title-bar">
        <h1 class="h3 mb-0 text-gray-800">Người dùng</h1>

        <div>
            <div class="d-flex users-page-toolbar">
                <button id="btnRefresh" class="btn btn-primary btn-sm shadow-sm" type="button">
                    <i class="fas fa-sync fa-sm text-white-50"></i> Làm mới
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between users-card-header-responsive">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách người dùng</h6>

            <div class="users-filter-toolbar">
                <div class="filter-keyword">
                    <input id="keyword" class="form-control form-control-sm w-100"
                           placeholder="Tìm tên / email / số điện thoại" />
                </div>

                <div class="filter-verified">
                    <select id="verifiedFilter" class="form-control form-control-sm w-100">
                        <option value="ALL" selected>Tất cả xác minh</option>
                        <option value="true">Đã xác minh</option>
                        <option value="false">Chưa xác minh</option>
                    </select>
                </div>

                <div class="filter-active">
                    <select id="activeFilter" class="form-control form-control-sm w-100">
                        <option value="ALL" selected>Tất cả trạng thái</option>
                        <option value="true">Đang hoạt động</option>
                        <option value="false">Đã khóa</option>
                    </select>
                </div>

                <div class="filter-action">
                    <button id="btnFilter" class="btn btn-sm btn-outline-primary" type="button">Lọc</button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div id="pageError" class="alert alert-danger d-none"></div>

            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width: 72px;">Ảnh đại diện</th>
                            <th>Người dùng</th>
                            <th>Thành phố</th>
                            <th>Xác minh</th>
                            <th>Trạng thái</th>
                            <th>Điểm trình độ (Đơn/Đôi)</th>
                            <th>Ngày tạo</th>
                            <th style="width: 170px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="usersBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted">Đang tải...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap" style="gap: 8px;">
                <div class="text-muted small">
                    <span id="pagingInfo">—</span>
                </div>

                <div class="d-flex align-items-center flex-wrap" style="gap: 8px;">
                    <select id="pageSize" class="form-control form-control-sm" style="width: 90px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                    </select>

                    <button id="btnPrev" class="btn btn-sm btn-outline-secondary" type="button">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button id="btnNext" class="btn btn-sm btn-outline-secondary" type="button">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ===== Modal: Edit/Rating (1 modal dùng chung) ===== -->
<div class="modal fade" id="modalUser" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form id="formUser">
                <input type="hidden" id="editingId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Chi tiết người dùng</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="formError" class="alert alert-danger d-none"></div>

                    <div class="d-flex align-items-center" style="gap: 12px;">
                        <img id="uAvatar" src="" class="user-avatar-lg" />
                        <div>
                            <div class="font-weight-bold text-gray-900" id="uName">—</div>
                            <div class="small text-gray-500" id="uSub">—</div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Họ và tên</label>
                            <input id="fullName" class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Email</label>
                            <input id="email" class="form-control" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>Số điện thoại</label>
                            <input id="phone" class="form-control" />
                        </div>
                        <div class="form-group col-md-4">
                            <label>Thành phố</label>
                            <input id="city" class="form-control" />
                        </div>
                        <div class="form-group col-md-4">
                            <label>Giới tính</label>
                            <input id="gender" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Giới thiệu</label>
                        <textarea id="bio" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Điểm đơn</label>
                            <input id="ratingSingle" type="number" min="0" max="5" step="0.01" class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Điểm đôi</label>
                            <input id="ratingDouble" type="number" min="0" max="5" step="0.01" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex flex-wrap" style="gap: 8px;">
                        <button id="btnToggleActive" class="btn btn-outline-warning btn-sm" type="button">
                            <i class="fas fa-lock mr-1"></i> Chuyển trạng thái hoạt động
                        </button>

                        <button id="btnToggleVerified" class="btn btn-outline-success btn-sm" type="button">
                            <i class="fas fa-check mr-1"></i> Chuyển trạng thái xác minh
                        </button>
                    </div>

                    <div class="small text-muted mt-2" id="uMeta">—</div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    <button id="btnSubmit" class="btn btn-primary" type="submit">
                        <span class="mr-1"><i class="fas fa-save"></i></span> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        const API_BASE = "/api/admin/users";

        let state = {
            page: 1,
            pageSize: 20,
            total: 0,
            items: []
        };

        function escapeHtml(str) {
            return String(str || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function fmtDate(dt) {
            if (!dt) return "—";
            const d = new Date(dt);
            if (isNaN(d.getTime())) return "—";
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const dd = String(d.getDate()).padStart(2, "0");
            const hh = String(d.getHours()).padStart(2, "0");
            const mi = String(d.getMinutes()).padStart(2, "0");
            return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
        }

        function badgeVerified(v) {
            return v
                ? `<span class="badge badge-success">Đã xác minh</span>`
                : `<span class="badge badge-secondary">Chưa</span>`;
        }

        function badgeActive(v) {
            return v
                ? `<span class="badge badge-primary">Hoạt động</span>`
                : `<span class="badge badge-danger">Đã khóa</span>`;
        }

        function avatarHtml(url, name) {
            const safe = escapeHtml(name || "U");
            if (url) {
                return `<img src="${url}" class="user-avatar-sm" />`;
            }
            return `<div class="user-avatar-fallback">
                        ${safe.substring(0,1).toUpperCase()}
                    </div>`;
        }

        function showPageError(msg) {
            const box = document.getElementById("pageError");
            box.textContent = msg || "Đã xảy ra lỗi";
            box.classList.remove("d-none");
        }

        function clearPageError() {
            const box = document.getElementById("pageError");
            box.classList.add("d-none");
            box.textContent = "";
        }

        function showFormError(msg) {
            const box = document.getElementById("formError");
            box.textContent = msg || "Đã xảy ra lỗi";
            box.classList.remove("d-none");
        }

        function clearFormError() {
            const box = document.getElementById("formError");
            box.classList.add("d-none");
            box.textContent = "";
        }

        function rowHtml(u) {
            const userLine = `
                <div class="font-weight-bold text-gray-900">${escapeHtml(u.fullName || "—")}</div>
                <div class="small text-gray-500">
                    ${escapeHtml(u.email || "—")}
                    ${u.phone ? " • " + escapeHtml(u.phone) : ""}
                </div>`;

            const rs = (u.ratingSingle ?? 0);
            const rd = (u.ratingDouble ?? 0);

            return `
                <tr data-id="${u.userId}">
                    <td>${avatarHtml(u.avatarUrl, u.fullName)}</td>
                    <td>${userLine}</td>
                    <td>${escapeHtml(u.city || "—")}</td>
                    <td>${badgeVerified(!!u.verified)}</td>
                    <td>${badgeActive(!!u.isActive)}</td>
                    <td>${Number(rs).toFixed(2)} / ${Number(rd).toFixed(2)}</td>
                    <td>${fmtDate(u.createdAt)}</td>
                    <td style="white-space:nowrap">
                        <button class="btn btn-sm btn-outline-primary" onclick="openEdit(${u.userId})" type="button" title="Chỉnh sửa / Điểm trình độ">
                            <i class="fas fa-edit"></i>
                        </button>

                        <button class="btn btn-sm btn-outline-warning" onclick="toggleActive(${u.userId})" type="button" title="Khóa/Mở khóa">
                            <i class="fas fa-lock"></i>
                        </button>

                        <button class="btn btn-sm btn-outline-success" onclick="toggleVerified(${u.userId})" type="button" title="Xác minh">
                            <i class="fas fa-check"></i>
                        </button>
                    </td>
                </tr>
            `;
        }

        function updateRowInTable(u) {
            const row = document.querySelector(`#usersBody tr[data-id="${u.userId}"]`);
            if (!row) return;
            row.outerHTML = rowHtml(u);
        }

        function getFilters() {
            const keyword = document.getElementById("keyword").value.trim();
            const verified = document.getElementById("verifiedFilter").value;
            const active = document.getElementById("activeFilter").value;

            const params = {
                page: state.page,
                pageSize: state.pageSize
            };

            if (keyword) params.keyword = keyword;
            if (verified !== "ALL") params.verified = verified;
            if (active !== "ALL") params.active = active;

            return params;
        }

        async function loadUsers(resetPage = false) {
            if (resetPage) state.page = 1;

            clearPageError();
            const body = document.getElementById("usersBody");
            body.innerHTML = `<tr><td colspan="8" class="text-center text-muted">Đang tải...</td></tr>`;

            try {
                const res = await axios.get(API_BASE, { params: getFilters() });
                const items = res.data?.items || [];
                state.total = res.data?.total || 0;
                state.items = items;

                if (!items.length) {
                    body.innerHTML = `<tr><td colspan="8" class="text-center text-muted">Không có người dùng</td></tr>`;
                } else {
                    body.innerHTML = items.map(rowHtml).join("");
                }

                renderPaging();
            } catch (e) {
                body.innerHTML = `<tr><td colspan="8" class="text-center text-danger">Tải dữ liệu thất bại</td></tr>`;
                const msg = e?.response?.data?.message || e?.message || "Tải dữ liệu thất bại.";
                showPageError(String(msg));
            }
        }

        function renderPaging() {
            const info = document.getElementById("pagingInfo");
            const total = state.total || 0;
            const page = state.page || 1;
            const pageSize = state.pageSize || 20;
            const start = total === 0 ? 0 : ((page - 1) * pageSize + 1);
            const end = Math.min(page * pageSize, total);

            info.textContent = `Hiển thị ${start}-${end} trên tổng ${total}`;

            document.getElementById("btnPrev").disabled = page <= 1;
            document.getElementById("btnNext").disabled = end >= total;
        }

        function resetModal() {
            clearFormError();
            document.getElementById("formUser").reset();
            document.getElementById("editingId").value = "";

            document.getElementById("uAvatar").src = "";
            document.getElementById("uName").textContent = "—";
            document.getElementById("uSub").textContent = "—";
            document.getElementById("uMeta").textContent = "—";

            setSubmitText("Lưu");
        }

        function setSubmitText(text) {
            document.getElementById("btnSubmit").innerHTML =
                `<span class="mr-1"><i class="fas fa-save"></i></span> ${text}`;
        }

        function fillModal(u) {
            document.getElementById("editingId").value = String(u.userId);

            document.getElementById("uAvatar").src = u.avatarUrl || "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=";
            document.getElementById("uName").textContent = u.fullName || "—";
            document.getElementById("uSub").textContent = `${u.email || "—"}${u.phone ? " • " + u.phone : ""}`;

            document.getElementById("fullName").value = u.fullName || "";
            document.getElementById("email").value = u.email || "";
            document.getElementById("phone").value = u.phone || "";
            document.getElementById("city").value = u.city || "";
            document.getElementById("gender").value = u.gender || "";
            document.getElementById("bio").value = u.bio || "";

            if (u.ratingSingle !== undefined && u.ratingSingle !== null)
                document.getElementById("ratingSingle").value = u.ratingSingle;
            if (u.ratingDouble !== undefined && u.ratingDouble !== null)
                document.getElementById("ratingDouble").value = u.ratingDouble;

            const meta = `Xác minh: ${u.verified ? "Có" : "Không"} • Trạng thái: ${u.isActive ? "Hoạt động" : "Đã khóa"} • Ngày tạo: ${fmtDate(u.createdAt)}`;
            document.getElementById("uMeta").textContent = meta;

            const btnA = document.getElementById("btnToggleActive");
            btnA.innerHTML = u.isActive
                ? `<i class="fas fa-lock mr-1"></i> Khóa người dùng`
                : `<i class="fas fa-unlock mr-1"></i> Mở khóa người dùng`;

            const btnV = document.getElementById("btnToggleVerified");
            btnV.innerHTML = u.verified
                ? `<i class="fas fa-times mr-1"></i> Bỏ xác minh`
                : `<i class="fas fa-check mr-1"></i> Xác minh`;
        }

        async function openEdit(id) {
            resetModal();
            $("#modalUser").modal("show");

            try {
                const res = await axios.get(`${API_BASE}/${id}`);
                fillModal(res.data);
            } catch (e) {
                const msg = e?.response?.data?.message || e?.message || "Tải thông tin người dùng thất bại.";
                showFormError(String(msg));
            }
        }

        async function toggleActive(id) {
            try {
                await axios.post(`${API_BASE}/${id}/toggle-active`);
                const d = await axios.get(`${API_BASE}/${id}`);
                updateRowInTable(d.data);
            } catch (e) {
                alert(e?.response?.data?.message || e?.message || "Chuyển trạng thái hoạt động thất bại.");
            }
        }

        async function toggleVerified(id) {
            try {
                await axios.post(`${API_BASE}/${id}/toggle-verified`);
                const d = await axios.get(`${API_BASE}/${id}`);
                updateRowInTable(d.data);
            } catch (e) {
                alert(e?.response?.data?.message || e?.message || "Chuyển trạng thái xác minh thất bại.");
            }
        }

        async function modalToggleActive() {
            const id = document.getElementById("editingId").value;
            if (!id) return;

            try {
                await axios.post(`${API_BASE}/${id}/toggle-active`);
                const d = await axios.get(`${API_BASE}/${id}`);
                fillModal(d.data);
                updateRowInTable(d.data);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Chuyển trạng thái hoạt động thất bại.");
            }
        }

        async function modalToggleVerified() {
            const id = document.getElementById("editingId").value;
            if (!id) return;

            try {
                await axios.post(`${API_BASE}/${id}/toggle-verified`);
                const d = await axios.get(`${API_BASE}/${id}`);
                fillModal(d.data);
                updateRowInTable(d.data);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Chuyển trạng thái xác minh thất bại.");
            }
        }

        function buildUpdatePayload() {
            const singleValue = document.getElementById("ratingSingle").value;
            const doubleValue = document.getElementById("ratingDouble").value;

            return {
                fullName: document.getElementById("fullName").value || "",
                email: document.getElementById("email").value || "",
                phone: document.getElementById("phone").value || "",
                city: document.getElementById("city").value || "",
                gender: document.getElementById("gender").value || "",
                bio: document.getElementById("bio").value || "",
                ratingSingle: singleValue === "" ? null : parseFloat(singleValue),
                ratingDouble: doubleValue === "" ? null : parseFloat(doubleValue),
            };
        }

        document.addEventListener("DOMContentLoaded", () => {
            state.pageSize = parseInt(document.getElementById("pageSize").value, 10) || 20;
            loadUsers(true);

            document.getElementById("btnFilter").addEventListener("click", () => loadUsers(true));
            document.getElementById("btnRefresh").addEventListener("click", () => loadUsers(false));

            document.getElementById("keyword").addEventListener("keydown", (e) => {
                if (e.key === "Enter") loadUsers(true);
            });

            document.getElementById("pageSize").addEventListener("change", () => {
                state.pageSize = parseInt(document.getElementById("pageSize").value, 10) || 20;
                loadUsers(true);
            });

            document.getElementById("btnPrev").addEventListener("click", () => {
                if (state.page > 1) {
                    state.page--;
                    loadUsers(false);
                }
            });

            document.getElementById("btnNext").addEventListener("click", () => {
                state.page++;
                loadUsers(false);
            });

            document.getElementById("btnToggleActive").addEventListener("click", modalToggleActive);
            document.getElementById("btnToggleVerified").addEventListener("click", modalToggleVerified);

            document.getElementById("formUser").addEventListener("submit", async (e) => {
                e.preventDefault();
                clearFormError();

                const id = document.getElementById("editingId").value;
                if (!id) {
                    showFormError("Thiếu mã người dùng.");
                    return;
                }

                const btn = document.getElementById("btnSubmit");
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                try {
                    const payload = buildUpdatePayload();
                    const res = await axios.put(`${API_BASE}/${id}`, payload);

                    fillModal(res.data);
                    updateRowInTable(res.data);
                    $("#modalUser").modal("hide");
                } catch (err) {
                    const msg = err?.response?.data?.message || err?.response?.data || err?.message || "Lưu thất bại.";
                    showFormError(String(msg));
                } finally {
                    btn.disabled = false;
                    setSubmitText("Lưu");
                }
            });

            $("#modalUser").on("hidden.bs.modal", function () {
                resetModal();
            });
        });
    </script>
}
