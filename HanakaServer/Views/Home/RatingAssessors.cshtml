@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Đội chấm trình";
}

<style>
    .rating-assessor-toolbar {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rating-assessor-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .rating-assessor-filters .keyword {
        min-width: 260px;
        flex: 1 1 260px;
    }

    .avatar-sm {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #e3e6f0;
        background: #f8f9fc;
    }

    .avatar-fallback {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed #d1d3e2;
        color: #858796;
        font-weight: 700;
    }

    .lookup-card {
        border: 1px solid #e3e6f0;
        border-radius: 8px;
        padding: 12px;
        background: #fff;
    }

    @@media (max-width: 767.98px) {
        .rating-assessor-filters .keyword,
        .rating-assessor-filters select,
        .rating-assessor-filters button,
        .rating-assessor-toolbar button {
            width: 100%;
        }
    }
</style>

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Đội chấm trình</h1>
    <div class="rating-assessor-toolbar">
        <button id="btnAdd" class="btn btn-success btn-sm shadow-sm" type="button">
            <i class="fas fa-user-plus fa-sm text-white-50"></i> Gán quyền chấm trình
        </button>
        <button id="btnRefresh" class="btn btn-primary btn-sm shadow-sm" type="button">
            <i class="fas fa-sync fa-sm text-white-50"></i> Làm mới
        </button>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap" style="gap:12px;">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách nhân viên được gán quyền</h6>
            <div class="rating-assessor-filters">
                <input id="keyword" class="form-control form-control-sm keyword" placeholder="Tìm tên / email / phone / UserId" />
                <select id="activeFilter" class="form-control form-control-sm" style="width:170px;">
                    <option value="ALL" selected>Tất cả trạng thái</option>
                    <option value="true">Đang hoạt động</option>
                    <option value="false">Đã khóa</option>
                </select>
                <button id="btnFilter" class="btn btn-sm btn-outline-primary" type="button">Lọc</button>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div id="pageError" class="alert alert-danger d-none"></div>
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th style="width:72px;">Ảnh</th>
                        <th>Nhân viên</th>
                        <th>Thành phố</th>
                        <th>Trạng thái</th>
                        <th>Điểm hiện tại</th>
                        <th>Ngày gán quyền</th>
                        <th style="width:120px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="itemsBody">
                    <tr><td colspan="7" class="text-center text-muted">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap" style="gap:8px;">
            <div class="text-muted small" id="pagingInfo">—</div>
            <div class="d-flex align-items-center flex-wrap" style="gap:8px;">
                <select id="pageSize" class="form-control form-control-sm" style="width:90px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                </select>
                <button id="btnPrev" class="btn btn-sm btn-outline-secondary" type="button">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button id="btnNext" class="btn btn-sm btn-outline-secondary" type="button">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAssign" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form id="formAssign">
                <div class="modal-header">
                    <h5 class="modal-title">Gán quyền chấm trình</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div id="formError" class="alert alert-danger d-none"></div>

                    <div class="form-group">
                        <label>UserId</label>
                        <div class="input-group">
                            <input id="lookupUserId" class="form-control" type="number" min="1" placeholder="Nhập UserId của người dùng" />
                            <div class="input-group-append">
                                <button id="btnLookup" class="btn btn-outline-info" type="button">
                                    <i class="fas fa-search"></i> Tải user
                                </button>
                            </div>
                        </div>
                        <small class="form-text text-muted">
                            Người dùng đăng ký bình thường trước, admin chỉ gán thêm quyền RATING_ASSESSOR tại đây.
                        </small>
                    </div>

                    <div id="lookupBox" class="lookup-card d-none"></div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    <button id="btnSubmit" class="btn btn-primary" type="submit">
                        <i class="fas fa-check"></i> Gán quyền
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const API = "/api/admin/rating-assessors";
        const EMPTY_IMG = "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=";

        let state = {
            page: 1,
            pageSize: 20,
            total: 0,
            items: [],
            selectedUser: null
        };

        const $id = (id) => document.getElementById(id);

        function esc(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function fmtDate(value) {
            if (!value) return "—";
            const d = new Date(value);
            if (Number.isNaN(d.getTime())) return "—";
            const dd = String(d.getDate()).padStart(2, "0");
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const yyyy = d.getFullYear();
            const hh = String(d.getHours()).padStart(2, "0");
            const mi = String(d.getMinutes()).padStart(2, "0");
            return `${dd}/${mm}/${yyyy} ${hh}:${mi}`;
        }

        function fmtScore(value) {
            if (value === null || value === undefined) return "—";
            const n = Number(value);
            if (Number.isNaN(n)) return "—";
            return n.toFixed(2).replace(/\.?0+$/, "");
        }

        function avatarHtml(url, name) {
            if (url) return `<img class="avatar-sm" src="${esc(url)}" alt="" />`;
            const first = String(name || "U").substring(0, 1).toUpperCase();
            return `<span class="avatar-fallback">${esc(first)}</span>`;
        }

        function badgeActive(value) {
            return value
                ? `<span class="badge badge-primary">Đang hoạt động</span>`
                : `<span class="badge badge-danger">Đã khóa</span>`;
        }

        function showPageError(message) {
            const box = $id("pageError");
            box.textContent = message || "Đã xảy ra lỗi.";
            box.classList.remove("d-none");
        }

        function clearPageError() {
            const box = $id("pageError");
            box.textContent = "";
            box.classList.add("d-none");
        }

        function showFormError(message) {
            const box = $id("formError");
            box.textContent = message || "Đã xảy ra lỗi.";
            box.classList.remove("d-none");
        }

        function clearFormError() {
            const box = $id("formError");
            box.textContent = "";
            box.classList.add("d-none");
        }

        function rowHtml(item) {
            return `
                <tr data-user-id="${item.userId}">
                    <td>${avatarHtml(item.avatarUrl, item.fullName)}</td>
                    <td>
                        <div class="font-weight-bold text-gray-900">${esc(item.fullName || "—")}</div>
                        <div class="small text-gray-500">UserId: ${esc(item.userId)} • ${esc(item.email || "—")}${item.phone ? " • " + esc(item.phone) : ""}</div>
                    </td>
                    <td>${esc(item.city || "—")}</td>
                    <td>${badgeActive(!!item.isActive)}</td>
                    <td>
                        ${fmtScore(item.ratingSingle)} / ${fmtScore(item.ratingDouble)}
                        <div class="small text-muted">${fmtDate(item.ratingUpdatedAt)}</div>
                    </td>
                    <td>${fmtDate(item.assessorSince)}</td>
                    <td style="white-space:nowrap">
                        <button class="btn btn-sm btn-outline-danger" type="button" onclick="disableAssessor(${item.userId})">
                            <i class="fas fa-user-minus"></i>
                        </button>
                    </td>
                </tr>
            `;
        }

        function getFilters() {
            const params = {
                page: state.page,
                pageSize: state.pageSize
            };

            const keyword = $id("keyword").value.trim();
            const active = $id("activeFilter").value;

            if (keyword) params.keyword = keyword;
            if (active !== "ALL") params.active = active;
            return params;
        }

        async function loadItems(resetPage = false) {
            if (resetPage) state.page = 1;
            clearPageError();

            const body = $id("itemsBody");
            body.innerHTML = `<tr><td colspan="7" class="text-center text-muted">Đang tải...</td></tr>`;

            try {
                const res = await axios.get(API, { params: getFilters() });
                state.items = res.data?.items || [];
                state.total = res.data?.total || 0;

                body.innerHTML = state.items.length
                    ? state.items.map(rowHtml).join("")
                    : `<tr><td colspan="7" class="text-center text-muted">Chưa có nhân viên chấm trình</td></tr>`;

                renderPaging();
            } catch (err) {
                body.innerHTML = `<tr><td colspan="7" class="text-center text-danger">Tải dữ liệu thất bại</td></tr>`;
                showPageError(err?.response?.data?.message || err?.message || "Tải dữ liệu thất bại.");
            }
        }

        function renderPaging() {
            const total = state.total || 0;
            const page = state.page || 1;
            const pageSize = state.pageSize || 20;
            const start = total === 0 ? 0 : ((page - 1) * pageSize + 1);
            const end = Math.min(page * pageSize, total);
            $id("pagingInfo").textContent = `Hiển thị ${start}-${end} trên tổng ${total}`;
            $id("btnPrev").disabled = page <= 1;
            $id("btnNext").disabled = end >= total;
        }

        function resetModal() {
            clearFormError();
            state.selectedUser = null;
            $id("lookupUserId").value = "";
            $id("lookupBox").classList.add("d-none");
            $id("lookupBox").innerHTML = "";
        }

        function renderLookup(user) {
            state.selectedUser = user;
            const locked = user.isActive === false;
            const already = !!user.hasAssessorRole;
            $id("lookupBox").innerHTML = `
                <div class="d-flex align-items-center" style="gap:12px;">
                    ${avatarHtml(user.avatarUrl, user.fullName)}
                    <div class="flex-grow-1">
                        <div class="font-weight-bold">${esc(user.fullName || "—")}</div>
                        <div class="small text-muted">UserId: ${esc(user.userId)} • ${esc(user.email || "—")}${user.phone ? " • " + esc(user.phone) : ""}</div>
                        <div class="mt-1">
                            ${badgeActive(!locked)}
                            ${already ? `<span class="badge badge-success">Đã có quyền chấm trình</span>` : `<span class="badge badge-secondary">Chưa có quyền chấm trình</span>`}
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="small text-muted">Điểm hiện tại</div>
                        <div class="font-weight-bold">${fmtScore(user.ratingSingle)} / ${fmtScore(user.ratingDouble)}</div>
                    </div>
                </div>
            `;
            $id("lookupBox").classList.remove("d-none");
        }

        async function lookupUser() {
            clearFormError();
            const userId = Number($id("lookupUserId").value || 0);
            if (!userId) {
                showFormError("Vui lòng nhập UserId.");
                return;
            }

            try {
                const res = await axios.get(`${API}/lookup-user`, { params: { userId } });
                renderLookup(res.data);
            } catch (err) {
                state.selectedUser = null;
                $id("lookupBox").classList.add("d-none");
                showFormError(err?.response?.data?.message || err?.message || "Không tải được user.");
            }
        }

        async function submitAssign(e) {
            e.preventDefault();
            clearFormError();

            const userId = state.selectedUser?.userId || Number($id("lookupUserId").value || 0);
            if (!userId) {
                showFormError("Vui lòng tải user trước khi gán quyền.");
                return;
            }

            const btn = $id("btnSubmit");
            btn.disabled = true;
            btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang gán...`;

            try {
                await axios.post(`${API}/${userId}/enable`);
                $("#modalAssign").modal("hide");
                await loadItems(false);
            } catch (err) {
                showFormError(err?.response?.data?.message || err?.message || "Gán quyền thất bại.");
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i class="fas fa-check"></i> Gán quyền`;
            }
        }

        async function disableAssessor(userId) {
            if (!confirm("Bỏ quyền chấm trình của user này?")) return;

            try {
                await axios.post(`${API}/${userId}/disable`);
                await loadItems(false);
            } catch (err) {
                alert(err?.response?.data?.message || err?.message || "Bỏ quyền thất bại.");
            }
        }

        window.disableAssessor = disableAssessor;

        document.addEventListener("DOMContentLoaded", () => {
            state.pageSize = Number($id("pageSize").value || 20);
            loadItems(true);

            $id("btnAdd").addEventListener("click", () => {
                resetModal();
                $("#modalAssign").modal("show");
            });

            $id("btnRefresh").addEventListener("click", () => loadItems(false));
            $id("btnFilter").addEventListener("click", () => loadItems(true));
            $id("btnLookup").addEventListener("click", lookupUser);
            $id("formAssign").addEventListener("submit", submitAssign);

            $id("keyword").addEventListener("keydown", (e) => {
                if (e.key === "Enter") loadItems(true);
            });

            $id("lookupUserId").addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    lookupUser();
                }
            });

            $id("pageSize").addEventListener("change", () => {
                state.pageSize = Number($id("pageSize").value || 20);
                loadItems(true);
            });

            $id("btnPrev").addEventListener("click", () => {
                if (state.page > 1) {
                    state.page--;
                    loadItems(false);
                }
            });

            $id("btnNext").addEventListener("click", () => {
                state.page++;
                loadItems(false);
            });

            $("#modalAssign").on("hidden.bs.modal", resetModal);
        });
    </script>
}
