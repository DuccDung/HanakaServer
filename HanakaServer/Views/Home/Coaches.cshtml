@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Huấn luyện viên";
}

<style>
    .coach-toolbar {
        gap: 8px;
    }

    .filter-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        width: 100%;
    }

        .filter-toolbar .filter-keyword {
            flex: 1 1 320px;
            min-width: 220px;
        }

        .filter-toolbar .filter-verified {
            flex: 0 0 170px;
            min-width: 170px;
        }

        .filter-toolbar .filter-action {
            flex: 0 0 auto;
        }

    .coach-avatar-lg {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
        background: #f8f9fc;
    }

    .coach-avatar-sm {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
        background: #f8f9fc;
    }

    .coach-avatar-fallback {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px dashed #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        font-weight: 700;
        background: #fafafa;
    }

    .readonly-box {
        border: 1px solid #e3e6f0;
        border-radius: 0.35rem;
        background: #fff;
        padding: 12px;
    }

    .readonly-box-sm {
        min-height: 42px;
    }

    .modal-section-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #4e73df;
        margin-bottom: 10px;
    }

    .history-box {
        max-height: 240px;
        overflow: auto;
        border: 1px solid #e3e6f0;
        border-radius: 0.35rem;
        background: #fff;
    }

    .history-item {
        padding: 12px;
        border-bottom: 1px solid #edf2f9;
    }

        .history-item:last-child {
            border-bottom: none;
        }

    .small-muted {
        font-size: 12px;
        color: #858796;
    }

    .coach-link-warning {
        font-size: 12px;
    }

    .user-badge-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    @@media (max-width: 991.98px) {
        .card-header-responsive {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
        }

            .card-header-responsive h6 {
                margin-bottom: 0;
            }

        .filter-toolbar .filter-keyword,
        .filter-toolbar .filter-verified,
        .filter-toolbar .filter-action {
            flex: 1 1 100%;
            min-width: 100%;
        }

        .filter-toolbar .btn {
            width: 100%;
        }
    }

    @@media (max-width: 575.98px) {
        .page-title-bar {
            gap: 12px;
        }

            .page-title-bar > div:last-child {
                width: 100%;
            }

        .coach-toolbar {
            display: flex;
            flex-wrap: wrap;
            width: 100%;
        }

            .coach-toolbar button {
                flex: 1 1 calc(50% - 4px);
            }
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 page-title-bar">
        <h1 class="h3 mb-0 text-gray-800">Huấn luyện viên</h1>

        <div>
            <div class="d-flex coach-toolbar">
                <button id="btnAdd" class="btn btn-success btn-sm shadow-sm" type="button">
                    <i class="fas fa-plus fa-sm text-white-50"></i> Thêm huấn luyện viên
                </button>
                <button id="btnRefresh" class="btn btn-primary btn-sm shadow-sm" type="button">
                    <i class="fas fa-sync fa-sm text-white-50"></i> Làm mới
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between card-header-responsive">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách huấn luyện viên</h6>

            <div class="filter-toolbar">
                <div class="filter-keyword">
                    <input id="keyword" class="form-control form-control-sm w-100"
                           placeholder="Tìm theo tên / thành phố / loại / UserId" />
                </div>

                <div class="filter-verified">
                    <select id="verifiedFilter" class="form-control form-control-sm w-100">
                        <option value="ALL" selected>Tất cả xác minh coach</option>
                        <option value="true">Đã xác minh</option>
                        <option value="false">Chưa xác minh</option>
                    </select>
                </div>

                <div class="filter-action">
                    <button id="btnFilter" class="btn btn-sm btn-outline-primary" type="button">Lọc</button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div id="pageError" class="alert alert-danger d-none"></div>

            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width: 72px;">Ảnh</th>
                            <th>Huấn luyện viên</th>
                            <th>Thành phố</th>
                            <th>Xác minh coach</th>
                            <th>Xác minh user</th>
                            <th>Trình độ (Đơn / Đôi)</th>
                            <th>Loại</th>
                            <th style="width: 170px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itemsBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted">Đang tải...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap" style="gap: 8px;">
                <div class="text-muted small">
                    <span id="pagingInfo">—</span>
                </div>

                <div class="d-flex align-items-center flex-wrap" style="gap: 8px;">
                    <select id="pageSize" class="form-control form-control-sm" style="width: 90px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                    </select>

                    <button id="btnPrev" class="btn btn-sm btn-outline-secondary" type="button">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button id="btnNext" class="btn btn-sm btn-outline-secondary" type="button">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalItem" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <form id="formItem">
                <input type="hidden" id="editingId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Chi tiết huấn luyện viên</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="formError" class="alert alert-danger d-none"></div>

                    <div class="modal-section-title">Liên kết User</div>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label>UserId / ExternalId</label>
                            <div class="input-group">
                                <input id="externalId" class="form-control" placeholder="Nhập UserId" />
                                <div class="input-group-append">
                                    <button id="btnLookupUser" class="btn btn-outline-info" type="button">
                                        <i class="fas fa-search mr-1"></i> Tải User
                                    </button>
                                </div>
                            </div>
                            <small class="form-text text-muted">
                                Dữ liệu chuẩn hoá yêu cầu coach phải liên kết với User có thật. Tên, thành phố, ảnh, điểm trình sẽ lấy từ User.
                            </small>
                        </div>

                        <div class="form-group col-md-4">
                            <label>Loại huấn luyện viên</label>
                            <input id="coachType" class="form-control" value="Huấn luyện viên" />
                        </div>
                    </div>

                    <div class="readonly-box mb-3">
                        <div class="d-flex align-items-center" style="gap: 14px;">
                            <img id="uAvatar" src="" class="coach-avatar-lg" />

                            <div class="flex-grow-1">
                                <div class="font-weight-bold text-gray-900" id="uName">Chưa chọn user</div>
                                <div class="small text-gray-500" id="uSub">—</div>
                                <div class="mt-2 user-badge-wrap" id="uBadges"></div>
                            </div>
                        </div>

                        <div id="coachLinkWarning" class="alert alert-warning coach-link-warning d-none mt-3 mb-0"></div>

                        <div class="form-row mt-3">
                            <div class="form-group col-md-3 mb-2">
                                <div class="small-muted">Email</div>
                                <div id="uEmail" class="readonly-box readonly-box-sm">—</div>
                            </div>
                            <div class="form-group col-md-3 mb-2">
                                <div class="small-muted">Số điện thoại</div>
                                <div id="uPhone" class="readonly-box readonly-box-sm">—</div>
                            </div>
                            <div class="form-group col-md-3 mb-2">
                                <div class="small-muted">Giới tính</div>
                                <div id="uGender" class="readonly-box readonly-box-sm">—</div>
                            </div>
                            <div class="form-group col-md-3 mb-2">
                                <div class="small-muted">Ngày sinh</div>
                                <div id="uBirthOfDate" class="readonly-box readonly-box-sm">—</div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group col-md-4 mb-2">
                                <div class="small-muted">Điểm đơn hiện tại</div>
                                <div id="uRatingSingle" class="readonly-box readonly-box-sm">—</div>
                            </div>
                            <div class="form-group col-md-4 mb-2">
                                <div class="small-muted">Điểm đôi hiện tại</div>
                                <div id="uRatingDouble" class="readonly-box readonly-box-sm">—</div>
                            </div>
                            <div class="form-group col-md-4 mb-2">
                                <div class="small-muted">Cập nhật điểm gần nhất</div>
                                <div id="uRatingUpdatedAt" class="readonly-box readonly-box-sm">—</div>
                            </div>
                        </div>

                        <div class="form-group mb-0">
                            <div class="small-muted">Giới thiệu cá nhân (User.Bio)</div>
                            <div id="uBio" class="readonly-box" style="min-height:72px;">—</div>
                        </div>
                    </div>

                    <div class="modal-section-title">Thông tin riêng của hồ sơ huấn luyện viên</div>

                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label>Giới thiệu giảng dạy</label>
                            <textarea id="introduction" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label>Khu vực giảng dạy</label>
                            <textarea id="teachingArea" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label>Thành tích / chứng chỉ huấn luyện</label>
                            <textarea id="achievements" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap align-items-center" style="gap: 12px;">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="verified">
                            <label class="custom-control-label" for="verified">Đã xác minh hồ sơ coach</label>
                        </div>

                        <button id="btnSyncFromUser" class="btn btn-outline-info btn-sm" type="button">
                            <i class="fas fa-sync mr-1"></i> Đồng bộ từ User
                        </button>

                        <button id="btnToggleVerified" class="btn btn-outline-success btn-sm" type="button">
                            <i class="fas fa-check mr-1"></i> Chuyển trạng thái xác minh
                        </button>

                        <button id="btnDelete" class="btn btn-outline-danger btn-sm ml-auto" type="button">
                            <i class="fas fa-trash mr-1"></i> Xóa
                        </button>
                    </div>

                    <hr />

                    <div class="form-row">
                        <div class="form-group col-lg-6">
                            <div class="modal-section-title mb-2">Lịch sử điểm trình</div>
                            <div id="ratingHistoryBox" class="history-box">
                                <div class="history-item text-muted text-center">Chưa có dữ liệu</div>
                            </div>
                        </div>

                        <div class="form-group col-lg-6">
                            <div class="modal-section-title mb-2">Thành tích thi đấu</div>
                            <div id="userAchievementsBox" class="history-box">
                                <div class="history-item text-muted text-center">Chưa có dữ liệu</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    <button id="btnSubmit" class="btn btn-primary" type="submit">
                        <span class="mr-1"><i class="fas fa-save"></i></span> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const API_BASE = "/api/admin/coaches";
        const EMPTY_IMG = "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=";

        let state = {
            page: 1,
            pageSize: 20,
            total: 0,
            items: []
        };

        function escapeHtml(str) {
            return String(str || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatScore(v) {
            const n = Number(v || 0);
            return n % 1 === 0 ? `${n}` : n.toFixed(2).replace(/\.?0+$/, "");
        }

        function formatDate(value) {
            if (!value) return "—";
            try {
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return String(value);
                const dd = String(d.getDate()).padStart(2, "0");
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const yyyy = d.getFullYear();
                return `${dd}/${mm}/${yyyy}`;
            } catch {
                return String(value);
            }
        }

        function formatDateTime(value) {
            if (!value) return "—";
            try {
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return String(value);
                const dd = String(d.getDate()).padStart(2, "0");
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const yyyy = d.getFullYear();
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");
                return `${dd}/${mm}/${yyyy} ${hh}:${mi}`;
            } catch {
                return String(value);
            }
        }

        function getCoachTypeLabel(type) {
            const value = String(type || "COACH").trim().toUpperCase();
            switch (value) {
                case "COACH":
                    return "Huấn luyện viên";
                default:
                    return type || "Huấn luyện viên";
            }
        }

        function normalizeCoachTypeForApi(value) {
            const raw = String(value || "").trim();
            if (!raw) return "COACH";

            const normalized = raw.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();

            if (normalized === "HUAN LUYEN VIEN" || normalized === "COACH") {
                return "COACH";
            }

            return raw.toUpperCase();
        }

        function badgeVerified(v, okText = "Đã xác minh", noText = "Chưa xác minh") {
            return v
                ? `<span class="badge badge-success">${escapeHtml(okText)}</span>`
                : `<span class="badge badge-secondary">${escapeHtml(noText)}</span>`;
        }

        function badgeUserActive(v) {
            return v
                ? `<span class="badge badge-info">User đang hoạt động</span>`
                : `<span class="badge badge-warning">User không hoạt động</span>`;
        }

        function badgeLinkStatus(item) {
            if (!item?.hasLinkedUser) {
                return `<span class="badge badge-danger">Chưa link User</span>`;
            }

            if (!item?.userIsActive) {
                return `<span class="badge badge-warning">User inactive</span>`;
            }

            return `<span class="badge badge-primary">Đã link User</span>`;
        }

        function avatarHtml(url, name) {
            const safe = escapeHtml(name || "C");
            if (url) {
                return `<img src="${escapeHtml(url)}" class="coach-avatar-sm" />`;
            }
            return `<div class="coach-avatar-fallback">${safe.substring(0, 1).toUpperCase()}</div>`;
        }

        function showPageError(msg) {
            const box = document.getElementById("pageError");
            box.textContent = msg || "Có lỗi xảy ra";
            box.classList.remove("d-none");
        }

        function clearPageError() {
            const box = document.getElementById("pageError");
            box.classList.add("d-none");
            box.textContent = "";
        }

        function showFormError(msg) {
            const box = document.getElementById("formError");
            box.textContent = msg || "Có lỗi xảy ra";
            box.classList.remove("d-none");
        }

        function clearFormError() {
            const box = document.getElementById("formError");
            box.classList.add("d-none");
            box.textContent = "";
        }

        function renderRatingHistory(items) {
            const box = document.getElementById("ratingHistoryBox");
            const list = Array.isArray(items) ? items : [];

            if (!list.length) {
                box.innerHTML = `<div class="history-item text-muted text-center">Chưa có lịch sử điểm trình</div>`;
                return;
            }

            box.innerHTML = list.map(x => `
                <div class="history-item">
                    <div class="font-weight-bold text-gray-900">${escapeHtml(formatDateTime(x.ratedAt))}</div>
                    <div class="small-muted mt-1">
                        Điểm đơn: <strong>${escapeHtml(formatScore(x.ratingSingle))}</strong> |
                        Điểm đôi: <strong>${escapeHtml(formatScore(x.ratingDouble))}</strong>
                    </div>
                    <div class="small-muted mt-1">
                        Người chấm: <strong>${escapeHtml(x.ratedByName || "Hệ thống")}</strong>
                    </div>
                    <div class="small-muted mt-1">
                        Ghi chú: ${escapeHtml(x.note || "—")}
                    </div>
                </div>
            `).join("");
        }

        function renderUserAchievements(items) {
            const box = document.getElementById("userAchievementsBox");
            const list = Array.isArray(items) ? items : [];

            if (!list.length) {
                box.innerHTML = `<div class="history-item text-muted text-center">Chưa có thành tích thi đấu</div>`;
                return;
            }

            box.innerHTML = list.map(x => `
                <div class="history-item">
                    <div class="font-weight-bold text-gray-900">${escapeHtml(x.title || x.tournamentName || "Thành tích")}</div>
                    <div class="small-muted mt-1">
                        ${escapeHtml(x.achievementLabel || x.achievementType || "Thành tích")}
                    </div>
                    <div class="small-muted mt-1">
                        Ngày: ${escapeHtml(formatDate(x.date || x.achievedAt || x.createdAt))}
                    </div>
                    <div class="small-muted mt-1">
                        Ghi chú: ${escapeHtml(x.note || "—")}
                    </div>
                </div>
            `).join("");
        }

        function clearUserPreview() {
            document.getElementById("uAvatar").src = EMPTY_IMG;
            document.getElementById("uName").textContent = "Chưa chọn user";
            document.getElementById("uSub").textContent = "—";
            document.getElementById("uBadges").innerHTML = "";
            document.getElementById("uEmail").textContent = "—";
            document.getElementById("uPhone").textContent = "—";
            document.getElementById("uGender").textContent = "—";
            document.getElementById("uBirthOfDate").textContent = "—";
            document.getElementById("uRatingSingle").textContent = "—";
            document.getElementById("uRatingDouble").textContent = "—";
            document.getElementById("uRatingUpdatedAt").textContent = "—";
            document.getElementById("uBio").textContent = "—";

            const warn = document.getElementById("coachLinkWarning");
            warn.classList.add("d-none");
            warn.textContent = "";

            renderRatingHistory([]);
            renderUserAchievements([]);
        }

        function setLinkWarning(message) {
            const warn = document.getElementById("coachLinkWarning");
            if (!message) {
                warn.classList.add("d-none");
                warn.textContent = "";
                return;
            }

            warn.classList.remove("d-none");
            warn.textContent = message;
        }

        function renderPreviewBadges(data, editingCoachId = null) {
            const badges = [];

            badges.push(data?.verified
                ? `<span class="badge badge-success">User đã xác minh</span>`
                : `<span class="badge badge-secondary">User chưa xác minh</span>`);

            badges.push(data?.isActive === false
                ? `<span class="badge badge-warning">User không hoạt động</span>`
                : `<span class="badge badge-info">User đang hoạt động</span>`);

            if (data?.existingCoachId) {
                const sameCoach = String(editingCoachId || "") === String(data.existingCoachId);
                badges.push(
                    sameCoach
                        ? `<span class="badge badge-primary">Đang liên kết hồ sơ coach #${escapeHtml(data.existingCoachId)}</span>`
                        : `<span class="badge badge-danger">Đã có coach #${escapeHtml(data.existingCoachId)}</span>`
                );
            }

            return badges.join(" ");
        }

        function setUserPreviewFromLookup(data) {
            document.getElementById("uAvatar").src = data?.avatarUrl || EMPTY_IMG;
            document.getElementById("uName").textContent = data?.fullName || "—";
            document.getElementById("uSub").textContent = `${data?.city || "—"} • UserId: ${data?.userId || "—"}`;
            document.getElementById("uBadges").innerHTML = renderPreviewBadges(data, document.getElementById("editingId").value || null);

            document.getElementById("uEmail").textContent = data?.email || "—";
            document.getElementById("uPhone").textContent = data?.phone || "—";
            document.getElementById("uGender").textContent = data?.gender || "—";
            document.getElementById("uBirthOfDate").textContent = formatDate(data?.birthOfDate);
            document.getElementById("uRatingSingle").textContent = formatScore(data?.ratingSingle);
            document.getElementById("uRatingDouble").textContent = formatScore(data?.ratingDouble);
            document.getElementById("uRatingUpdatedAt").textContent = formatDateTime(data?.ratingUpdatedAt);
            document.getElementById("uBio").textContent = data?.bio || "—";

            setLinkWarning(data?.isActive === false ? "User này đang bị vô hiệu hoá. Không thể liên kết làm coach." : "");
        }

        function setUserPreviewFromDetail(data) {
            document.getElementById("uAvatar").src = data?.avatarUrl || EMPTY_IMG;
            document.getElementById("uName").textContent = data?.fullName || "—";
            document.getElementById("uSub").textContent =
                `${data?.city || "—"} • UserId: ${data?.userId || data?.externalId || "—"}`;

            document.getElementById("uBadges").innerHTML = [
                badgeVerified(!!data?.userVerified, "User đã xác minh", "User chưa xác minh"),
                badgeUserActive(!!data?.userIsActive),
                badgeLinkStatus(data)
            ].join(" ");

            document.getElementById("uEmail").textContent = data?.email || "—";
            document.getElementById("uPhone").textContent = data?.phone || "—";
            document.getElementById("uGender").textContent = data?.gender || "—";
            document.getElementById("uBirthOfDate").textContent = formatDate(data?.birthOfDate);
            document.getElementById("uRatingSingle").textContent = formatScore(data?.levelSingle);
            document.getElementById("uRatingDouble").textContent = formatScore(data?.levelDouble);
            document.getElementById("uRatingUpdatedAt").textContent = formatDateTime(data?.ratingUpdatedAt);
            document.getElementById("uBio").textContent = data?.bio || "—";

            setLinkWarning(data?.linkWarning || "");
            renderRatingHistory(data?.ratingHistory || []);
            renderUserAchievements(data?.userAchievements || []);
        }

        function rowHtml(u) {
            const infoLine = `
                <div class="font-weight-bold text-gray-900">${escapeHtml(u.fullName || "—")}</div>
                <div class="small text-gray-500">UserId / ExternalId: ${escapeHtml(u.externalId || "—")}</div>
                <div class="small text-gray-500">${escapeHtml(u.email || "—")} ${u.phone ? `• ${escapeHtml(u.phone)}` : ""}</div>
                <div class="mt-1">${badgeLinkStatus(u)} ${u.linkWarning ? `<span class="badge badge-warning">${escapeHtml(u.linkWarning)}</span>` : ""}</div>
            `;

            return `
                <tr data-id="${u.coachId}">
                    <td>${avatarHtml(u.avatarUrl, u.fullName)}</td>
                    <td>${infoLine}</td>
                    <td>${escapeHtml(u.city || "—")}</td>
                    <td>${badgeVerified(!!u.verified, "Đã xác minh", "Chưa")}</td>
                    <td>${badgeVerified(!!u.userVerified, "Đã xác minh", "Chưa")}</td>
                    <td>
                        ${escapeHtml(formatScore(u.levelSingle))} / ${escapeHtml(formatScore(u.levelDouble))}
                        <div class="small text-muted">${escapeHtml(formatDateTime(u.ratingUpdatedAt))}</div>
                    </td>
                    <td>${escapeHtml(getCoachTypeLabel(u.coachType))}</td>
                    <td style="white-space:nowrap">
                        <button class="btn btn-sm btn-outline-primary" onclick="openEdit(${u.coachId})" type="button">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-success" onclick="toggleVerified(${u.coachId})" type="button">
                            <i class="fas fa-check"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(${u.coachId})" type="button">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
        }

        function updateRowInTable(u) {
            const row = document.querySelector(`#itemsBody tr[data-id="${u.coachId}"]`);
            if (!row) return;
            row.outerHTML = rowHtml(u);
        }

        function getFilters() {
            const keyword = document.getElementById("keyword").value.trim();
            const verified = document.getElementById("verifiedFilter").value;

            const params = {
                page: state.page,
                pageSize: state.pageSize
            };

            if (keyword) params.keyword = keyword;
            if (verified !== "ALL") params.verified = verified;

            return params;
        }

        async function loadItems(resetPage = false) {
            if (resetPage) state.page = 1;

            clearPageError();

            const body = document.getElementById("itemsBody");
            body.innerHTML = `<tr><td colspan="8" class="text-center text-muted">Đang tải...</td></tr>`;

            try {
                const res = await axios.get(API_BASE, { params: getFilters() });
                const items = res.data?.items || [];

                state.total = res.data?.total || 0;
                state.items = items;

                if (!items.length) {
                    body.innerHTML = `<tr><td colspan="8" class="text-center text-muted">Không có huấn luyện viên</td></tr>`;
                } else {
                    body.innerHTML = items.map(rowHtml).join("");
                }

                renderPaging();
            } catch (e) {
                body.innerHTML = `<tr><td colspan="8" class="text-center text-danger">Tải dữ liệu thất bại</td></tr>`;
                showPageError(e?.response?.data?.message || e?.message || "Tải dữ liệu thất bại.");
            }
        }

        function renderPaging() {
            const info = document.getElementById("pagingInfo");
            const total = state.total || 0;
            const page = state.page || 1;
            const pageSize = state.pageSize || 20;
            const start = total === 0 ? 0 : ((page - 1) * pageSize + 1);
            const end = Math.min(page * pageSize, total);

            info.textContent = `Hiển thị ${start}-${end} trên tổng ${total}`;
            document.getElementById("btnPrev").disabled = page <= 1;
            document.getElementById("btnNext").disabled = end >= total;
        }

        function resetModal() {
            clearFormError();
            document.getElementById("formItem").reset();
            document.getElementById("editingId").value = "";
            document.getElementById("coachType").value = "Huấn luyện viên";
            document.getElementById("verified").checked = false;

            clearUserPreview();

            document.getElementById("btnDelete").classList.add("d-none");
            document.getElementById("btnToggleVerified").classList.add("d-none");
            document.getElementById("btnSyncFromUser").classList.add("d-none");

            document.getElementById("modalTitle").textContent = "Thêm huấn luyện viên";
        }

        function fillModal(u) {
            document.getElementById("editingId").value = String(u.coachId);
            document.getElementById("externalId").value = u.externalId || "";
            document.getElementById("coachType").value = getCoachTypeLabel(u.coachType);
            document.getElementById("verified").checked = !!u.verified;
            document.getElementById("introduction").value = u.introduction || "";
            document.getElementById("teachingArea").value = u.teachingArea || "";
            document.getElementById("achievements").value = u.achievements || "";

            setUserPreviewFromDetail(u);

            document.getElementById("btnDelete").classList.remove("d-none");
            document.getElementById("btnToggleVerified").classList.remove("d-none");
            document.getElementById("btnSyncFromUser").classList.remove("d-none");

            document.getElementById("modalTitle").textContent = "Chi tiết huấn luyện viên";
        }

        function buildPayload() {
            return {
                externalId: document.getElementById("externalId").value || null,
                verified: document.getElementById("verified").checked,
                coachType: normalizeCoachTypeForApi(document.getElementById("coachType").value),
                introduction: document.getElementById("introduction").value || null,
                teachingArea: document.getElementById("teachingArea").value || null,
                achievements: document.getElementById("achievements").value || null
            };
        }

        async function lookupUserPreview(showError = true) {
            const externalId = document.getElementById("externalId").value.trim();
            if (!externalId) {
                clearUserPreview();
                return;
            }

            try {
                const res = await axios.get(`${API_BASE}/lookup-user`, {
                    params: { externalId }
                });

                setUserPreviewFromLookup(res.data);
            } catch (e) {
                clearUserPreview();

                const msg = e?.response?.data?.message || e?.message || "Không tải được user.";
                setLinkWarning(msg);

                if (showError) {
                    showFormError(msg);
                }
            }
        }

        async function openCreate() {
            resetModal();
            $("#modalItem").modal("show");
        }

        async function openEdit(id) {
            resetModal();
            $("#modalItem").modal("show");

            try {
                const res = await axios.get(`${API_BASE}/${id}`);
                fillModal(res.data);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Tải chi tiết thất bại.");
            }
        }

        async function toggleVerified(id) {
            try {
                const res = await axios.post(`${API_BASE}/${id}/toggle-verified`);
                updateRowInTable(res.data);
            } catch (e) {
                alert(e?.response?.data?.message || e?.message || "Chuyển trạng thái xác minh thất bại.");
            }
        }

        async function modalToggleVerified() {
            const id = document.getElementById("editingId").value;
            if (!id) return;

            try {
                const res = await axios.post(`${API_BASE}/${id}/toggle-verified`);
                fillModal(res.data);
                updateRowInTable(res.data);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Chuyển trạng thái xác minh thất bại.");
            }
        }

        async function modalSyncFromUser() {
            const id = document.getElementById("editingId").value;
            if (!id) return;

            try {
                const res = await axios.post(`${API_BASE}/${id}/sync-from-user`);
                fillModal(res.data);
                updateRowInTable(res.data);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Đồng bộ từ User thất bại.");
            }
        }

        async function deleteItem(id) {
            if (!confirm("Bạn có chắc muốn xóa huấn luyện viên này?")) return;

            try {
                await axios.delete(`${API_BASE}/${id}`);
                loadItems(false);
            } catch (e) {
                alert(e?.response?.data?.message || e?.message || "Xóa thất bại.");
            }
        }

        async function modalDelete() {
            const id = document.getElementById("editingId").value;
            if (!id) return;
            if (!confirm("Bạn có chắc muốn xóa huấn luyện viên này?")) return;

            try {
                await axios.delete(`${API_BASE}/${id}`);
                $("#modalItem").modal("hide");
                loadItems(false);
            } catch (e) {
                showFormError(e?.response?.data?.message || e?.message || "Xóa thất bại.");
            }
        }

        window.openEdit = openEdit;
        window.toggleVerified = toggleVerified;
        window.deleteItem = deleteItem;

        document.addEventListener("DOMContentLoaded", () => {
            state.pageSize = parseInt(document.getElementById("pageSize").value, 10) || 20;
            loadItems(true);

            document.getElementById("btnAdd").addEventListener("click", openCreate);
            document.getElementById("btnRefresh").addEventListener("click", () => loadItems(false));
            document.getElementById("btnFilter").addEventListener("click", () => loadItems(true));

            document.getElementById("keyword").addEventListener("keydown", (e) => {
                if (e.key === "Enter") loadItems(true);
            });

            document.getElementById("pageSize").addEventListener("change", () => {
                state.pageSize = parseInt(document.getElementById("pageSize").value, 10) || 20;
                loadItems(true);
            });

            document.getElementById("btnPrev").addEventListener("click", () => {
                if (state.page > 1) {
                    state.page--;
                    loadItems(false);
                }
            });

            document.getElementById("btnNext").addEventListener("click", () => {
                state.page++;
                loadItems(false);
            });

            document.getElementById("btnLookupUser").addEventListener("click", () => {
                clearFormError();
                lookupUserPreview(true);
            });

            document.getElementById("externalId").addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    clearFormError();
                    lookupUserPreview(true);
                }
            });

            document.getElementById("externalId").addEventListener("blur", () => {
                const editingId = document.getElementById("editingId").value;
                if (!editingId) {
                    lookupUserPreview(false);
                }
            });

            document.getElementById("btnToggleVerified").addEventListener("click", modalToggleVerified);
            document.getElementById("btnSyncFromUser").addEventListener("click", modalSyncFromUser);
            document.getElementById("btnDelete").addEventListener("click", modalDelete);

            document.getElementById("formItem").addEventListener("submit", async (e) => {
                e.preventDefault();
                clearFormError();

                const id = document.getElementById("editingId").value;
                const payload = buildPayload();

                const btn = document.getElementById("btnSubmit");
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                try {
                    let res;
                    if (id) {
                        res = await axios.put(`${API_BASE}/${id}`, payload);
                        updateRowInTable(res.data);
                    } else {
                        res = await axios.post(API_BASE, payload);
                    }

                    $("#modalItem").modal("hide");
                    loadItems(false);
                } catch (err) {
                    showFormError(err?.response?.data?.message || err?.message || "Lưu thất bại.");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = `<span class="mr-1"><i class="fas fa-save"></i></span> Lưu`;
                }
            });

            $("#modalItem").on("hidden.bs.modal", function () {
                resetModal();
            });
        });
    </script>
}