@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Giải đấu";
}

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />

<style>
    .ql-editor {
        min-height: 180px;
        font-size: 14px;
    }

    .rule-preview-lite {
        max-height: 56px;
        overflow: hidden;
        color: #6c757d;
    }

        .rule-preview-lite p,
        .rule-preview-lite ul,
        .rule-preview-lite ol {
            margin-bottom: 0.25rem;
        }

    .tournament-pagination {
        gap: 10px;
        padding-top: 14px;
        border-top: 1px solid #eef2f7;
    }

    .tournament-pagination__info {
        color: #6c757d;
        font-size: 0.875rem;
        font-weight: 700;
    }

    .tournament-pagination__controls {
        gap: 8px;
    }

    .tournament-page-numbers {
        gap: 6px;
    }

    .tournament-page-btn {
        min-width: 34px;
        height: 31px;
        padding: 0 9px;
        border: 1px solid #dbe4f0;
        border-radius: 8px;
        background: #fff;
        color: #4e73df;
        font-size: 0.8125rem;
        font-weight: 800;
        transition: all 0.18s ease;
    }

        .tournament-page-btn:hover {
            border-color: #4e73df;
            background: #eef2ff;
            color: #224abe;
        }

        .tournament-page-btn.active {
            border-color: #4e73df;
            background: #4e73df;
            color: #fff;
            box-shadow: 0 8px 18px rgba(78, 115, 223, 0.24);
        }

        .tournament-page-btn:disabled {
            cursor: not-allowed;
            opacity: 0.55;
        }

    @@media (max-width: 767.98px) {
        .tournament-pagination {
            align-items: stretch !important;
        }

        .tournament-pagination__controls {
            width: 100%;
            justify-content: space-between;
        }

        .tournament-page-numbers {
            order: 3;
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Giải đấu</h1>

        <button id="btnOpenCreate"
                class="btn btn-primary btn-sm shadow-sm"
                type="button">
            <i class="fas fa-plus fa-sm text-white-50"></i> Tạo giải đấu
        </button>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách giải đấu</h6>
            <div class="d-flex" style="gap: 8px">
                <select id="statusFilter" class="form-control form-control-sm" style="width: 140px;">
                    <option value="ALL" selected>Tất cả trạng thái</option>
                    <option value="OPEN">Mở đăng ký</option>
                    <option value="CLOSED">Đã đóng</option>
                    <option value="DRAFT">Bản nháp</option>
                </select>
                <button id="btnFilter" class="btn btn-sm btn-outline-primary" type="button">Lọc</button>
            </div>
        </div>

        <div class="card-body">
            <div id="pageError" class="alert alert-danger d-none"></div>

            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Ảnh banner</th>
                            <th>Tiêu đề</th>
                            <th>Trạng thái</th>
                            <th>Ngày bắt đầu</th>
                            <th>Hạn đăng ký</th>
                            <th>Nội dung thi đấu</th>
                            <th>Số đội</th>
                            <th>Giới hạn đơn</th>
                            <th>Giới hạn đôi</th>
                            <th style="width: 250px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="tournamentsBody">
                        <tr>
                            <td colspan="10" class="text-center text-muted">Đang tải...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="tournament-pagination d-flex justify-content-between align-items-center flex-wrap">
                <div class="tournament-pagination__info">
                    <span id="pagingInfo">—</span>
                </div>

                <div class="tournament-pagination__controls d-flex align-items-center flex-wrap">
                    <select id="pageSize" class="form-control form-control-sm" style="width: 96px;">
                        <option value="10" selected>10 dòng</option>
                        <option value="20">20 dòng</option>
                        <option value="50">50 dòng</option>
                    </select>

                    <button id="btnFirst" class="btn btn-sm btn-outline-secondary" type="button" title="Trang đầu">
                        <i class="fas fa-angle-double-left"></i>
                    </button>
                    <button id="btnPrev" class="btn btn-sm btn-outline-secondary" type="button" title="Trang trước">
                        <i class="fas fa-chevron-left"></i>
                    </button>

                    <div id="pageNumbers" class="tournament-page-numbers d-flex align-items-center flex-wrap"></div>

                    <button id="btnNext" class="btn btn-sm btn-outline-secondary" type="button" title="Trang sau">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                    <button id="btnLast" class="btn btn-sm btn-outline-secondary" type="button" title="Trang cuối">
                        <i class="fas fa-angle-double-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTournament" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <form id="formTournament">
                <input type="hidden" id="mode" value="create" />
                <input type="hidden" id="editingId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Tạo giải đấu</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="formError" class="alert alert-danger d-none"></div>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label>Tiêu đề *</label>
                            <input id="title" class="form-control" placeholder="Hanaka Cup 2026" required />
                        </div>
                        <div class="form-group col-md-4">
                            <label>Trạng thái</label>
                            <select id="status" class="form-control">
                                <option value="DRAFT" selected>Bản nháp</option>
                                <option value="OPEN">Mở đăng ký</option>
                                <option value="CLOSED">Đã đóng</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>Nội dung thi đấu *</label>
                            <select id="tournamentType" class="form-control" required>
                                <option value="" selected>Chọn nội dung thi đấu</option>
                                <option value="SINGLE_MEN">Đơn Nam</option>
                                <option value="SINGLE_WOMEN">Đơn Nữ</option>
                                <option value="DOUBLE_MEN">Đôi Nam</option>
                                <option value="DOUBLE_WOMEN">Đôi Nữ</option>
                                <option value="DOUBLE_MIXED">Hỗn Hợp Nam Nữ</option>
                                <option value="SINGLE_OPEN">Đơn Mở / Dữ Liệu Cũ</option>
                                <option value="DOUBLE_OPEN">Đôi Mở / Dữ Liệu Cũ</option>
                            </select>
                            <small class="text-muted d-block mt-2">
                                Đơn Nam = SINGLE + MEN • Đơn Nữ = SINGLE + WOMEN • Đôi Nam = DOUBLE + MEN • Đôi Nữ = DOUBLE + WOMEN • Hỗn Hợp Nam Nữ = DOUBLE + MIXED
                            </small>
                        </div>
                        <div class="form-group col-md-4">
                            <label>Số đội dự kiến</label>
                            <input id="expectedTeams" type="number" class="form-control" value="16" min="0" />
                        </div>
                        <div class="form-group col-md-4">
                            <label>Khu vực</label>
                            <input id="areaText" class="form-control" placeholder="Hà Nội / HCM ..." />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Thời gian bắt đầu</label>
                            <input id="startTime" type="datetime-local" class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Hạn đăng ký</label>
                            <input id="registerDeadline" type="datetime-local" class="form-control" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Địa điểm</label>
                            <input id="locationText" class="form-control" placeholder="Sân pickleball ..." />
                        </div>
                        <div class="form-group col-md-3">
                            <label>Giới hạn đơn</label>
                            <input id="singleLimit" type="number" step="0.01" class="form-control" value="0" />
                        </div>
                        <div class="form-group col-md-3">
                            <label>Giới hạn đôi</label>
                            <input id="doubleLimit" type="number" step="0.01" class="form-control" value="0" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Đơn vị tổ chức</label>
                            <input id="organizer" class="form-control" placeholder="CLB / Trung tâm / Nhà tài trợ..." />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Người tạo giải</label>
                            <input id="creatorName" class="form-control" placeholder="Tên người tạo giải..." />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label>Thể thức thi đấu mở rộng</label>
                            <input id="formatText" class="form-control" placeholder="VD: Vòng bảng + loại trực tiếp, BO3, 11 điểm..." />
                        </div>
                        <div class="form-group col-md-4">
                            <label>Loại vòng loại</label>
                            <input id="playoffType" class="form-control" placeholder="VD: Knockout / RoundRobin / Swiss..." />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Nội dung</label>
                        <textarea id="tournament_content"
                                  name="content"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Ghi chú ngắn / mô tả phụ..."></textarea>
                    </div>

                    <div class="form-group">
                        <label>Thể lệ giải</label>
                        <div id="tournamentRuleEditor" style="background:#fff;"></div>
                        <small class="text-muted d-block mt-2">
                            Có thể in đậm, in nghiêng, xuống dòng, tiêu đề, danh sách...
                        </small>
                    </div>

                    <div class="form-group">
                        <label>Ảnh banner</label>
                        <div class="custom-file">
                            <input id="bannerFile" type="file" class="custom-file-input" accept="image/*" />
                            <label id="bannerLabel" class="custom-file-label" for="bannerFile">Chọn tệp</label>
                        </div>

                        <div class="mt-3 d-flex" style="gap: 12px; align-items: center;">
                            <img id="bannerPreview"
                                 src=""
                                 style="display:none; width: 220px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid #eee;" />
                            <small class="text-muted">jpg / png / webp — tối đa 10MB</small>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Hủy</button>
                    <button id="btnSubmit" class="btn btn-primary" type="submit">
                        <span class="mr-1"><i class="fas fa-save"></i></span> Tạo mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

    <script>
        const API_BASE = "/api/admin/tournaments";
        const TOURNAMENT_LIST_STATE_KEY = "admin-home-tournaments:return-state";
        let tournamentRuleQuill = null;
        let pendingTournamentListState = null;
        let tournamentListState = {
            page: 1,
            pageSize: 10,
            total: 0,
            items: []
        };

        function escapeHtml(str) {
            return String(str || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function getStatusLabel(status) {
            const s = (status || "").toUpperCase();
            if (s === "OPEN") return "Mở đăng ký";
            if (s === "CLOSED") return "Đã đóng";
            return "Bản nháp";
        }

        function composeTournamentTypeValue(gameType, genderCategory) {
            let g = (gameType || "").toUpperCase();
            let c = (genderCategory || "").toUpperCase();

            if (g === "MIXED") {
                g = "DOUBLE";
                c = "MIXED";
            }

            if (!c) {
                c = "OPEN";
            }

            const value = `${g}_${c}`;
            const allowed = new Set([
                "SINGLE_OPEN",
                "SINGLE_MEN",
                "SINGLE_WOMEN",
                "DOUBLE_OPEN",
                "DOUBLE_MEN",
                "DOUBLE_WOMEN",
                "DOUBLE_MIXED"
            ]);

            return allowed.has(value) ? value : "";
        }

        function parseTournamentTypeValue(value) {
            switch ((value || "").toUpperCase()) {
                case "SINGLE_MEN":
                    return { gameType: "SINGLE", genderCategory: "MEN" };
                case "SINGLE_WOMEN":
                    return { gameType: "SINGLE", genderCategory: "WOMEN" };
                case "DOUBLE_MEN":
                    return { gameType: "DOUBLE", genderCategory: "MEN" };
                case "DOUBLE_WOMEN":
                    return { gameType: "DOUBLE", genderCategory: "WOMEN" };
                case "DOUBLE_MIXED":
                    return { gameType: "DOUBLE", genderCategory: "MIXED" };
                case "SINGLE_OPEN":
                    return { gameType: "SINGLE", genderCategory: "OPEN" };
                case "DOUBLE_OPEN":
                    return { gameType: "DOUBLE", genderCategory: "OPEN" };
                default:
                    return { gameType: "", genderCategory: "" };
            }
        }

        function getTournamentTypeLabel(gameType, genderCategory) {
            const value = composeTournamentTypeValue(gameType, genderCategory);
            switch (value) {
                case "SINGLE_MEN": return "Đơn Nam";
                case "SINGLE_WOMEN": return "Đơn Nữ";
                case "DOUBLE_MEN": return "Đôi Nam";
                case "DOUBLE_WOMEN": return "Đôi Nữ";
                case "DOUBLE_MIXED": return "Hỗn Hợp Nam Nữ";
                case "SINGLE_OPEN": return "Đơn Mở";
                case "DOUBLE_OPEN": return "Đôi Mở";
                default: return "—";
            }
        }

        function getTournamentTypeCode(gameType, genderCategory) {
            const value = composeTournamentTypeValue(gameType, genderCategory);
            switch (value) {
                case "SINGLE_MEN": return "SINGLE + MEN";
                case "SINGLE_WOMEN": return "SINGLE + WOMEN";
                case "DOUBLE_MEN": return "DOUBLE + MEN";
                case "DOUBLE_WOMEN": return "DOUBLE + WOMEN";
                case "DOUBLE_MIXED": return "DOUBLE + MIXED";
                case "SINGLE_OPEN": return "SINGLE + OPEN";
                case "DOUBLE_OPEN": return "DOUBLE + OPEN";
                default: return "Chưa xác định";
            }
        }

        function badgeHtml(status) {
            const s = (status || "").toUpperCase();
            if (s === "OPEN") return `<span class="badge badge-success badge-status">Mở đăng ký</span>`;
            if (s === "CLOSED") return `<span class="badge badge-warning badge-status">Đã đóng</span>`;
            return `<span class="badge badge-secondary badge-status">Bản nháp</span>`;
        }

        function fmtDate(dt) {
            if (!dt) return "—";
            const d = new Date(dt);
            if (isNaN(d.getTime())) return "—";
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const dd = String(d.getDate()).padStart(2, "0");
            const hh = String(d.getHours()).padStart(2, "0");
            const mi = String(d.getMinutes()).padStart(2, "0");
            return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
        }

        function toDatetimeLocalValue(iso) {
            if (!iso) return "";
            const d = new Date(iso);
            if (isNaN(d.getTime())) return "";
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const dd = String(d.getDate()).padStart(2, "0");
            const hh = String(d.getHours()).padStart(2, "0");
            const mi = String(d.getMinutes()).padStart(2, "0");
            return `${yyyy}-${mm}-${dd}T${hh}:${mi}`;
        }

        function normalizeHtml(html) {
            if (!html) return "";
            const trimmed = String(html).trim();
            if (trimmed === "<p><br></p>") return "";
            return trimmed;
        }

        function readTournamentListState() {
            try {
                const raw = sessionStorage.getItem(TOURNAMENT_LIST_STATE_KEY);
                if (!raw) return null;

                sessionStorage.removeItem(TOURNAMENT_LIST_STATE_KEY);
                const state = JSON.parse(raw);
                const isSamePage = state?.path === window.location.pathname;
                const isFresh = Number.isFinite(Number(state?.savedAt))
                    && (Date.now() - Number(state.savedAt)) < (30 * 60 * 1000);

                return isSamePage && isFresh ? state : null;
            } catch (_) {
                sessionStorage.removeItem(TOURNAMENT_LIST_STATE_KEY);
                return null;
            }
        }

        function saveTournamentListState() {
            const statusFilter = document.getElementById("statusFilter");
            const state = {
                path: window.location.pathname,
                scrollY: Math.max(0, window.scrollY || window.pageYOffset || 0),
                status: statusFilter?.value || "ALL",
                page: tournamentListState.page,
                pageSize: tournamentListState.pageSize,
                savedAt: Date.now()
            };

            sessionStorage.setItem(TOURNAMENT_LIST_STATE_KEY, JSON.stringify(state));
        }

        function applyPendingTournamentListState() {
            if (!pendingTournamentListState) {
                return;
            }

            const state = pendingTournamentListState;
            pendingTournamentListState = null;
            const targetY = Math.max(0, Number(state?.scrollY) || 0);

            window.requestAnimationFrame(() => {
                window.setTimeout(() => {
                    window.scrollTo(0, targetY);
                }, 60);
            });
        }

        function showPageError(msg) {
            const box = document.getElementById("pageError");
            if (!box) {
                return;
            }

            box.textContent = msg || "Có lỗi xảy ra.";
            box.classList.remove("d-none");
        }

        function clearPageError() {
            const box = document.getElementById("pageError");
            if (!box) {
                return;
            }

            box.classList.add("d-none");
            box.textContent = "";
        }

        function gotoPrizeSetup(tournamentId) {
            saveTournamentListState();
            window.location.href = `/TournamentPrizeSetup/Index?tournamentId=${tournamentId}`;
        }

        function gotoBracket(tournamentId) {
            saveTournamentListState();
            const returnUrl = `${window.location.pathname}${window.location.search}`;
            window.location.href = `/TournamentAdminBracket/Index?tournamentId=${tournamentId}&returnUrl=${encodeURIComponent(returnUrl)}`;
        }

        async function softDeleteTournament(tournamentId, title) {
            const safeTitle = title || `#${tournamentId}`;
            const ok = window.confirm(`Xóa mềm giải đấu "${safeTitle}"?\n\nGiải này sẽ bị ẩn khỏi web và app.`);
            if (!ok) {
                return;
            }

            try {
                await axios.delete(`${API_BASE}/${tournamentId}`);
                await loadTournaments();
            } catch (err) {
                const msg = err?.response?.data?.message || err?.message || "Xóa mềm giải đấu thất bại.";
                window.alert(String(msg));
            }
        }

        function rowHtml(t) {
            const banner = t.bannerUrl
                ? `<img style="width:120px;height:44px;object-fit:cover;border-radius:6px" src="${t.bannerUrl}" />`
                : `<div style="width:120px;height:44px;border:1px dashed #ddd;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#999">Chưa có banner</div>`;

            const sub = `${t.areaText || "—"}${t.locationText ? " • " + t.locationText : ""}`;
            const extra1 = `${t.organizer ? "Đơn vị tổ chức: " + t.organizer : "Đơn vị tổ chức: —"}${t.creatorName ? " • Người tạo: " + t.creatorName : ""}`;
            const extra2 = `${t.formatText ? "Thể thức: " + t.formatText : "Thể thức: —"}${t.playoffType ? " • Vòng loại: " + t.playoffType : ""}`;
            const rulePreview = normalizeHtml(t.tournamentRule)
                ? `<div class="small rule-preview-lite mt-1">${t.tournamentRule}</div>`
                : `<div class="small text-gray-500 mt-1">Thể lệ: —</div>`;

            const singleLimit = (t.singleLimit ?? 0);
            const doubleLimit = (t.doubleLimit ?? 0);
            const tournamentTypeLabel = getTournamentTypeLabel(t.gameType, t.genderCategory);
            const tournamentTypeCode = getTournamentTypeCode(t.gameType, t.genderCategory);

            return `
                <tr data-id="${t.tournamentId}">
                    <td>${banner}</td>
                    <td>
                        <div class="font-weight-bold text-gray-900">${escapeHtml(t.title)}</div>
                        <div class="small text-gray-500">${escapeHtml(sub)}</div>
                        <div class="small text-gray-500">${escapeHtml(extra1)}</div>
                        <div class="small text-gray-500">${escapeHtml(extra2)}</div>
                        ${rulePreview}
                    </td>
                    <td>${badgeHtml(t.status)}</td>
                    <td>${fmtDate(t.startTime)}</td>
                    <td>${fmtDate(t.registerDeadline)}</td>
                    <td>
                        <div class="font-weight-bold text-gray-900">${escapeHtml(tournamentTypeLabel)}</div>
                        <div class="small text-muted">${escapeHtml(tournamentTypeCode)}</div>
                    </td>
                    <td>${t.expectedTeams ?? 0}</td>
                    <td>${Number(singleLimit).toFixed(2)}</td>
                    <td>${Number(doubleLimit).toFixed(2)}</td>
                    <td>
                        <div class="d-flex flex-wrap" style="gap:6px">
                            <button class="btn btn-sm btn-outline-primary" onclick="openEdit(${t.tournamentId})" type="button" title="Chỉnh sửa">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-info" onclick="gotoRegs(${t.tournamentId})" type="button" title="Danh sách đăng ký">
                                <i class="fas fa-list"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-success" onclick="gotoRounds(${t.tournamentId})" type="button" title="Các vòng đấu">
                                <i class="fas fa-layer-group"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-dark" onclick="gotoBracket(${t.tournamentId})" type="button" title="Sơ đồ admin">
                                <i class="fas fa-project-diagram"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-warning" onclick="gotoPrizeSetup(${t.tournamentId})" type="button" title="Thiết lập giải thưởng">
                                <i class="fas fa-trophy"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" data-title="${escapeHtml(t.title || "")}" onclick="softDeleteTournament(${t.tournamentId}, this.dataset.title)" type="button" title="Xóa mềm">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        }

        function gotoRounds(tournamentId) {
            saveTournamentListState();
            window.location.href = `/TournamentRounds/Index?tournamentId=${tournamentId}`;
        }

        function gotoRegs(tournamentId) {
            saveTournamentListState();
            window.location.href = `/Registrations/Index?tournamentId=${tournamentId}`;
        }

        function showError(msg) {
            const box = document.getElementById("formError");
            box.textContent = msg || "Có lỗi xảy ra";
            box.classList.remove("d-none");
        }

        function clearError() {
            const box = document.getElementById("formError");
            box.classList.add("d-none");
            box.textContent = "";
        }

        function setSubmitText(text) {
            document.getElementById("btnSubmit").innerHTML =
                `<span class="mr-1"><i class="fas fa-save"></i></span> ${text}`;
        }

        function resetFileUI() {
            document.getElementById("bannerLabel").textContent = "Chọn tệp";
            document.getElementById("bannerFile").value = "";

            const preview = document.getElementById("bannerPreview");
            preview.style.display = "none";
            preview.src = "";
        }

        function resetForm() {
            document.getElementById("formTournament").reset();
            resetFileUI();
            clearError();

            document.getElementById("tournamentType").value = "";
            document.getElementById("organizer").value = "";
            document.getElementById("creatorName").value = "";
            document.getElementById("formatText").value = "";
            document.getElementById("playoffType").value = "";
            document.getElementById("tournament_content").value = "";

            if (tournamentRuleQuill) {
                tournamentRuleQuill.setContents([]);
            }
        }

        function getTournamentListParams() {
            const status = document.getElementById("statusFilter").value;
            const params = {
                page: tournamentListState.page,
                pageSize: tournamentListState.pageSize
            };

            if (status) {
                params.status = status;
            }

            return params;
        }

        async function loadTournaments(resetPage = false) {
            if (resetPage) {
                tournamentListState.page = 1;
            }

            clearPageError();
            const body = document.getElementById("tournamentsBody");
            body.innerHTML = `<tr><td colspan="10" class="text-center text-muted">Đang tải...</td></tr>`;

            try {
                const res = await axios.get(API_BASE, { params: getTournamentListParams() });
                const items = res.data?.items || [];
                const total = Number(res.data?.total) || 0;
                const serverPage = Number(res.data?.page) || tournamentListState.page;
                const serverPageSize = Number(res.data?.pageSize) || tournamentListState.pageSize;

                tournamentListState.page = serverPage;
                tournamentListState.pageSize = serverPageSize;
                tournamentListState.total = total;
                tournamentListState.items = items;

                if (!items.length && total > 0 && tournamentListState.page > 1) {
                    const lastPage = Math.max(1, Math.ceil(total / tournamentListState.pageSize));
                    tournamentListState.page = Math.min(tournamentListState.page - 1, lastPage);
                    return await loadTournaments(false);
                }

                if (!items.length) {
                    body.innerHTML = `<tr><td colspan="10" class="text-center text-muted">Không có giải đấu</td></tr>`;
                } else {
                    body.innerHTML = items.map(rowHtml).join("");
                }

                renderTournamentPaging();
            } catch (e) {
                body.innerHTML = `<tr><td colspan="10" class="text-center text-danger">Tải dữ liệu thất bại</td></tr>`;
                showPageError(e?.response?.data?.message || e?.message || "Tải dữ liệu thất bại.");
                renderTournamentPaging();
            } finally {
                applyPendingTournamentListState();
            }
        }

        function getVisibleTournamentPages(currentPage, totalPages) {
            const maxButtons = 5;
            const pages = [];
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + maxButtons - 1);

            if ((end - start + 1) < maxButtons) {
                start = Math.max(1, end - maxButtons + 1);
            }

            for (let page = start; page <= end; page += 1) {
                pages.push(page);
            }

            return pages;
        }

        function renderTournamentPaging() {
            const total = tournamentListState.total || 0;
            const page = tournamentListState.page || 1;
            const pageSize = tournamentListState.pageSize || 10;
            const totalPages = Math.max(1, Math.ceil(total / pageSize));
            const start = total === 0 ? 0 : ((page - 1) * pageSize + 1);
            const end = Math.min(page * pageSize, total);
            const info = document.getElementById("pagingInfo");
            const pageNumbers = document.getElementById("pageNumbers");

            if (info) {
                info.textContent = `Hiển thị ${start}-${end} trên tổng ${total} giải đấu`;
            }

            if (pageNumbers) {
                pageNumbers.innerHTML = getVisibleTournamentPages(page, totalPages).map(function (pageNumber) {
                    const activeClass = pageNumber === page ? " active" : "";
                    return `<button class="tournament-page-btn${activeClass}" type="button" data-page="${pageNumber}">${pageNumber}</button>`;
                }).join("");
            }

            document.getElementById("btnFirst").disabled = page <= 1;
            document.getElementById("btnPrev").disabled = page <= 1;
            document.getElementById("btnNext").disabled = page >= totalPages || total === 0;
            document.getElementById("btnLast").disabled = page >= totalPages || total === 0;
        }

        function goToTournamentPage(page) {
            const total = tournamentListState.total || 0;
            const totalPages = Math.max(1, Math.ceil(total / (tournamentListState.pageSize || 10)));
            const nextPage = Math.max(1, Math.min(totalPages, Number(page) || 1));

            if (nextPage === tournamentListState.page) {
                return;
            }

            tournamentListState.page = nextPage;
            loadTournaments(false);
        }

        function openCreate() {
            resetForm();
            document.getElementById("mode").value = "create";
            document.getElementById("editingId").value = "";

            document.getElementById("modalTitle").textContent = "Tạo giải đấu";
            setSubmitText("Tạo mới");

            $("#modalTournament").modal("show");
        }

        function fillForm(t) {
            document.getElementById("title").value = t.title || "";
            document.getElementById("status").value = (t.status || "DRAFT").toUpperCase();
            document.getElementById("tournamentType").value = composeTournamentTypeValue(t.gameType, t.genderCategory);
            document.getElementById("expectedTeams").value = t.expectedTeams ?? 0;

            document.getElementById("areaText").value = t.areaText || "";
            document.getElementById("locationText").value = t.locationText || "";

            document.getElementById("startTime").value = toDatetimeLocalValue(t.startTime);
            document.getElementById("registerDeadline").value = toDatetimeLocalValue(t.registerDeadline);

            if (t.singleLimit !== undefined && t.singleLimit !== null)
                document.getElementById("singleLimit").value = t.singleLimit;

            if (t.doubleLimit !== undefined && t.doubleLimit !== null)
                document.getElementById("doubleLimit").value = t.doubleLimit;

            document.getElementById("tournament_content").value = t.content || "";
            document.getElementById("organizer").value = t.organizer || "";
            document.getElementById("creatorName").value = t.creatorName || "";
            document.getElementById("formatText").value = t.formatText || "";
            document.getElementById("playoffType").value = t.playoffType || "";

            if (tournamentRuleQuill) {
                tournamentRuleQuill.root.innerHTML = normalizeHtml(t.tournamentRule || "");
            }

            resetFileUI();
            const preview = document.getElementById("bannerPreview");
            if (t.bannerUrl) {
                preview.src = t.bannerUrl;
                preview.style.display = "block";
            }
        }

        async function openEdit(id) {
            resetForm();
            document.getElementById("mode").value = "edit";
            document.getElementById("editingId").value = String(id);

            document.getElementById("modalTitle").textContent = "Chỉnh sửa giải đấu";
            setSubmitText("Lưu");

            $("#modalTournament").modal("show");

            try {
                const res = await axios.get(`${API_BASE}/${id}`);
                fillForm(res.data);
            } catch (e) {
                const msg = e?.response?.data?.message || e?.message || "Tải thông tin giải đấu thất bại.";
                showError(String(msg));
            }
        }

        function updateRowInTable(t) {
            const row = document.querySelector(`#tournamentsBody tr[data-id="${t.tournamentId}"]`);
            if (!row) return;
            row.outerHTML = rowHtml(t);
        }

        function prependRow(t) {
            const body = document.getElementById("tournamentsBody");
            const empty = body.querySelector("tr td[colspan='10']");
            if (empty) body.innerHTML = "";
            body.insertAdjacentHTML("afterbegin", rowHtml(t));
        }

        function buildFormData() {
            const fd = new FormData();
            const selectedTournamentType = document.getElementById("tournamentType").value;
            const parsedTournamentType = parseTournamentTypeValue(selectedTournamentType);

            if (!parsedTournamentType.gameType || !parsedTournamentType.genderCategory) {
                throw new Error("Vui lòng chọn đúng nội dung thi đấu.");
            }

            fd.append("title", document.getElementById("title").value.trim());
            fd.append("status", document.getElementById("status").value);
            fd.append("gameType", parsedTournamentType.gameType);
            fd.append("genderCategory", parsedTournamentType.genderCategory);
            fd.append("expectedTeams", document.getElementById("expectedTeams").value || "0");

            const st = document.getElementById("startTime").value;
            const dl = document.getElementById("registerDeadline").value;
            if (st) fd.append("startTime", new Date(st).toISOString());
            if (dl) fd.append("registerDeadline", new Date(dl).toISOString());

            fd.append("locationText", document.getElementById("locationText").value || "");
            fd.append("areaText", document.getElementById("areaText").value || "");
            fd.append("singleLimit", document.getElementById("singleLimit").value || "0");
            fd.append("doubleLimit", document.getElementById("doubleLimit").value || "0");
            fd.append("content", document.getElementById("tournament_content").value || "");
            fd.append("tournamentRule", normalizeHtml(tournamentRuleQuill ? tournamentRuleQuill.root.innerHTML : ""));

            fd.append("organizer", document.getElementById("organizer").value || "");
            fd.append("creatorName", document.getElementById("creatorName").value || "");
            fd.append("formatText", document.getElementById("formatText").value || "");
            fd.append("playoffType", document.getElementById("playoffType").value || "");

            const banner = document.getElementById("bannerFile").files?.[0];
            if (banner) fd.append("bannerFile", banner);

            return fd;
        }

        document.addEventListener("DOMContentLoaded", () => {
            pendingTournamentListState = readTournamentListState();

            if (pendingTournamentListState?.status) {
                document.getElementById("statusFilter").value = pendingTournamentListState.status;
            }

            if (pendingTournamentListState?.pageSize) {
                tournamentListState.pageSize = parseInt(pendingTournamentListState.pageSize, 10) || 10;
            }

            if (pendingTournamentListState?.page) {
                tournamentListState.page = Math.max(1, parseInt(pendingTournamentListState.page, 10) || 1);
            }

            document.getElementById("pageSize").value = String(tournamentListState.pageSize);

            tournamentRuleQuill = new Quill("#tournamentRuleEditor", {
                theme: "snow",
                placeholder: "Nhập thể lệ giải...",
                modules: {
                    toolbar: [
                        [{ header: [1, 2, 3, false] }],
                        ["bold", "italic", "underline", "strike"],
                        [{ list: "ordered" }, { list: "bullet" }],
                        ["blockquote"],
                        ["link"],
                        ["clean"]
                    ]
                }
            });

            loadTournaments();

            document.getElementById("btnFilter").addEventListener("click", () => loadTournaments(true));
            document.getElementById("btnOpenCreate").addEventListener("click", () => openCreate());

            document.getElementById("statusFilter").addEventListener("change", () => loadTournaments(true));

            document.getElementById("pageSize").addEventListener("change", () => {
                tournamentListState.pageSize = parseInt(document.getElementById("pageSize").value, 10) || 10;
                loadTournaments(true);
            });

            document.getElementById("btnFirst").addEventListener("click", () => goToTournamentPage(1));
            document.getElementById("btnPrev").addEventListener("click", () => goToTournamentPage(tournamentListState.page - 1));
            document.getElementById("btnNext").addEventListener("click", () => goToTournamentPage(tournamentListState.page + 1));
            document.getElementById("btnLast").addEventListener("click", () => {
                const totalPages = Math.max(1, Math.ceil((tournamentListState.total || 0) / (tournamentListState.pageSize || 10)));
                goToTournamentPage(totalPages);
            });

            document.getElementById("pageNumbers").addEventListener("click", (event) => {
                const button = event.target.closest("[data-page]");
                if (!button) {
                    return;
                }

                goToTournamentPage(button.dataset.page);
            });

            const fileInput = document.getElementById("bannerFile");
            const fileLabel = document.getElementById("bannerLabel");
            const preview = document.getElementById("bannerPreview");

            fileInput.addEventListener("change", () => {
                const f = fileInput.files && fileInput.files[0];
                if (!f) {
                    fileLabel.textContent = "Chọn tệp";
                    preview.style.display = "none";
                    preview.src = "";
                    return;
                }
                fileLabel.textContent = f.name;
                const url = URL.createObjectURL(f);
                preview.src = url;
                preview.style.display = "block";
            });

            document.getElementById("formTournament").addEventListener("submit", async (e) => {
                e.preventDefault();
                clearError();

                const mode = document.getElementById("mode").value;
                const editingId = document.getElementById("editingId").value;

                const btn = document.getElementById("btnSubmit");
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                try {
                    const fd = buildFormData();

                    if (mode === "edit") {
                        await axios.put(`${API_BASE}/${editingId}`, fd, {
                            headers: { "Content-Type": "multipart/form-data" }
                        });
                        await loadTournaments(false);
                    } else {
                        await axios.post(API_BASE, fd, {
                            headers: { "Content-Type": "multipart/form-data" }
                        });
                        await loadTournaments(true);
                    }

                    $("#modalTournament").modal("hide");
                } catch (err) {
                    const msg = err?.response?.data?.message || err?.response?.data || err?.message || "Lưu thất bại.";
                    showError(String(msg));
                } finally {
                    btn.disabled = false;
                    setSubmitText(mode === "edit" ? "Lưu" : "Tạo mới");
                }
            });

            $("#modalTournament").on("hidden.bs.modal", function () {
                resetForm();
            });
        });
    </script>
}
