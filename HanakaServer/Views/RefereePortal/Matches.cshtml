@{
    Layout = null;
    ViewData["Title"] = "Trận đấu của trọng tài";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg: #f5f7fb;
            --card: #ffffff;
            --border: #e5e7eb;
            --muted: #6b7280;
            --text: #111827;
            --primary: #2563eb;
            --success: #16a34a;
            --warning: #d97706;
            --dark: #0f172a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            font-family: "Be Vietnam Pro", Arial, sans-serif;
            color: var(--text);
            margin: 0;
            min-height: 100vh;
            min-height: 100dvh;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
            overflow-x: hidden;
        }

        button,
        .match-card {
            touch-action: manipulation;
        }

        .topbar {
            background: var(--dark);
            color: #fff;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 10px 24px rgba(15, 23, 42, .16);
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            min-width: 0;
            line-height: 1.35;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .topbar-right .small {
            max-width: 220px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            color: rgba(255, 255, 255, .78);
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 0 0 auto;
        }

        .topbar .btn {
            min-height: 40px;
            border-radius: 12px;
            font-weight: 700;
            white-space: nowrap;
        }

        .topbar-icon-btn {
            width: 42px;
            height: 42px;
            min-width: 42px;
            border: 0;
            border-radius: 14px;
            background: rgba(255, 255, 255, .12);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: background-color .15s ease, transform .15s ease;
        }

        .topbar-icon-btn:active {
            transform: scale(.96);
        }

        .topbar-icon-btn:hover,
        .topbar-icon-btn:focus,
        .topbar-icon-btn.active {
            background: #fff;
            color: var(--dark);
            outline: 0;
        }

        .topbar-search {
            position: absolute;
            top: calc(100% + 8px);
            right: 24px;
            z-index: 120;
            width: min(390px, calc(100vw - 28px));
            padding: 10px;
            border: 1px solid rgba(148, 163, 184, .3);
            border-radius: 16px;
            background: #fff;
            box-shadow: 0 18px 42px rgba(15, 23, 42, .2);
            display: none;
        }

        .topbar.search-open .topbar-search {
            display: block;
        }

        .search-input-shell {
            display: grid;
            grid-template-columns: 20px minmax(0, 1fr) 34px;
            align-items: center;
            gap: 8px;
            min-height: 46px;
            padding: 0 8px 0 12px;
            border: 1px solid #d1d5db;
            border-radius: 14px;
            background: #f8fafc;
            color: #64748b;
        }

        .search-input-shell input {
            width: 100%;
            border: 0;
            outline: 0;
            background: transparent;
            color: var(--text);
            font-size: 15px;
            font-weight: 700;
        }

        .search-input-shell input::placeholder {
            color: #94a3b8;
            font-weight: 600;
        }

        .search-clear-btn {
            width: 34px;
            height: 34px;
            border: 0;
            border-radius: 12px;
            background: transparent;
            color: #64748b;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-clear-btn:hover,
        .search-clear-btn:focus {
            background: #e5e7eb;
            color: #111827;
            outline: 0;
        }

        .search-hint {
            margin-top: 8px;
            color: #64748b;
            font-size: 12px;
            font-weight: 700;
        }

        .page-wrap {
            max-width: 1280px;
            margin: 24px auto;
            padding: 0 16px 32px;
        }

        .page-title {
            font-size: 30px;
            font-weight: 800;
            margin-bottom: 6px;
            color: var(--text);
            line-height: 1.2;
        }

        .page-subtitle {
            color: var(--muted);
            margin-bottom: 24px;
            line-height: 1.65;
        }

        .match-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .match-card {
            background: var(--card);
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 8px 24px rgba(0,0,0,.05);
            padding: 18px;
            cursor: pointer;
            transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
            -webkit-tap-highlight-color: transparent;
        }

        .match-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(0,0,0,.08);
            border-color: #cbd5e1;
        }

        .match-card:active {
            transform: scale(.995);
        }

        .match-card.completed {
            border-color: #bbf7d0;
        }

        .match-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
        }

        .match-title {
            font-size: 17px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 4px;
            line-height: 1.35;
            overflow-wrap: anywhere;
        }

        .match-meta {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 2px;
            line-height: 1.55;
            overflow-wrap: anywhere;
        }

        .match-chip-col {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 6px;
        }

        .match-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 700;
            background: #eef2ff;
            color: #3730a3;
            line-height: 1.25;
            white-space: nowrap;
        }

        .match-chip.success {
            background: #dcfce7;
            color: #166534;
        }

        .match-chip.muted {
            background: #f3f4f6;
            color: #4b5563;
        }

        .match-id-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 8px;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: .02em;
            background: #111827;
            color: #fff;
        }

        .score-preview {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px dashed #d1d5db;
        }

        .team-preview {
            font-weight: 700;
            font-size: 15px;
            color: var(--text);
            line-height: 1.4;
        }

        .team-preview.right {
            text-align: right;
        }

        .team-preview.winner {
            color: var(--warning);
        }

        .score-preview-value {
            font-size: 28px;
            font-weight: 900;
            color: var(--text);
            min-width: 96px;
            text-align: center;
            font-variant-numeric: tabular-nums;
        }

        .hint-click {
            margin-top: 14px;
            font-size: 12px;
            color: var(--primary);
            font-weight: 700;
            line-height: 1.45;
        }

        .empty-box {
            background: #fff;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
            padding: 32px;
            text-align: center;
            color: var(--muted);
            grid-column: 1 / -1;
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .72);
            z-index: 3000;
            display: none;
            align-items: stretch;
            justify-content: stretch;
        }

        .overlay.show {
            display: flex;
        }

        .overlay-panel {
            background: #fff;
            width: 100%;
            height: 100%;
            min-height: 0;
            overflow: auto;
            display: flex;
            flex-direction: column;
        }

        .overlay-header {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
        }

        .overlay-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 4px;
            color: var(--text);
            line-height: 1.25;
            overflow-wrap: anywhere;
        }

        .overlay-subtitle {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.5;
        }

        .overlay-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            flex: 0 0 auto;
        }

        .overlay-actions .btn {
            min-height: 44px;
            border-radius: 14px;
            font-weight: 800;
        }

        #btnCloseOverlay {
            border: 0;
            background: transparent;
            box-shadow: none;
            color: #64748b;
            min-width: 44px;
            min-height: 44px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        #btnCloseOverlay:hover,
        #btnCloseOverlay:focus {
            border: 0;
            background: rgba(15, 23, 42, .06);
            box-shadow: none;
            color: #334155;
        }

        #btnCloseOverlay i {
            margin: 0;
            font-size: 16px;
        }

        .overlay-body {
            padding: 24px;
        }

        .focus-match {
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
        }

        .focus-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

        .focus-meta {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.7;
            overflow-wrap: anywhere;
        }

        .focus-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .focus-scoreboard {
            margin-top: 18px;
            padding-top: 20px;
            border-top: 1px dashed #d1d5db;
            display: grid;
            grid-template-columns: 1fr 280px 1fr;
            gap: 20px;
            align-items: center;
        }

        .focus-team {
            font-size: 28px;
            font-weight: 800;
            line-height: 1.35;
            color: var(--text);
            overflow-wrap: anywhere;
        }

        .focus-team.right {
            text-align: right;
        }

        .focus-team.winner {
            color: var(--warning);
        }

        .focus-score-center {
            background: #0f172a;
            color: #fff;
            border-radius: 24px;
            padding: 24px 12px;
            text-align: center;
            box-shadow: 0 12px 28px rgba(15, 23, 42, .18);
        }

        .focus-score-value {
            font-size: 72px;
            font-weight: 900;
            line-height: 1;
            letter-spacing: 1px;
            font-variant-numeric: tabular-nums;
        }

        .focus-score-label {
            margin-top: 10px;
            font-size: 14px;
            opacity: .9;
            font-weight: 700;
        }

        .focus-controls {
            margin-top: 28px;
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 24px;
        }

        .history-section,
        .score-form-section {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 14px;
            color: var(--text);
        }

        .history-list {
            max-height: 420px;
            overflow: auto;
            padding-right: 4px;
        }

        .history-empty {
            color: var(--muted);
            font-size: 14px;
        }

        .history-item {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 10px;
        }

        .history-score {
            font-size: 18px;
            font-weight: 900;
            color: var(--text);
            font-variant-numeric: tabular-nums;
        }

        .history-meta {
            font-size: 12px;
            color: var(--muted);
            margin-top: 4px;
        }

        .history-note {
            margin-top: 8px;
            font-size: 14px;
            color: var(--text);
        }

        .big-score-inputs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .big-score-box label {
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
            line-height: 1.35;
            overflow-wrap: anywhere;
        }

        .big-score-box input {
            height: 90px;
            font-size: 42px;
            font-weight: 900;
            text-align: center;
            border-radius: 16px;
            font-variant-numeric: tabular-nums;
            -webkit-appearance: none;
            appearance: textfield;
            touch-action: manipulation;
        }

        .big-score-box input::-webkit-outer-spin-button,
        .big-score-box input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .score-stepper {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 10px;
            align-items: stretch;
        }

        .score-stepper-btn {
            display: none;
            align-items: center;
            justify-content: center;
            min-width: 58px;
            min-height: 58px;
            border: 0;
            border-radius: 18px;
            background: #2563eb;
            color: #fff;
            font-size: 22px;
            box-shadow: 0 12px 24px rgba(37, 99, 235, .22);
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
            transition: transform .12s ease, background-color .12s ease, box-shadow .12s ease;
        }

        .score-stepper-btn:active {
            transform: scale(.96);
            background: #1d4ed8;
            box-shadow: 0 8px 18px rgba(37, 99, 235, .22);
        }

        .score-stepper-btn--minus {
            background: #475569;
            box-shadow: 0 12px 24px rgba(71, 85, 105, .18);
        }

        .score-stepper-btn--minus:active {
            background: #334155;
            box-shadow: 0 8px 18px rgba(71, 85, 105, .18);
        }

        .score-stepper-btn:disabled {
            opacity: .9;
        }

        .score-stepper-btn:focus {
            outline: 3px solid rgba(37, 99, 235, .22);
            outline-offset: 2px;
        }

        .score-toast {
            position: fixed;
            top: calc(12px + env(safe-area-inset-top));
            left: 50%;
            z-index: 2000;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            max-width: calc(100vw - 28px);
            min-height: 42px;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(15, 23, 42, .94);
            color: #fff;
            font-size: 14px;
            font-weight: 800;
            line-height: 1.25;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .22);
            opacity: 0;
            pointer-events: none;
            transform: translate(-50%, -12px);
            transition: opacity .18s ease, transform .18s ease;
        }

        .score-toast.show {
            opacity: 1;
            transform: translate(-50%, 0);
        }

        .score-toast.success {
            background: rgba(22, 101, 52, .96);
        }

        .score-toast.error {
            background: rgba(185, 28, 28, .96);
        }

        .end-match-modal {
            position: fixed;
            inset: 0;
            z-index: 4200;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 18px;
            background: rgba(15, 23, 42, .66);
        }

        .end-match-modal.show {
            display: flex;
        }

        .end-match-dialog {
            width: min(430px, 100%);
            border-radius: 22px;
            background: #fff;
            padding: 22px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, .28);
        }

        .end-match-icon {
            width: 54px;
            height: 54px;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #dcfce7;
            color: #15803d;
            font-size: 22px;
            margin-bottom: 14px;
        }

        .end-match-title {
            color: var(--text);
            font-size: 24px;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 8px;
        }

        .end-match-text {
            color: #64748b;
            font-size: 15px;
            line-height: 1.55;
            margin-bottom: 18px;
        }

        .end-match-actions {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 10px;
        }

        .end-match-actions .btn {
            min-height: 48px;
            border-radius: 14px;
            font-weight: 900;
        }

        .form-note-select {
            height: 48px;
            border-radius: 12px;
        }

        .score-form-section .btn-success {
            min-height: 52px;
            border-radius: 14px;
            font-weight: 800;
            box-shadow: 0 12px 24px rgba(22, 163, 74, .18);
        }

        .switch-wrap {
            margin-top: 14px;
            padding: 12px 14px;
            background: #f8fafc;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }

        .focus-lock {
            margin-top: 14px;
            padding: 12px 14px;
            border-radius: 12px;
            background: #fff7ed;
            color: #9a3412;
            border: 1px solid #fed7aa;
            font-size: 14px;
            font-weight: 700;
        }

        @@media (max-width: 1100px) {
            .match-grid {
                grid-template-columns: 1fr;
            }

            .focus-scoreboard {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .focus-team,
            .focus-team.right {
                text-align: center;
                font-size: 24px;
            }

            .focus-controls {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .topbar {
                padding: 12px 14px;
                align-items: stretch;
                flex-direction: column;
                gap: 10px;
            }

            .topbar-left {
                font-size: 15px;
            }

            .topbar-right {
                justify-content: space-between;
                width: 100%;
            }

            .topbar-right .small {
                max-width: calc(100vw - 206px);
                min-height: 24px;
                display: inline-flex;
                align-items: center;
            }

            .topbar-actions {
                gap: 8px;
            }

            .topbar-search {
                left: 14px;
                right: 14px;
                top: calc(100% + 8px);
                width: auto;
            }

            .page-wrap {
                margin: 0 auto;
                padding: 18px 14px calc(28px + env(safe-area-inset-bottom));
            }

            .page-title {
                font-size: 24px;
                margin-bottom: 8px;
            }

            .page-subtitle {
                font-size: 14px;
                margin-bottom: 16px;
            }

            .match-grid {
                gap: 14px;
            }

            .match-card {
                border-radius: 18px;
                padding: 16px;
                box-shadow: 0 8px 22px rgba(15, 23, 42, .07);
            }

            .match-head {
                flex-direction: column;
                gap: 12px;
            }

            .match-chip-col {
                width: 100%;
                align-items: flex-start;
                flex-direction: row;
                flex-wrap: wrap;
            }

            .score-preview {
                grid-template-columns: 1fr;
                gap: 8px;
                margin-top: 14px;
                padding-top: 14px;
            }

            .score-preview-value {
                order: -1;
                width: 100%;
                min-width: 0;
                padding: 12px 14px;
                border-radius: 16px;
                background: #f8fafc;
                border: 1px solid #e5e7eb;
            }

            .team-preview,
            .team-preview.right {
                text-align: left;
                font-size: 14px;
            }

            .hint-click {
                display: flex;
                align-items: center;
                gap: 8px;
                min-height: 44px;
                padding: 10px 12px;
                border-radius: 14px;
                background: #eff6ff;
            }

            .overlay-header,
            .overlay-body {
                padding: 14px;
            }

            .overlay-header {
                align-items: flex-start;
                gap: 10px;
            }

            .overlay-title {
                font-size: 18px;
            }

            .overlay-subtitle {
                font-size: 12px;
            }

            .overlay-actions .btn {
                width: 44px;
                padding: 0;
                overflow: hidden;
                color: transparent;
            }

            .overlay-actions .btn i {
                color: #6b7280;
                margin: 0;
                font-size: 16px;
            }

            .focus-match {
                padding: 14px;
                border-radius: 20px;
                box-shadow: none;
            }

            .focus-top {
                flex-direction: column;
                gap: 12px;
            }

            .focus-badges {
                justify-content: flex-start;
            }

            .focus-scoreboard {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 10px;
                margin-top: 14px;
                padding-top: 16px;
            }

            .focus-score-center {
                grid-column: 1 / -1;
                order: -1;
                border-radius: 20px;
                padding: 18px 12px;
            }

            .focus-score-value {
                font-size: 54px;
                letter-spacing: 0;
            }

            .focus-team,
            .focus-team.right {
                min-height: 68px;
                display: flex;
                align-items: center;
                justify-content: center;
                text-align: center;
                font-size: 16px;
                padding: 12px;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                background: #fff;
            }

            .focus-controls {
                gap: 14px;
                margin-top: 16px;
            }

            .score-form-section {
                order: -1;
            }

            .history-section,
            .score-form-section {
                border-radius: 16px;
                padding: 14px;
            }

            .section-title {
                font-size: 16px;
                margin-bottom: 12px;
            }

            .history-list {
                max-height: 260px;
            }

            .big-score-inputs {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .big-score-box input {
                height: 76px;
                font-size: 36px;
                font-size: clamp(32px, 10vw, 38px);
                padding: 6px;
            }

            .score-stepper {
                grid-template-columns: 56px minmax(0, 1fr) 64px;
                gap: 8px;
            }

            .score-stepper-btn {
                display: inline-flex;
            }

            .form-note-select,
            .score-form-section .form-control {
                min-height: 48px;
                font-size: 16px;
            }

        }

        @@media (max-width: 380px) {
            .topbar,
            .page-wrap,
            .overlay-header,
            .overlay-body {
                padding-left: 10px;
                padding-right: 10px;
            }

            .match-card,
            .focus-match,
            .history-section,
            .score-form-section {
                border-radius: 14px;
                padding: 12px;
            }

            .match-chip {
                white-space: normal;
            }

            .focus-score-value {
                font-size: 46px;
            }

            .big-score-inputs {
                grid-template-columns: 1fr;
            }
        }

        @@media (orientation: landscape) and (max-height: 520px) {
            .topbar {
                position: static;
            }

            .topbar.search-open {
                position: sticky;
            }

            .overlay-panel {
                overflow: hidden;
            }

            .overlay-header {
                position: static;
                min-height: 44px;
                padding: 6px 10px;
                align-items: center;
            }

            .overlay-title {
                display: -webkit-box;
                -webkit-line-clamp: 1;
                -webkit-box-orient: vertical;
                overflow: hidden;
                font-size: 14px;
                line-height: 1.2;
                margin: 0;
            }

            .overlay-subtitle {
                display: none;
            }

            .overlay-actions .btn {
                width: 40px;
                min-height: 40px;
                padding: 0;
                overflow: hidden;
                color: transparent;
            }

            .overlay-actions .btn i {
                color: #64748b;
                margin: 0;
                font-size: 15px;
            }

            .overlay-body {
                flex: 1 1 auto;
                min-height: 0;
                overflow: auto;
                padding: 8px;
            }

            .focus-match {
                display: grid;
                grid-template-columns: minmax(190px, .72fr) minmax(0, 1.28fr);
                grid-template-areas: "score form";
                align-items: start;
                gap: 8px;
                min-height: 100%;
                padding: 8px;
                border-radius: 14px;
            }

            .focus-top,
            .history-section {
                display: none;
            }

            .focus-scoreboard {
                grid-area: score;
                display: block;
                margin: 0;
                padding: 0;
                border: 0;
            }

            .focus-team,
            .focus-team.right {
                display: none;
            }

            .focus-score-center {
                min-height: 126px;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                border-radius: 16px;
                padding: 14px 10px;
            }

            .focus-score-value {
                font-size: clamp(42px, 8vw, 60px);
                letter-spacing: 0;
            }

            .focus-score-label {
                margin-top: 8px;
                font-size: 13px;
            }

            .focus-controls {
                grid-area: form;
                display: block;
                margin: 0;
            }

            .score-form-section {
                order: 0;
                padding: 10px;
                border-radius: 14px;
            }

            .section-title {
                font-size: 15px;
                margin-bottom: 8px;
            }

            .big-score-inputs {
                grid-template-columns: 1fr;
                gap: 6px;
            }

            .big-score-box label {
                margin-bottom: 4px;
                font-size: 13px;
                line-height: 1.25;
            }

            .score-stepper {
                grid-template-columns: 46px minmax(0, 1fr) 52px;
                gap: 6px;
            }

            .score-stepper-btn {
                display: inline-flex;
                min-width: 46px;
                min-height: 46px;
                border-radius: 14px;
                font-size: 20px;
                box-shadow: none;
            }

            .big-score-box input {
                height: 46px;
                padding: 4px;
                font-size: 22px;
            }

            .form-group.mt-3 {
                margin-top: 8px !important;
            }

            .form-note-select,
            .score-form-section .form-control {
                min-height: 40px;
                height: 40px;
                font-size: 14px;
            }

            .score-form-section .big-score-box input {
                min-height: 46px;
                height: 46px;
                font-size: 22px;
            }

            .switch-wrap {
                margin-top: 8px;
                padding: 8px 10px;
                font-size: 13px;
            }

            .score-form-section .btn-success {
                min-height: 42px;
                margin-top: 8px !important;
                border-radius: 12px;
            }

            .score-toast {
                top: calc(8px + env(safe-area-inset-top));
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                transition-duration: 0.01ms !important;
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
            }
        }
    </style>
</head>
<body>
    <div class="topbar">
        <div class="topbar-left">
            <i class="fas fa-gavel"></i>
            <span>Cổng trọng tài</span>
        </div>
        <div class="topbar-right">
            <span id="meBox" class="small"></span>
            <div class="topbar-actions">
                <button class="topbar-icon-btn" id="btnSearchToggle" type="button" aria-label="Tìm trận đấu" aria-expanded="false" aria-controls="matchSearchPopover">
                    <i class="fas fa-search"></i>
                </button>
                <button class="btn btn-sm btn-light" id="btnLogout" type="button">
                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                </button>
            </div>
        </div>
        <div class="topbar-search" id="matchSearchPopover" role="search">
            <div class="search-input-shell">
                <i class="fas fa-search"></i>
                <input type="search" id="matchSearchInput" placeholder="Tìm theo mã trận hoặc tên đội" autocomplete="off" />
                <button type="button" class="search-clear-btn" id="btnSearchClear" aria-label="Xóa tìm kiếm">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="search-hint" id="searchHint">Nhập mã trận hoặc tên đội để lọc nhanh.</div>
        </div>
    </div>

    <div class="page-wrap">
        <div class="page-title">Trận đấu được phân công</div>
        <div class="page-subtitle">
            Chọn đúng trận đấu để vào màn hình chấm điểm riêng. Trọng tài chỉ có thể chấm khi đã đến thời gian thi đấu.
        </div>

        <div id="errBox" class="alert alert-danger d-none"></div>

        <div id="cards" class="match-grid">
            <div class="empty-box">Đang tải...</div>
        </div>
    </div>

    <!-- Full screen overlay -->
    <div class="overlay" id="matchOverlay">
        <div class="overlay-panel">
            <div class="overlay-header">
                <div>
                    <div class="overlay-title" id="overlayTitle">Chi tiết trận đấu</div>
                    <div class="overlay-subtitle" id="overlaySubtitle"></div>
                </div>

                <div class="overlay-actions">
                    <button type="button" class="btn btn-outline-secondary" id="btnCloseOverlay" aria-label="Đóng">
                        <i class="fas fa-times" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <div class="overlay-body">
                <div id="overlayContent"></div>
            </div>
        </div>
    </div>

    <div class="score-toast" id="scoreToast" role="status" aria-live="polite"></div>

    <div class="end-match-modal" id="endMatchConfirm" aria-hidden="true">
        <div class="end-match-dialog" role="dialog" aria-modal="true" aria-labelledby="endMatchConfirmTitle">
            <div class="end-match-icon">
                <i class="fas fa-flag-checkered"></i>
            </div>
            <div class="end-match-title" id="endMatchConfirmTitle">Kết thúc trận đấu?</div>
            <div class="end-match-text">
                Xác nhận kết thúc trận và lưu tỷ số hiện tại cho trận đấu này.
            </div>
            <div class="end-match-actions">
                <button type="button" class="btn btn-outline-secondary" id="btnEndMatchCancel">Xem lại</button>
                <button type="button" class="btn btn-success" id="btnEndMatchConfirm">
                    <i class="fas fa-check"></i> Xác nhận
                </button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        (() => {
            const $id = (id) => document.getElementById(id);
            const API = `/api/referee/matches`;

            let CACHE = { items: [] };
            let ACTIVE_MATCH_ID = null;
            let SCORE_SAVE_BUSY = false;
            let SCORE_TOAST_TIMER = null;
            let REFRESH_CARDS_ON_CLOSE = false;
            let SEARCH_QUERY = "";
            let END_MATCH_CONFIRM_RESOLVE = null;

            const esc = (s) => String(s || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const fmt = (dt) => {
                if (!dt) return "—";
                const d = new Date(dt);
                if (isNaN(d.getTime())) return "—";
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");
                return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
            };

            function showErr(msg) {
                const box = $id("errBox");
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideErr() {
                const box = $id("errBox");
                box.classList.add("d-none");
                box.textContent = "";
            }

            function getMatch(matchId) {
                return (CACHE.items || []).find(x => x.matchId === matchId) || null;
            }

            function getStatusBadge(m) {
                if (m.isCompleted) {
                    return `<span class="match-chip success"><i class="fas fa-check-circle"></i> Đã kết thúc</span>`;
                }
                return `<span class="match-chip muted"><i class="fas fa-clock"></i> Chưa kết thúc</span>`;
            }

            function getEditBadge(m) {
                if (m.canEditScore) {
                    return `<span class="match-chip"><i class="fas fa-clipboard-check"></i> Có thể chấm điểm</span>`;
                }
                return `<span class="match-chip muted"><i class="fas fa-lock"></i> Chưa thể chấm điểm</span>`;
            }

            function cardHtml(m) {
                const completed = !!m.isCompleted;
                const t1Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team1RegistrationId;
                const t2Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team2RegistrationId;

                return `
                    <div class="match-card ${completed ? "completed" : ""}" onclick="openMatchDetail(${m.matchId})">
                        <div class="match-head">
                            <div>
                                <div class="match-id-badge">
                                    <i class="fas fa-hashtag"></i> Mã trận #${m.matchId}
                                </div>
                                <div class="match-title">${esc(m.tournamentTitle)}</div>
                                <div class="match-meta">Vòng: ${esc(m.roundKey)} • ${esc(m.roundLabel)} • Bảng: ${esc(m.groupName)}</div>
                                <div class="match-meta">Bắt đầu: ${fmt(m.startAt)}${m.courtText ? " • " + esc(m.courtText) : ""}</div>
                                <div class="match-meta">Địa chỉ: ${esc(m.addressText || "—")}</div>
                            </div>

                            <div class="match-chip-col">
                                ${getStatusBadge(m)}
                                ${getEditBadge(m)}
                            </div>
                        </div>

                        <div class="score-preview">
                            <div class="team-preview ${t1Winner ? "winner" : ""}">${esc(m.team1Text)}</div>
                            <div class="score-preview-value">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                            <div class="team-preview right ${t2Winner ? "winner" : ""}">${esc(m.team2Text)}</div>
                        </div>

                        <div class="hint-click">
                            <i class="fas fa-expand"></i> Bấm để vào màn hình chấm điểm riêng cho trận này
                        </div>
                    </div>
                `;
            }

            function historyHtml(histories) {
                if (!histories || !histories.length) {
                    return `<div class="history-empty">Chưa có lịch sử chấm điểm.</div>`;
                }

                return `
                    <div class="history-list">
                        ${histories.map(h => `
                            <div class="history-item">
                                <div class="history-score">
                                    ${Number(h.scoreTeam1 || 0)} - ${Number(h.scoreTeam2 || 0)}
                                    ${h.winnerTeam ? `<span class="badge badge-warning ml-2">Đội thắng: ${h.winnerTeam}</span>` : ``}
                                </div>
                                <div class="history-meta">
                                    ${esc(h.refereeName || ("User #" + h.refereeUserId))} • ${fmt(h.createdAt)}
                                </div>
                                ${h.note ? `<div class="history-note">${esc(h.note)}</div>` : ``}
                            </div>
                        `).join("")}
                    </div>
                `;
            }

            function detailHtml(m) {
                const completed = !!m.isCompleted;
                const t1Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team1RegistrationId;
                const t2Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team2RegistrationId;

                return `
                    <div class="focus-match">
                        <div class="focus-top">
                            <div>
                                <div class="match-id-badge">
                                    <i class="fas fa-hashtag"></i> Mã trận #${m.matchId}
                                </div>
                                <div class="focus-meta"><b>Giải đấu:</b> ${esc(m.tournamentTitle)}</div>
                                <div class="focus-meta"><b>Vòng:</b> ${esc(m.roundKey)} • ${esc(m.roundLabel)} • <b>Bảng:</b> ${esc(m.groupName)}</div>
                                <div class="focus-meta"><b>Bắt đầu:</b> ${fmt(m.startAt)}</div>
                                <div class="focus-meta"><b>Sân:</b> ${esc(m.courtText || "—")}</div>
                                <div class="focus-meta"><b>Địa chỉ:</b> ${esc(m.addressText || "—")}</div>
                            </div>

                            <div class="focus-badges">
                                ${getStatusBadge(m)}
                                ${getEditBadge(m)}
                            </div>
                        </div>

                        <div class="focus-scoreboard">
                            <div class="focus-team ${t1Winner ? "winner" : ""}">
                                ${esc(m.team1Text)}
                            </div>

                            <div class="focus-score-center">
                                <div class="focus-score-value">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                                <div class="focus-score-label">Tỷ số hiện tại</div>
                            </div>

                            <div class="focus-team right ${t2Winner ? "winner" : ""}">
                                ${esc(m.team2Text)}
                            </div>
                        </div>

                        <div class="focus-controls">
                            <div class="history-section">
                                <div class="section-title">Lịch sử chấm điểm</div>
                                ${historyHtml(m.scoreHistories)}
                            </div>

                            <div class="score-form-section">
                                <div class="section-title">Chấm điểm trận đấu</div>

                                ${m.canEditScore ? `
                                    <form id="inlineScoreForm">
                                        <div id="inlineScoreErr" class="alert alert-danger d-none"></div>

                                        <div class="big-score-inputs">
                                            <div class="big-score-box">
                                                <label>${esc(m.team1Text)}</label>
                                                <div class="score-stepper">
                                                    <button type="button" class="score-stepper-btn score-stepper-btn--minus" data-score-target="inlineScore1" data-score-step="-1" aria-label="Trừ 1 điểm cho ${esc(m.team1Text)}">
                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                    <input type="text" class="form-control" id="inlineScore1" inputmode="numeric" pattern="[0-9]*" autocomplete="off" enterkeyhint="done" value="${Number(m.scoreTeam1 || 0)}" aria-label="Điểm ${esc(m.team1Text)}" />
                                                    <button type="button" class="score-stepper-btn" data-score-target="inlineScore1" data-score-step="1" aria-label="Cộng 1 điểm cho ${esc(m.team1Text)}">
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="big-score-box">
                                                <label>${esc(m.team2Text)}</label>
                                                <div class="score-stepper">
                                                    <button type="button" class="score-stepper-btn score-stepper-btn--minus" data-score-target="inlineScore2" data-score-step="-1" aria-label="Trừ 1 điểm cho ${esc(m.team2Text)}">
                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                    <input type="text" class="form-control" id="inlineScore2" inputmode="numeric" pattern="[0-9]*" autocomplete="off" enterkeyhint="done" value="${Number(m.scoreTeam2 || 0)}" aria-label="Điểm ${esc(m.team2Text)}" />
                                                    <button type="button" class="score-stepper-btn" data-score-target="inlineScore2" data-score-step="1" aria-label="Cộng 1 điểm cho ${esc(m.team2Text)}">
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-group mt-3">
                                            <label>Tình huống</label>
                                            <select class="form-control form-note-select" id="inlineScoreNote">
                                                <option value="">-- Chọn tình huống --</option>
                                                <option value="Tay Hai">Tay Hai</option>
                                                <option value="Tay Một">Tay Một</option>
                                                <option value="Đổi tay">Đổi tay</option>
                                            </select>
                                        </div>

                                        <div class="switch-wrap">
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="inlineIsCompleted" ${completed ? "checked" : ""}>
                                                <label class="custom-control-label" for="inlineIsCompleted">Kết thúc trận đấu</label>
                                            </div>
                                        </div>

                                        <button type="submit" class="btn btn-success btn-block mt-3" id="btnInlineSubmit">
                                            <i class="fas fa-save"></i> Lưu điểm cho trận này
                                        </button>
                                    </form>
                                ` : `
                                    <div class="focus-lock">
                                        <i class="fas fa-lock"></i>
                                        Trọng tài chỉ có thể chấm điểm cho trận diễn ra trong hôm nay.
                                    </div>
                                `}
                            </div>
                        </div>
                    </div>
                `;
            }

            function normalizeSearchText(value) {
                return String(value || "")
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .toLowerCase()
                    .trim();
            }

            function getSearchText(m) {
                return normalizeSearchText([
                    m.matchId,
                    `#${m.matchId}`,
                    m.team1Text,
                    m.team2Text
                ].join(" "));
            }

            function getVisibleMatches() {
                const items = CACHE.items || [];
                const query = normalizeSearchText(SEARCH_QUERY);

                if (!query) return items;

                return items.filter(m => getSearchText(m).includes(query));
            }

            function updateSearchHint(visibleCount, totalCount) {
                const hint = $id("searchHint");
                const toggle = $id("btnSearchToggle");
                if (!hint || !toggle) return;

                const hasQuery = !!SEARCH_QUERY.trim();
                toggle.classList.toggle("active", hasQuery);

                if (!hasQuery) {
                    hint.textContent = "Nhập mã trận hoặc tên đội để lọc nhanh.";
                    return;
                }

                hint.textContent = `Đang hiển thị ${visibleCount}/${totalCount} trận phù hợp.`;
            }

            function render() {
                const box = $id("cards");
                const allItems = CACHE.items || [];
                const items = getVisibleMatches();

                updateSearchHint(items.length, allItems.length);

                if (!allItems.length) {
                    box.innerHTML = `<div class="empty-box">Bạn chưa được phân công trận đấu nào.</div>`;
                    return;
                }

                if (!items.length) {
                    box.innerHTML = `<div class="empty-box">Không tìm thấy trận đấu phù hợp với từ khóa đang nhập.</div>`;
                    return;
                }

                box.innerHTML = items.map(cardHtml).join("");
            }

            function getMatchIdFromUrl() {
                const params = new URLSearchParams(window.location.search);
                const queryId = Number(params.get("matchId") || 0);

                if (Number.isFinite(queryId) && queryId > 0) {
                    return queryId;
                }

                const parts = window.location.pathname.replace(/\/+$/, "").split("/").filter(Boolean);
                const isMatchesPage = parts[0]?.toLowerCase() === "refereeportal" && parts[1]?.toLowerCase() === "matches";
                const pathId = Number(isMatchesPage ? parts[2] : 0);

                return Number.isFinite(pathId) && pathId > 0 ? pathId : null;
            }

            function setMatchUrl(matchId, replace = false) {
                const nextUrl = `/RefereePortal/Matches/${encodeURIComponent(matchId)}`;
                const currentUrl = `${window.location.pathname}${window.location.search}`;
                if (currentUrl === nextUrl) return;

                window.history[replace ? "replaceState" : "pushState"]({ matchId }, "", nextUrl);
            }

            function setMatchesListUrl() {
                const nextUrl = "/RefereePortal/Matches";
                const currentUrl = `${window.location.pathname}${window.location.search}`;
                if (currentUrl === nextUrl) return;

                window.history.replaceState({ matchId: null }, "", nextUrl);
            }

            function openOverlay(matchId, options = {}) {
                ACTIVE_MATCH_ID = matchId;
                const m = getMatch(matchId);
                if (!m) return;

                $id("overlayTitle").textContent = `Mã trận #${m.matchId} • ${m.tournamentTitle || "Chi tiết trận đấu"}`;
                $id("overlaySubtitle").innerHTML = `
                    Trận đấu riêng biệt để chấm điểm, tránh nhầm lẫn với các trận khác.
                `;
                $id("overlayContent").innerHTML = detailHtml(m);
                $id("matchOverlay").classList.add("show");
                document.body.style.overflow = "hidden";

                bindInlineScoreForm();

                if (options.syncUrl !== false) {
                    setMatchUrl(matchId, !!options.replaceUrl);
                }
            }

            function closeOverlay(options = {}) {
                ACTIVE_MATCH_ID = null;
                $id("matchOverlay").classList.remove("show");
                $id("overlayContent").innerHTML = "";
                document.body.style.overflow = "";

                if (REFRESH_CARDS_ON_CLOSE) {
                    render();
                    REFRESH_CARDS_ON_CLOSE = false;
                }

                if (options.syncUrl !== false) {
                    setMatchesListUrl();
                }
            }

            function normalizeScoreInput(input, fallbackToZero = false) {
                if (!input) return "0";

                const cleaned = String(input.value || "").replace(/[^\d]/g, "");
                const nextValue = fallbackToZero && cleaned === "" ? "0" : cleaned;

                if (input.value !== nextValue) {
                    input.value = nextValue;
                }

                return nextValue;
            }

            function readScoreInput(input) {
                const value = normalizeScoreInput(input, true);
                const score = Number(value || 0);
                return Number.isFinite(score) ? Math.max(0, Math.floor(score)) : 0;
            }

            function setScoreInput(input, value) {
                if (!input) return;

                const score = Number(value || 0);
                input.value = String(Number.isFinite(score) ? Math.max(0, Math.floor(score)) : 0);
                input.dispatchEvent(new Event("input", { bubbles: true }));

                try {
                    input.focus({ preventScroll: true });
                } catch {
                    input.focus();
                }

                const end = input.value.length;
                if (typeof input.setSelectionRange === "function") {
                    input.setSelectionRange(end, end);
                }
            }

            function getInlineScorePayload() {
                const note = ($id("inlineScoreNote")?.value || "").trim();
                const isCompleted = !!$id("inlineIsCompleted")?.checked;

                return {
                    scoreTeam1: readScoreInput($id("inlineScore1")),
                    scoreTeam2: readScoreInput($id("inlineScore2")),
                    isCompleted,
                    note: note || null
                };
            }

            function setInlineScoreSaving(form, isSaving, triggerButton = null, showTriggerSpinner = true, showSubmitSpinner = true) {
                const submitButton = $id("btnInlineSubmit");
                const stepButtons = form ? Array.from(form.querySelectorAll("[data-score-target]")) : [];

                if (submitButton) {
                    submitButton.disabled = isSaving;

                    if (showSubmitSpinner) {
                        submitButton.innerHTML = isSaving
                            ? `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`
                            : `<i class="fas fa-save"></i> Lưu điểm cho trận này`;
                    }
                }

                stepButtons.forEach(button => {
                    button.disabled = isSaving;
                });

                if (!triggerButton || !showTriggerSpinner) return;

                if (isSaving) {
                    triggerButton.dataset.originalHtml = triggerButton.innerHTML;
                    triggerButton.innerHTML = `<i class="fas fa-spinner fa-spin"></i>`;
                } else if (triggerButton.dataset.originalHtml) {
                    triggerButton.innerHTML = triggerButton.dataset.originalHtml;
                    delete triggerButton.dataset.originalHtml;
                }
            }

            function applyScoreSaveResult(matchId, data) {
                const idx = (CACHE.items || []).findIndex(x => x.matchId === matchId);
                if (idx < 0) return;

                CACHE.items[idx].scoreTeam1 = data.scoreTeam1;
                CACHE.items[idx].scoreTeam2 = data.scoreTeam2;
                CACHE.items[idx].isCompleted = data.isCompleted;
                CACHE.items[idx].winnerRegistrationId = data.winnerRegistrationId;
                CACHE.items[idx].winnerTeam = data.winnerTeam;

                if (!Array.isArray(CACHE.items[idx].scoreHistories)) {
                    CACHE.items[idx].scoreHistories = [];
                }

                CACHE.items[idx].scoreHistories.unshift(data.history);
            }

            function syncInlineScoreView(data) {
                const scoreTeam1 = Number(data.scoreTeam1 || 0);
                const scoreTeam2 = Number(data.scoreTeam2 || 0);
                const scoreText = `${scoreTeam1} - ${scoreTeam2}`;
                const scoreValue = document.querySelector("#overlayContent .focus-score-value");
                const score1Input = $id("inlineScore1");
                const score2Input = $id("inlineScore2");

                if (scoreValue) {
                    scoreValue.textContent = scoreText;
                }

                if (score1Input) {
                    score1Input.value = String(scoreTeam1);
                }

                if (score2Input) {
                    score2Input.value = String(scoreTeam2);
                }
            }

            function showScoreToast(message, type = "success") {
                const toast = $id("scoreToast");
                if (!toast) return;

                window.clearTimeout(SCORE_TOAST_TIMER);
                toast.className = `score-toast ${type}`;
                toast.innerHTML = `<i class="fas ${type === "error" ? "fa-exclamation-circle" : "fa-check-circle"}"></i><span></span>`;
                toast.querySelector("span").textContent = message;

                window.requestAnimationFrame(() => toast.classList.add("show"));
                SCORE_TOAST_TIMER = window.setTimeout(() => {
                    toast.classList.remove("show");
                }, 1400);
            }

            async function saveInlineScore(form, options = {}) {
                if (SCORE_SAVE_BUSY || !ACTIVE_MATCH_ID) return false;

                const triggerButton = options.triggerButton || null;
                const refreshOverlay = options.refreshOverlay !== false;
                const showToast = !!options.showToast;
                const triggerSpinner = options.triggerSpinner !== false;
                const submitSpinner = options.submitSpinner !== false;
                const matchId = ACTIVE_MATCH_ID;
                const errBox = $id("inlineScoreErr");
                const payload = getInlineScorePayload();

                if (errBox) {
                    errBox.classList.add("d-none");
                    errBox.textContent = "";
                }

                SCORE_SAVE_BUSY = true;
                setInlineScoreSaving(form, true, triggerButton, triggerSpinner, submitSpinner);

                try {
                    const res = await axios.put(`${API}/${matchId}/score`, payload);

                    applyScoreSaveResult(matchId, res.data);

                    if (refreshOverlay) {
                        render();

                        if (ACTIVE_MATCH_ID === matchId) {
                            openOverlay(matchId, { syncUrl: false });
                        }
                    } else {
                        syncInlineScoreView(res.data);
                        REFRESH_CARDS_ON_CLOSE = true;

                        if (showToast) {
                            showScoreToast("Đã lưu điểm");
                        }
                    }

                    return true;
                } catch (err) {
                    if (errBox) {
                        errBox.textContent = err?.response?.data?.message || err?.message || "Chấm điểm thất bại.";
                        errBox.classList.remove("d-none");
                    }

                    if (showToast) {
                        showScoreToast("Không lưu được điểm", "error");
                    }

                    return false;
                } finally {
                    SCORE_SAVE_BUSY = false;
                    setInlineScoreSaving(form, false, triggerButton, triggerSpinner, submitSpinner);
                }
            }

            function shouldConfirmEndMatch() {
                const match = getMatch(ACTIVE_MATCH_ID);
                const checkbox = $id("inlineIsCompleted");

                return !!checkbox?.checked && !match?.isCompleted;
            }

            function setEndMatchConfirmVisible(isVisible) {
                const modal = $id("endMatchConfirm");
                if (!modal) return;

                modal.classList.toggle("show", isVisible);
                modal.setAttribute("aria-hidden", isVisible ? "false" : "true");

                if (isVisible) {
                    window.setTimeout(() => $id("btnEndMatchConfirm")?.focus(), 0);
                }
            }

            function resolveEndMatchConfirm(result) {
                if (!END_MATCH_CONFIRM_RESOLVE) return;

                const resolve = END_MATCH_CONFIRM_RESOLVE;
                END_MATCH_CONFIRM_RESOLVE = null;
                setEndMatchConfirmVisible(false);
                resolve(result);
            }

            function confirmEndMatch() {
                if (END_MATCH_CONFIRM_RESOLVE) {
                    resolveEndMatchConfirm(false);
                }

                setEndMatchConfirmVisible(true);

                return new Promise(resolve => {
                    END_MATCH_CONFIRM_RESOLVE = resolve;
                });
            }

            function bindEndMatchConfirm() {
                const modal = $id("endMatchConfirm");
                const cancelButton = $id("btnEndMatchCancel");
                const confirmButton = $id("btnEndMatchConfirm");
                if (!modal || !cancelButton || !confirmButton) return;

                cancelButton.addEventListener("click", () => resolveEndMatchConfirm(false));
                confirmButton.addEventListener("click", () => resolveEndMatchConfirm(true));

                modal.addEventListener("click", (event) => {
                    if (event.target === modal) {
                        resolveEndMatchConfirm(false);
                    }
                });
            }

            function bindScoreInputs(form) {
                const scoreInputs = [$id("inlineScore1"), $id("inlineScore2")].filter(Boolean);

                scoreInputs.forEach(input => {
                    input.addEventListener("input", () => normalizeScoreInput(input));
                    input.addEventListener("blur", () => normalizeScoreInput(input, true));
                    input.addEventListener("focus", () => {
                        window.setTimeout(() => input.select?.(), 0);
                    });
                });

                form.querySelectorAll("[data-score-target]").forEach(button => {
                    button.addEventListener("click", async (event) => {
                        event.preventDefault();

                        const input = $id(button.dataset.scoreTarget);
                        const step = Number(button.dataset.scoreStep || 1);
                        const currentScore = readScoreInput(input);
                        const nextScore = Math.max(0, currentScore + step);

                        if (nextScore === currentScore && step < 0) return;

                        setScoreInput(input, nextScore);
                        const saved = await saveInlineScore(form, {
                            triggerButton: button,
                            refreshOverlay: false,
                            showToast: true,
                            triggerSpinner: false,
                            submitSpinner: false
                        });

                        if (!saved) {
                            setScoreInput(input, currentScore);
                        }
                    });
                });
            }

            function bindInlineScoreForm() {
                const form = $id("inlineScoreForm");
                if (!form || !ACTIVE_MATCH_ID) return;

                bindScoreInputs(form);

                form.addEventListener("submit", async (e) => {
                    e.preventDefault();

                    if (shouldConfirmEndMatch()) {
                        const confirmed = await confirmEndMatch();
                        if (!confirmed) return;
                    }

                    await saveInlineScore(form);
                });
            }

            async function loadMe() {
                try {
                    const res = await axios.get("/api/referee-auth/me");
                    $id("meBox").textContent = res.data?.fullName || "";
                } catch {
                    $id("meBox").textContent = "";
                }
            }

            async function loadMatches() {
                hideErr();
                try {
                    const res = await axios.get(API);
                    CACHE.items = res.data?.items || [];
                    render();

                    const matchId = getMatchIdFromUrl();
                    if (matchId) {
                        if (getMatch(matchId)) {
                            openOverlay(matchId, {
                                replaceUrl: true
                            });
                        } else {
                            showErr("Không tìm thấy trận đấu này trong danh sách được phân công.");
                            setMatchesListUrl();
                        }
                    }
                } catch (err) {
                    showErr(err?.response?.data?.message || err?.message || "Tải dữ liệu thất bại.");
                }
            }

            function openSearchPopover() {
                const topbar = document.querySelector(".topbar");
                const button = $id("btnSearchToggle");
                const input = $id("matchSearchInput");
                if (!topbar || !button || !input) return;

                topbar.classList.add("search-open");
                button.setAttribute("aria-expanded", "true");

                window.setTimeout(() => {
                    try {
                        input.focus({ preventScroll: true });
                    } catch {
                        input.focus();
                    }
                    input.select?.();
                }, 0);
            }

            function closeSearchPopover() {
                const topbar = document.querySelector(".topbar");
                const button = $id("btnSearchToggle");
                if (!topbar || !button) return;

                topbar.classList.remove("search-open");
                button.setAttribute("aria-expanded", "false");
            }

            function clearSearch() {
                SEARCH_QUERY = "";

                const input = $id("matchSearchInput");
                if (input) {
                    input.value = "";
                }

                render();
            }

            function bindMatchSearch() {
                const topbar = document.querySelector(".topbar");
                const toggle = $id("btnSearchToggle");
                const input = $id("matchSearchInput");
                const clearButton = $id("btnSearchClear");
                if (!topbar || !toggle || !input || !clearButton) return;

                toggle.addEventListener("click", (event) => {
                    event.stopPropagation();

                    if (topbar.classList.contains("search-open")) {
                        closeSearchPopover();
                    } else {
                        openSearchPopover();
                    }
                });

                input.addEventListener("input", () => {
                    SEARCH_QUERY = input.value || "";
                    render();
                });

                input.addEventListener("keydown", (event) => {
                    if (event.key !== "Escape") return;

                    if (SEARCH_QUERY.trim()) {
                        clearSearch();
                    } else {
                        closeSearchPopover();
                    }
                });

                clearButton.addEventListener("click", () => {
                    clearSearch();
                    try {
                        input.focus({ preventScroll: true });
                    } catch {
                        input.focus();
                    }
                });

                document.addEventListener("click", (event) => {
                    if (!topbar.classList.contains("search-open")) return;
                    if (topbar.contains(event.target)) return;

                    closeSearchPopover();
                });
            }

            window.openMatchDetail = (matchId) => {
                openOverlay(matchId);
            };

            $id("btnCloseOverlay").addEventListener("click", closeOverlay);

            $id("matchOverlay").addEventListener("click", (e) => {
                if (e.target.id === "matchOverlay") {
                    closeOverlay();
                }
            });

            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && $id("endMatchConfirm")?.classList.contains("show")) {
                    resolveEndMatchConfirm(false);
                    return;
                }

                if (e.key === "Escape" && $id("matchOverlay").classList.contains("show")) {
                    closeOverlay();
                }
            });

            window.addEventListener("popstate", () => {
                const matchId = getMatchIdFromUrl();

                if (matchId && getMatch(matchId)) {
                    openOverlay(matchId, { syncUrl: false });
                    return;
                }

                if ($id("matchOverlay").classList.contains("show")) {
                    closeOverlay({ syncUrl: false });
                }
            });

            $id("btnLogout").addEventListener("click", async () => {
                await axios.post("/api/referee-auth/logout");
                window.location.href = "/RefereePortal/Login";
            });

            document.addEventListener("DOMContentLoaded", async () => {
                bindMatchSearch();
                bindEndMatchConfirm();
                await loadMe();
                await loadMatches();
            });
        })();
    </script>
</body>
</html> 
