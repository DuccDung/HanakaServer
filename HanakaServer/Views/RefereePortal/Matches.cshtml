@{
    Layout = null;
    ViewData["Title"] = "Trận đấu của trọng tài";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --bg: #f3f4f6;
            --card: #ffffff;
            --border: #e5e7eb;
            --muted: #6b7280;
            --text: #111827;
            --primary: #2563eb;
            --success: #16a34a;
            --warning: #d97706;
            --dark: #0f172a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            font-family: Arial, sans-serif;
            color: var(--text);
            margin: 0;
        }

        .topbar {
            background: var(--dark);
            color: #fff;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-wrap {
            max-width: 1280px;
            margin: 24px auto;
            padding: 0 16px 32px;
        }

        .page-title {
            font-size: 30px;
            font-weight: 800;
            margin-bottom: 6px;
            color: var(--text);
        }

        .page-subtitle {
            color: var(--muted);
            margin-bottom: 24px;
        }

        .match-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .match-card {
            background: var(--card);
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 8px 24px rgba(0,0,0,.05);
            padding: 18px;
            cursor: pointer;
            transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
        }

        .match-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(0,0,0,.08);
            border-color: #cbd5e1;
        }

        .match-card.completed {
            border-color: #bbf7d0;
        }

        .match-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
        }

        .match-title {
            font-size: 17px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 4px;
        }

        .match-meta {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 2px;
        }

        .match-chip-col {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 6px;
        }

        .match-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 700;
            background: #eef2ff;
            color: #3730a3;
        }

        .match-chip.success {
            background: #dcfce7;
            color: #166534;
        }

        .match-chip.muted {
            background: #f3f4f6;
            color: #4b5563;
        }

        .score-preview {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px dashed #d1d5db;
        }

        .team-preview {
            font-weight: 700;
            font-size: 15px;
            color: var(--text);
            line-height: 1.4;
        }

        .team-preview.right {
            text-align: right;
        }

        .team-preview.winner {
            color: var(--warning);
        }

        .score-preview-value {
            font-size: 28px;
            font-weight: 900;
            color: var(--text);
            min-width: 96px;
            text-align: center;
        }

        .hint-click {
            margin-top: 14px;
            font-size: 12px;
            color: var(--primary);
            font-weight: 700;
        }

        .empty-box {
            background: #fff;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
            padding: 32px;
            text-align: center;
            color: var(--muted);
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .72);
            z-index: 3000;
            display: none;
            align-items: stretch;
            justify-content: stretch;
        }

        .overlay.show {
            display: flex;
        }

        .overlay-panel {
            background: #fff;
            width: 100%;
            height: 100%;
            overflow: auto;
            display: flex;
            flex-direction: column;
        }

        .overlay-header {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
        }

        .overlay-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 4px;
            color: var(--text);
        }

        .overlay-subtitle {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.5;
        }

        .overlay-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .overlay-body {
            padding: 24px;
        }

        .focus-match {
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
        }

        .focus-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

        .focus-meta {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.7;
        }

        .focus-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .focus-scoreboard {
            margin-top: 18px;
            padding-top: 20px;
            border-top: 1px dashed #d1d5db;
            display: grid;
            grid-template-columns: 1fr 280px 1fr;
            gap: 20px;
            align-items: center;
        }

        .focus-team {
            font-size: 28px;
            font-weight: 800;
            line-height: 1.35;
            color: var(--text);
        }

        .focus-team.right {
            text-align: right;
        }

        .focus-team.winner {
            color: var(--warning);
        }

        .focus-score-center {
            background: #0f172a;
            color: #fff;
            border-radius: 24px;
            padding: 24px 12px;
            text-align: center;
            box-shadow: 0 12px 28px rgba(15, 23, 42, .18);
        }

        .focus-score-value {
            font-size: 72px;
            font-weight: 900;
            line-height: 1;
            letter-spacing: 1px;
        }

        .focus-score-label {
            margin-top: 10px;
            font-size: 14px;
            opacity: .9;
            font-weight: 700;
        }

        .focus-controls {
            margin-top: 28px;
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 24px;
        }

        .history-section,
        .score-form-section {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 14px;
            color: var(--text);
        }

        .history-list {
            max-height: 420px;
            overflow: auto;
            padding-right: 4px;
        }

        .history-empty {
            color: var(--muted);
            font-size: 14px;
        }

        .history-item {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 10px;
        }

        .history-score {
            font-size: 18px;
            font-weight: 900;
            color: var(--text);
        }

        .history-meta {
            font-size: 12px;
            color: var(--muted);
            margin-top: 4px;
        }

        .history-note {
            margin-top: 8px;
            font-size: 14px;
            color: var(--text);
        }

        .big-score-inputs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .big-score-box label {
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
        }

        .big-score-box input {
            height: 90px;
            font-size: 42px;
            font-weight: 900;
            text-align: center;
            border-radius: 16px;
        }

        .form-note-select {
            height: 48px;
            border-radius: 12px;
        }

        .switch-wrap {
            margin-top: 14px;
            padding: 12px 14px;
            background: #f8fafc;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }

        .focus-lock {
            margin-top: 14px;
            padding: 12px 14px;
            border-radius: 12px;
            background: #fff7ed;
            color: #9a3412;
            border: 1px solid #fed7aa;
            font-size: 14px;
            font-weight: 700;
        }

        @@media (max-width: 1100px) {
            .match-grid {
                grid-template-columns: 1fr;
            }

            .focus-scoreboard {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .focus-team,
            .focus-team.right {
                text-align: center;
                font-size: 24px;
            }

            .focus-controls {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .topbar {
                padding: 12px 14px;
            }

            .overlay-header,
            .overlay-body {
                padding: 14px;
            }

            .focus-match {
                padding: 16px;
            }

            .focus-score-value {
                font-size: 54px;
            }

            .big-score-box input {
                height: 76px;
                font-size: 34px;
            }
        }
    </style>
</head>
<body>
    <div class="topbar">
        <div class="topbar-left">
            <i class="fas fa-gavel"></i>
            <span>Cổng trọng tài</span>
        </div>
        <div class="topbar-right">
            <span id="meBox" class="small"></span>
            <button class="btn btn-sm btn-light" id="btnLogout" type="button">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </button>
        </div>
    </div>

    <div class="page-wrap">
        <div class="page-title">Trận đấu được phân công</div>
        <div class="page-subtitle">
            Chọn đúng trận đấu để vào màn hình chấm điểm riêng. Trọng tài chỉ có thể chấm khi đã đến thời gian thi đấu.
        </div>

        <div id="errBox" class="alert alert-danger d-none"></div>

        <div id="cards" class="match-grid">
            <div class="empty-box">Đang tải...</div>
        </div>
    </div>

    <!-- Full screen overlay -->
    <div class="overlay" id="matchOverlay">
        <div class="overlay-panel">
            <div class="overlay-header">
                <div>
                    <div class="overlay-title" id="overlayTitle">Chi tiết trận đấu</div>
                    <div class="overlay-subtitle" id="overlaySubtitle"></div>
                </div>

                <div class="overlay-actions">
                    <button type="button" class="btn btn-outline-secondary" id="btnCloseOverlay">
                        <i class="fas fa-times"></i> Đóng
                    </button>
                </div>
            </div>

            <div class="overlay-body">
                <div id="overlayContent"></div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        (() => {
            const $id = (id) => document.getElementById(id);
            const API = `/api/referee/matches`;

            let CACHE = { items: [] };
            let ACTIVE_MATCH_ID = null;

            const esc = (s) => String(s || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const fmt = (dt) => {
                if (!dt) return "—";
                const d = new Date(dt);
                if (isNaN(d.getTime())) return "—";
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");
                return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
            };

            function showErr(msg) {
                const box = $id("errBox");
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideErr() {
                const box = $id("errBox");
                box.classList.add("d-none");
                box.textContent = "";
            }

            function getMatch(matchId) {
                return (CACHE.items || []).find(x => x.matchId === matchId) || null;
            }

            function getStatusBadge(m) {
                if (m.isCompleted) {
                    return `<span class="match-chip success"><i class="fas fa-check-circle"></i> Đã kết thúc</span>`;
                }
                return `<span class="match-chip muted"><i class="fas fa-clock"></i> Chưa kết thúc</span>`;
            }

            function getEditBadge(m) {
                if (m.canEditScore) {
                    return `<span class="match-chip"><i class="fas fa-clipboard-check"></i> Có thể chấm điểm</span>`;
                }
                return `<span class="match-chip muted"><i class="fas fa-lock"></i> Chưa đến giờ đấu</span>`;
            }

            function cardHtml(m) {
                const completed = !!m.isCompleted;
                const t1Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team1RegistrationId;
                const t2Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team2RegistrationId;

                return `
                    <div class="match-card ${completed ? "completed" : ""}" onclick="openMatchDetail(${m.matchId})">
                        <div class="match-head">
                            <div>
                                <div class="match-title">${esc(m.tournamentTitle)}</div>
                                <div class="match-meta">Vòng: ${esc(m.roundKey)} • ${esc(m.roundLabel)} • Bảng: ${esc(m.groupName)}</div>
                                <div class="match-meta">Bắt đầu: ${fmt(m.startAt)}${m.courtText ? " • " + esc(m.courtText) : ""}</div>
                                <div class="match-meta">Địa chỉ: ${esc(m.addressText || "—")}</div>
                            </div>

                            <div class="match-chip-col">
                                ${getStatusBadge(m)}
                                ${getEditBadge(m)}
                            </div>
                        </div>

                        <div class="score-preview">
                            <div class="team-preview ${t1Winner ? "winner" : ""}">${esc(m.team1Text)}</div>
                            <div class="score-preview-value">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                            <div class="team-preview right ${t2Winner ? "winner" : ""}">${esc(m.team2Text)}</div>
                        </div>

                        <div class="hint-click">
                            <i class="fas fa-expand"></i> Bấm để vào màn hình chấm điểm riêng cho trận này
                        </div>
                    </div>
                `;
            }

            function historyHtml(histories) {
                if (!histories || !histories.length) {
                    return `<div class="history-empty">Chưa có lịch sử chấm điểm.</div>`;
                }

                return `
                    <div class="history-list">
                        ${histories.map(h => `
                            <div class="history-item">
                                <div class="history-score">
                                    ${Number(h.scoreTeam1 || 0)} - ${Number(h.scoreTeam2 || 0)}
                                    ${h.winnerTeam ? `<span class="badge badge-warning ml-2">Đội thắng: ${h.winnerTeam}</span>` : ``}
                                </div>
                                <div class="history-meta">
                                    ${esc(h.refereeName || ("User #" + h.refereeUserId))} • ${fmt(h.createdAt)}
                                </div>
                                ${h.note ? `<div class="history-note">${esc(h.note)}</div>` : ``}
                            </div>
                        `).join("")}
                    </div>
                `;
            }

            function detailHtml(m) {
                const completed = !!m.isCompleted;
                const t1Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team1RegistrationId;
                const t2Winner = completed && m.winnerRegistrationId && m.winnerRegistrationId === m.team2RegistrationId;

                return `
                    <div class="focus-match">
                        <div class="focus-top">
                            <div>
                                <div class="focus-meta"><b>Giải đấu:</b> ${esc(m.tournamentTitle)}</div>
                                <div class="focus-meta"><b>Vòng:</b> ${esc(m.roundKey)} • ${esc(m.roundLabel)} • <b>Bảng:</b> ${esc(m.groupName)}</div>
                                <div class="focus-meta"><b>Bắt đầu:</b> ${fmt(m.startAt)}</div>
                                <div class="focus-meta"><b>Sân:</b> ${esc(m.courtText || "—")}</div>
                                <div class="focus-meta"><b>Địa chỉ:</b> ${esc(m.addressText || "—")}</div>
                            </div>

                            <div class="focus-badges">
                                ${getStatusBadge(m)}
                                ${getEditBadge(m)}
                            </div>
                        </div>

                        <div class="focus-scoreboard">
                            <div class="focus-team ${t1Winner ? "winner" : ""}">
                                ${esc(m.team1Text)}
                            </div>

                            <div class="focus-score-center">
                                <div class="focus-score-value">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                                <div class="focus-score-label">Tỷ số hiện tại</div>
                            </div>

                            <div class="focus-team right ${t2Winner ? "winner" : ""}">
                                ${esc(m.team2Text)}
                            </div>
                        </div>

                        <div class="focus-controls">
                            <div class="history-section">
                                <div class="section-title">Lịch sử chấm điểm</div>
                                ${historyHtml(m.scoreHistories)}
                            </div>

                            <div class="score-form-section">
                                <div class="section-title">Chấm điểm trận đấu</div>

                                ${m.canEditScore ? `
                                    <form id="inlineScoreForm">
                                        <div id="inlineScoreErr" class="alert alert-danger d-none"></div>

                                        <div class="big-score-inputs">
                                            <div class="big-score-box">
                                                <label>${esc(m.team1Text)}</label>
                                                <input type="number" class="form-control" id="inlineScore1" min="0" value="${Number(m.scoreTeam1 || 0)}" />
                                            </div>
                                            <div class="big-score-box">
                                                <label>${esc(m.team2Text)}</label>
                                                <input type="number" class="form-control" id="inlineScore2" min="0" value="${Number(m.scoreTeam2 || 0)}" />
                                            </div>
                                        </div>

                                        <div class="form-group mt-3">
                                            <label>Tình huống</label>
                                            <select class="form-control form-note-select" id="inlineScoreNote">
                                                <option value="">-- Chọn tình huống --</option>
                                                <option value="Tay Hai">Tay Hai</option>
                                                <option value="Tay Một">Tay Một</option>
                                                <option value="Đổi tay">Đổi tay</option>
                                            </select>
                                        </div>

                                        <div class="switch-wrap">
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="inlineIsCompleted">
                                                <label class="custom-control-label" for="inlineIsCompleted">Kết thúc trận đấu</label>
                                            </div>
                                        </div>

                                        <button type="submit" class="btn btn-success btn-block mt-3" id="btnInlineSubmit">
                                            <i class="fas fa-save"></i> Lưu điểm cho trận này
                                        </button>
                                    </form>
                                ` : `
                                    <div class="focus-lock">
                                        <i class="fas fa-lock"></i>
                                        Chưa đến thời gian thi đấu. Trọng tài chỉ có thể xem thông tin trận đấu này.
                                    </div>
                                `}
                            </div>
                        </div>
                    </div>
                `;
            }

            function render() {
                const box = $id("cards");
                const items = CACHE.items || [];

                if (!items.length) {
                    box.innerHTML = `<div class="empty-box">Bạn chưa được phân công trận đấu nào.</div>`;
                    return;
                }

                box.innerHTML = items.map(cardHtml).join("");
            }

            function openOverlay(matchId) {
                ACTIVE_MATCH_ID = matchId;
                const m = getMatch(matchId);
                if (!m) return;

                $id("overlayTitle").textContent = m.tournamentTitle || "Chi tiết trận đấu";
                $id("overlaySubtitle").innerHTML = `
                    Trận đấu riêng biệt để chấm điểm, tránh nhầm lẫn với các trận khác.
                `;
                $id("overlayContent").innerHTML = detailHtml(m);
                $id("matchOverlay").classList.add("show");
                document.body.style.overflow = "hidden";

                bindInlineScoreForm();
            }

            function closeOverlay() {
                ACTIVE_MATCH_ID = null;
                $id("matchOverlay").classList.remove("show");
                $id("overlayContent").innerHTML = "";
                document.body.style.overflow = "";
            }

            function bindInlineScoreForm() {
                const form = $id("inlineScoreForm");
                if (!form || !ACTIVE_MATCH_ID) return;

                form.addEventListener("submit", async (e) => {
                    e.preventDefault();

                    const errBox = $id("inlineScoreErr");
                    const btn = $id("btnInlineSubmit");

                    errBox.classList.add("d-none");
                    errBox.textContent = "";

                    const s1 = Number($id("inlineScore1").value || 0);
                    const s2 = Number($id("inlineScore2").value || 0);
                    const note = ($id("inlineScoreNote").value || "").trim();
                    const isCompleted = !!$id("inlineIsCompleted").checked;

                    btn.disabled = true;
                    btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                    try {
                        const res = await axios.put(`${API}/${ACTIVE_MATCH_ID}/score`, {
                            scoreTeam1: s1,
                            scoreTeam2: s2,
                            isCompleted,
                            note: note || null
                        });

                        const idx = (CACHE.items || []).findIndex(x => x.matchId === ACTIVE_MATCH_ID);
                        if (idx >= 0) {
                            CACHE.items[idx].scoreTeam1 = res.data.scoreTeam1;
                            CACHE.items[idx].scoreTeam2 = res.data.scoreTeam2;
                            CACHE.items[idx].isCompleted = res.data.isCompleted;
                            CACHE.items[idx].winnerRegistrationId = res.data.winnerRegistrationId;
                            CACHE.items[idx].winnerTeam = res.data.winnerTeam;

                            if (!Array.isArray(CACHE.items[idx].scoreHistories)) {
                                CACHE.items[idx].scoreHistories = [];
                            }

                            CACHE.items[idx].scoreHistories.unshift(res.data.history);
                        }

                        render();
                        openOverlay(ACTIVE_MATCH_ID);
                    } catch (err) {
                        errBox.textContent = err?.response?.data?.message || err?.message || "Chấm điểm thất bại.";
                        errBox.classList.remove("d-none");
                    } finally {
                        btn.disabled = false;
                        btn.innerHTML = `<i class="fas fa-save"></i> Lưu điểm cho trận này`;
                    }
                });
            }

            async function loadMe() {
                try {
                    const res = await axios.get("/api/referee-auth/me");
                    $id("meBox").textContent = res.data?.fullName || "";
                } catch {
                    $id("meBox").textContent = "";
                }
            }

            async function loadMatches() {
                hideErr();
                try {
                    const res = await axios.get(API);
                    CACHE.items = res.data?.items || [];
                    render();
                } catch (err) {
                    showErr(err?.response?.data?.message || err?.message || "Tải dữ liệu thất bại.");
                }
            }

            window.openMatchDetail = (matchId) => {
                openOverlay(matchId);
            };

            $id("btnCloseOverlay").addEventListener("click", closeOverlay);

            $id("matchOverlay").addEventListener("click", (e) => {
                if (e.target.id === "matchOverlay") {
                    closeOverlay();
                }
            });

            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && $id("matchOverlay").classList.contains("show")) {
                    closeOverlay();
                }
            });

            $id("btnLogout").addEventListener("click", async () => {
                await axios.post("/api/referee-auth/logout");
                window.location.href = "/RefereePortal/Login";
            });

            document.addEventListener("DOMContentLoaded", async () => {
                await loadMe();
                await loadMatches();
            });
        })();
    </script>
</body>
</html> 