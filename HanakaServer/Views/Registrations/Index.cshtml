@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Registrations";
    var tid = (long)(ViewBag.TournamentId ?? 0L);
}

<style>
    .pill {
        border-radius: 999px;
    }

    .player-card {
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 12px;
        background: #fff;
    }

    .avatar-preview {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #ddd;
    }

    .avatar-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 1px dashed #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #aaa;
        font-weight: 700;
    }
</style>

<div class="container-fluid" id="pageRoot" data-tournament-id="@tid">
    <div class="d-sm-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Registrations</h1>
            <div class="small text-muted" id="tournamentMeta">Tournament #@tid</div>
        </div>

        <div class="d-flex" style="gap:8px">
            <button class="btn btn-sm btn-primary shadow-sm" type="button" id="btnOpenCreate">
                <i class="fas fa-plus fa-sm text-white-50"></i> Add Registration
            </button>
            <a class="btn btn-sm btn-outline-secondary" href="/Home/Tournaments">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Tabs counts -->
    <div class="mb-3 d-flex flex-wrap" style="gap:10px">
        <button class="btn btn-sm pill" id="tabSuccess">Thành công</button>
        <button class="btn btn-sm pill" id="tabWaiting">Chờ ghép</button>
        <button class="btn btn-sm pill btn-outline-secondary" id="tabCapacity">Còn chỗ</button>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">List</h6>

            <div class="d-flex" style="gap:8px; align-items:center;">
                <input id="q" class="form-control form-control-sm" style="width: 260px;" placeholder="Tìm tên / mã ĐK ..." />
                <button class="btn btn-sm btn-outline-primary" type="button" id="btnSearch">Search</button>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width:60px">#</th>
                            <th style="width:160px">Mã ĐK</th>
                            <th style="width:160px">Thời gian</th>
                            <th>VDV1</th>
                            <th>VDV2</th>
                            <th style="width:90px">Điểm</th>
                            <th style="width:110px">Mã BT</th>
                            <th style="width:80px">Paid</th>
                            <th style="width:160px">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="body">
                        <tr><td colspan="9" class="text-center text-muted">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <form id="formCreate">
                <div class="modal-header">
                    <h5 class="modal-title">Add Registration</h5>
                    <button class="close" type="button" data-dismiss="modal"><span aria-hidden="true">×</span></button>
                </div>

                <div class="modal-body">
                    <div id="createErr" class="alert alert-danger d-none"></div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>GameType</label>
                            <select class="form-control" id="gameType">
                                <option value="SINGLE">SINGLE</option>
                                <option value="DOUBLE" selected>DOUBLE</option>
                            </select>
                            <small class="text-muted">Sẽ tự lock theo Tournament.GameType nếu có.</small>
                        </div>

                        <div class="form-group col-md-4">
                            <label>Mode (DOUBLE)</label>
                            <select class="form-control" id="doubleMode">
                                <option value="PAIR" selected>Đủ cặp</option>
                                <option value="WAITING">Chờ ghép</option>
                            </select>
                        </div>

                        <div class="form-group col-md-4">
                            <label>Paid</label>
                            <select class="form-control" id="paid">
                                <option value="false" selected>No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Mã BT (optional)</label>
                            <input class="form-control" id="btCode" placeholder="BT..." />
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <!-- Player 1 -->
                        <div class="col-lg-6 mb-3">
                            <div class="player-card">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h6 class="text-primary font-weight-bold mb-0">VDV 1</h6>
                                    <div class="d-flex" style="gap:8px;align-items:center;">
                                        <label class="mb-0 small text-muted">Type</label>
                                        <select class="form-control form-control-sm" id="p1Type" style="width:120px;">
                                            <option value="USER" selected>USER</option>
                                            <option value="GUEST">GUEST</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex" style="gap:12px;align-items:center;">
                                    <div id="p1AvatarBox"><div class="avatar-placeholder">?</div></div>

                                    <div class="flex-grow-1">
                                        <!-- USER block -->
                                        <div id="p1UserBlock">
                                            <div class="form-row">
                                                <div class="form-group col-md-7 mb-2">
                                                    <label class="small text-muted">UserId</label>
                                                    <input class="form-control" id="p1UserId" placeholder="123" />
                                                </div>
                                                <div class="form-group col-md-5 mb-2 d-flex align-items-end">
                                                    <button class="btn btn-outline-primary btn-block" type="button" id="btnP1Check">
                                                        <i class="fas fa-check"></i> Check
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="small text-muted" id="p1UserInfo">Chưa check</div>
                                        </div>

                                        <!-- GUEST block -->
                                        <div id="p1GuestBlock" style="display:none;">
                                            <div class="form-row">
                                                <div class="form-group col-md-7 mb-2">
                                                    <label class="small text-muted">Name *</label>
                                                    <input class="form-control" id="p1GuestName" placeholder="VDV 1 name" />
                                                </div>
                                                <div class="form-group col-md-5 mb-2">
                                                    <label class="small text-muted">Level *</label>
                                                    <input type="number" step="0.01" class="form-control" id="p1GuestLevel" value="2.50" />
                                                </div>
                                            </div>

                                            <div class="form-group mb-0">
                                                <label class="small text-muted">Avatar (choose file)</label>
                                                <input type="file" id="p1GuestAvatarFile" accept="image/*" class="form-control" />
                                                <small class="text-muted">jpg/png/webp • max 10MB</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Player 2 -->
                        <div class="col-lg-6 mb-3" id="p2Wrap">
                            <div class="player-card">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h6 class="text-primary font-weight-bold mb-0">VDV 2</h6>
                                    <div class="d-flex" style="gap:8px;align-items:center;">
                                        <label class="mb-0 small text-muted">Type</label>
                                        <select class="form-control form-control-sm" id="p2Type" style="width:120px;">
                                            <option value="USER" selected>USER</option>
                                            <option value="GUEST">GUEST</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex" style="gap:12px;align-items:center;">
                                    <div id="p2AvatarBox"><div class="avatar-placeholder">?</div></div>

                                    <div class="flex-grow-1">
                                        <!-- USER block -->
                                        <div id="p2UserBlock">
                                            <div class="form-row">
                                                <div class="form-group col-md-7 mb-2">
                                                    <label class="small text-muted">UserId</label>
                                                    <input class="form-control" id="p2UserId" placeholder="456" />
                                                </div>
                                                <div class="form-group col-md-5 mb-2 d-flex align-items-end">
                                                    <button class="btn btn-outline-primary btn-block" type="button" id="btnP2Check">
                                                        <i class="fas fa-check"></i> Check
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="small text-muted" id="p2UserInfo">Chưa check</div>
                                        </div>

                                        <!-- GUEST block -->
                                        <div id="p2GuestBlock" style="display:none;">
                                            <div class="form-row">
                                                <div class="form-group col-md-7 mb-2">
                                                    <label class="small text-muted">Name *</label>
                                                    <input class="form-control" id="p2GuestName" placeholder="VDV 2 name" />
                                                </div>
                                                <div class="form-group col-md-5 mb-2">
                                                    <label class="small text-muted">Level *</label>
                                                    <input type="number" step="0.01" class="form-control" id="p2GuestLevel" value="2.50" />
                                                </div>
                                            </div>

                                            <div class="form-group mb-0">
                                                <label class="small text-muted">Avatar (choose file)</label>
                                                <input type="file" id="p2GuestAvatarFile" accept="image/*" class="form-control" />
                                                <small class="text-muted">jpg/png/webp • max 10MB</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit" id="btnCreateSubmit">
                        <i class="fas fa-save"></i> Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Pair -->
<div class="modal fade" id="modalPair" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="formPair">
                <input type="hidden" id="pairBaseId" />
                <div class="modal-header">
                    <h5 class="modal-title">Ghép cặp</h5>
                    <button class="close" type="button" data-dismiss="modal"><span aria-hidden="true">×</span></button>
                </div>
                <div class="modal-body">
                    <div id="pairErr" class="alert alert-danger d-none"></div>
                    <div class="form-group">
                        <label>Chọn 1 đăng ký đang chờ ghép</label>
                        <select class="form-control" id="pairWith"></select>
                        <small class="text-muted">Chỉ list WAITING. Sẽ ưu tiên auto-select người mới nhất.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-link"></i> Pair
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        (() => {
          const $id = (id) => document.getElementById(id);
          const on = (id, evt, handler) => { const el = $id(id); if (el) el.addEventListener(evt, handler); };

          const root = $id("pageRoot");
          const TOURNAMENT_ID = Number(root?.dataset?.tournamentId || 0);

          let CURRENT_TAB = "SUCCESS";
          let CACHE = { items: [], waiting: [] };
          let TOURNAMENT_GAME_TYPE = null; // "SINGLE" | "DOUBLE"

          const API_LIST = `/api/admin/tournaments/${TOURNAMENT_ID}/registrations`;

          const esc = (s) => String(s || "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
          const fmt = (dt) => {
            if(!dt) return "—";
            const d = new Date(dt);
            if(isNaN(d.getTime())) return "—";
            const yyyy=d.getFullYear(), mm=String(d.getMonth()+1).padStart(2,"0"), dd=String(d.getDate()).padStart(2,"0");
            const hh=String(d.getHours()).padStart(2,"0"), mi=String(d.getMinutes()).padStart(2,"0");
            return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
          };

          function avatarHtml(url){
            if(!url) return `<div class="avatar-placeholder">?</div>`;
            return `<img class="avatar-preview" src="${esc(url)}" />`;
          }

                  function playerCell(name, singleLevel, doubleLevel, pickedLevel, avatar, verified){
          const badge = verified ? `<span class="badge badge-success ml-2">Verified</span>` : ``;

          const s = (singleLevel === null || singleLevel === undefined) ? "—" : Number(singleLevel||0).toFixed(2);
          const d = (doubleLevel === null || doubleLevel === undefined) ? "—" : Number(doubleLevel||0).toFixed(2);
          const p = (pickedLevel === null || pickedLevel === undefined) ? "—" : Number(pickedLevel||0).toFixed(2);

          return `
            <div class="d-flex" style="gap:10px;align-items:center;">
              ${avatarHtml(avatar)}
              <div>
                <div class="font-weight-bold text-gray-900">${esc(name||"—")}${badge}</div>
                <div class="small text-muted">S: ${s} • D: ${d}</div>
                <div class="small text-muted">Pick: ${p}</div>
              </div>
            </div>
          `;
        }

          async function togglePaid(id, paid){
            await axios.put(`/api/admin/registrations/${id}`, { paid });
          }

          async function delReg(id){
            if(!confirm("Xoá đăng ký này?")) return;
            await axios.delete(`/api/admin/registrations/${id}`);
            await load(CURRENT_TAB);
          }

          function paidHtml(reg){
            const checked = reg.paid ? "checked" : "";
            return `<input type="checkbox" ${checked} onchange="togglePaid(${reg.registrationId}, this.checked)" />`;
          }

          function actionsHtml(reg){
            const isDouble = (TOURNAMENT_GAME_TYPE === "DOUBLE");
            const pairBtn = (isDouble && reg.waitingPair)
              ? `<button class="btn btn-sm btn-outline-warning" type="button" onclick="openPair(${reg.registrationId})" title="Ghép">
                   <i class="fas fa-link"></i>
                 </button>`
              : `<button class="btn btn-sm btn-outline-secondary" type="button" disabled title="Không cần ghép">
                   <i class="fas fa-link"></i>
                 </button>`;

            return `
              <div class="d-flex" style="gap:6px">
                ${pairBtn}
                <button class="btn btn-sm btn-outline-danger" type="button" onclick="delReg(${reg.registrationId})" title="Xoá">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            `;
          }

          function rowHtml(reg){
            return `
              <tr>
                <td>${reg.regIndex ?? ""}</td>
                <td><div class="font-weight-bold">${esc(reg.regCode)}</div></td>
                <td>${fmt(reg.regTime)}</td>
        <td>${playerCell(
          reg.player1Name,
          reg.player1LevelSingle,
          reg.player1LevelDouble,
          reg.player1Level, // pickedLevel hiện tại
          reg.player1Avatar,
          reg.player1Verified
        )}</td>

        <td>${playerCell(
          reg.player2Name,
          reg.player2LevelSingle,
          reg.player2LevelDouble,
          reg.player2Level,
          reg.player2Avatar,
          reg.player2Verified
        )}</td>
                <td class="text-right">${Number(reg.points||0).toFixed(2)}</td>
                <td>${esc(reg.btCode||"")}</td>
                <td class="text-center">${paidHtml(reg)}</td>
                <td>${actionsHtml(reg)}</td>
              </tr>
            `;
          }

          function setTabButtons(counts){
            const tabSuccess = $id("tabSuccess");
            const tabWaiting = $id("tabWaiting");
            const tabCapacity = $id("tabCapacity");

            if(tabSuccess){
              tabSuccess.className = `btn btn-sm pill ${CURRENT_TAB==="SUCCESS"?"btn-success":"btn-outline-success"}`;
              tabSuccess.textContent = `Thành công (${counts.success})`;
            }
            if(tabWaiting){
              tabWaiting.className = `btn btn-sm pill ${CURRENT_TAB==="WAITING"?"btn-warning":"btn-outline-warning"}`;
              tabWaiting.textContent = `Chờ ghép (${counts.waiting})`;
            }
            if(tabCapacity){
              tabCapacity.className = `btn btn-sm pill btn-outline-secondary`;
              tabCapacity.textContent = `Còn chỗ (${counts.capacityLeft})`;
            }
          }

          async function load(tab){
            CURRENT_TAB = tab;
            const body = $id("body");
            if(body) body.innerHTML = `<tr><td colspan="9" class="text-center text-muted">Loading...</td></tr>`;

            const res = await axios.get(API_LIST, { params: { tab } });
            const { tournament, counts, items } = res.data;

            TOURNAMENT_GAME_TYPE = (tournament.gameType || "").toUpperCase();

            const meta = $id("tournamentMeta");
            if(meta){
              meta.textContent = `${tournament.title} • ${tournament.status} • GameType: ${tournament.gameType}`;
            }
            setTabButtons(counts);

            CACHE.items = items || [];
            const waitingRes = await axios.get(API_LIST, { params: { tab: "WAITING" } });
            CACHE.waiting = waitingRes.data.items || [];

            if(!body) return;

            if(!CACHE.items.length){
              body.innerHTML = `<tr><td colspan="9" class="text-center text-muted">No registrations</td></tr>`;
              return;
            }
            body.innerHTML = CACHE.items.map(rowHtml).join("");
          }

          // expose for inline onclick
          window.togglePaid = togglePaid;
          window.delReg = delReg;

          function openPair(baseId){
            if(TOURNAMENT_GAME_TYPE !== "DOUBLE"){
              alert("Giải đơn không cần ghép đôi.");
              return;
            }

            $id("pairBaseId").value = String(baseId);
            $id("pairErr")?.classList.add("d-none");

            // sort waiting by regIndex desc => newest first
            const waiting = (CACHE.waiting || [])
              .filter(x => x.registrationId !== baseId)
              .sort((a,b) => (b.regIndex||0) - (a.regIndex||0));

            const sel = $id("pairWith");
                   const options = waiting.map(x => {
          const s = (x.player1LevelSingle ?? x.player1Level ?? 0).toFixed(2);
          const d = (x.player1LevelDouble ?? x.player1Level ?? 0).toFixed(2);
          return `<option value="${x.registrationId}">${x.regCode} — ${esc(x.player1Name)} (S:${s} D:${d})</option>`;
        });
            sel.innerHTML = options.join("");

            // auto-select newest (first option)
            if(sel.options.length > 0) sel.selectedIndex = 0;

            $("#modalPair").modal("show");
          }
          window.openPair = openPair;

          function showCreateErr(msg){
            const box = $id("createErr");
            if(!box) return;
            box.textContent = msg || "Error";
            box.classList.remove("d-none");
          }
          function clearCreateErr(){
            const box = $id("createErr");
            if(!box) return;
            box.classList.add("d-none");
            box.textContent = "";
          }

          function setAvatarBox(boxId, url){
            const box = $id(boxId);
            if(!box) return;
            box.innerHTML = url ? `<img class="avatar-preview" src="${esc(url)}" />` : `<div class="avatar-placeholder">?</div>`;
          }

          function applyModeUI(){
            const dm = $id("doubleMode")?.value || "PAIR";

            // lock theo tournament
            if (TOURNAMENT_GAME_TYPE === "SINGLE" || TOURNAMENT_GAME_TYPE === "DOUBLE"){
              $id("gameType").value = TOURNAMENT_GAME_TYPE;
              $id("gameType").disabled = true;
            } else {
              $id("gameType").disabled = false;
            }

            const finalGT = $id("gameType")?.value || "DOUBLE";
            const p2Wrap = $id("p2Wrap");

            if(finalGT === "SINGLE"){
              if(p2Wrap) p2Wrap.style.display = "none";
              if($id("doubleMode")) $id("doubleMode").disabled = true;
            } else {
              if($id("doubleMode")) $id("doubleMode").disabled = false;
              if(p2Wrap) p2Wrap.style.display = (dm === "WAITING") ? "none" : "block";
            }
          }

          function applyPlayerTypeUI(pn){
            const type = $id(`p${pn}Type`)?.value || "USER";
            const userBlock = $id(`p${pn}UserBlock`);
            const guestBlock = $id(`p${pn}GuestBlock`);
            const info = $id(`p${pn}UserInfo`);

            if(type === "USER"){
              if(userBlock) userBlock.style.display = "block";
              if(guestBlock) guestBlock.style.display = "none";
              if(info) info.textContent = "Chưa check";
              setAvatarBox(`p${pn}AvatarBox`, null);

              const gn = $id(`p${pn}GuestName`); if(gn) gn.value = "";
              const gl = $id(`p${pn}GuestLevel`); if(gl) gl.value = "2.50";
              const gf = $id(`p${pn}GuestAvatarFile`); if(gf) gf.value = "";
            } else {
              if(userBlock) userBlock.style.display = "none";
              if(guestBlock) guestBlock.style.display = "block";
              setAvatarBox(`p${pn}AvatarBox`, null);

              const ui = $id(`p${pn}UserId`); if(ui) ui.value = "";
              if(info) info.textContent = "Guest mode";
            }
          }

          async function checkUser(pn){
            const idRaw = ($id(`p${pn}UserId`)?.value || "").trim();
            const id = Number(idRaw);
            if(!id || id <= 0) return showCreateErr(`VDV ${pn}: nhập UserId hợp lệ.`);

            try{
              // route đúng của bạn: /api/admin/users/find/{id}
              const res = await axios.get(`/api/admin/users/find/${id}`);
              const u = res.data;

              // u: { userId, fullName, avatarUrl, ratingSingle, ratingDouble }
              const single = Number(u.ratingSingle || 0);
              const dbl = Number(u.ratingDouble || 0);

              // lấy level theo gameType giải (DOUBLE => ratingDouble, SINGLE => ratingSingle)
              const pickedLevel = (TOURNAMENT_GAME_TYPE === "DOUBLE") ? dbl : single;

              const info = $id(`p${pn}UserInfo`);
              if(info){
                info.textContent =
                  `${u.fullName} • Single: ${single.toFixed(2)} • Double: ${dbl.toFixed(2)} • Pick: ${pickedLevel.toFixed(2)} • UserId: ${u.userId}`;
              }
              setAvatarBox(`p${pn}AvatarBox`, u.avatarUrl || null);
            } catch(err){
              const msg = err?.response?.data?.message || err?.message || "Check user failed.";
              showCreateErr(`VDV ${pn}: ${msg}`);
            }
          }

          function previewGuestAvatar(pn){
            const input = $id(`p${pn}GuestAvatarFile`);
            const f = input?.files?.[0];
            if(!f){ setAvatarBox(`p${pn}AvatarBox`, null); return; }
            const url = URL.createObjectURL(f);
            setAvatarBox(`p${pn}AvatarBox`, url);
          }

          function buildFormData(){
            const fd = new FormData();

            const gt = $id("gameType")?.value || "DOUBLE";
            let dm = $id("doubleMode")?.value || "PAIR";

            if(gt === "SINGLE") dm = "PAIR";
            const waitingPair = (gt === "DOUBLE" && dm === "WAITING");

            fd.append("gameType", gt);
            fd.append("waitingPair", String(waitingPair));
            fd.append("paid", String(($id("paid")?.value || "false") === "true"));
            fd.append("btCode", $id("btCode")?.value || "");

            // Player1
            const p1Type = $id("p1Type")?.value || "USER";
            if(p1Type === "USER"){
              const id = ($id("p1UserId")?.value || "").trim();
              if(!id) throw new Error("VDV1: chưa nhập UserId.");
              fd.append("player1UserId", id);
            } else {
              const name = ($id("p1GuestName")?.value || "").trim();
              const level = ($id("p1GuestLevel")?.value || "").trim();
              if(!name) throw new Error("VDV1 (guest): thiếu Name.");
              if(!level) throw new Error("VDV1 (guest): thiếu Level.");
              fd.append("player1Name", name);
              fd.append("player1Level", level);

              const f = $id("p1GuestAvatarFile")?.files?.[0];
              if(f) fd.append("player1AvatarFile", f);
            }

            // Player2 only if DOUBLE and not waiting
            if(gt === "DOUBLE" && !waitingPair){
              const p2Type = $id("p2Type")?.value || "USER";
              if(p2Type === "USER"){
                const id = ($id("p2UserId")?.value || "").trim();
                if(!id) throw new Error("VDV2: chưa nhập UserId.");
                fd.append("player2UserId", id);
              } else {
                const name = ($id("p2GuestName")?.value || "").trim();
                const level = ($id("p2GuestLevel")?.value || "").trim();
                if(!name) throw new Error("VDV2 (guest): thiếu Name.");
                if(!level) throw new Error("VDV2 (guest): thiếu Level.");
                fd.append("player2Name", name);
                fd.append("player2Level", level);

                const f = $id("p2GuestAvatarFile")?.files?.[0];
                if(f) fd.append("player2AvatarFile", f);
              }
            }

            return fd;
          }

          // Wire events
          document.addEventListener("DOMContentLoaded", async () => {
            if(!TOURNAMENT_ID){
              console.error("TOURNAMENT_ID missing. Check ViewBag.TournamentId.");
              return;
            }

            on("tabSuccess","click", () => load("SUCCESS"));
            on("tabWaiting","click", () => load("WAITING"));
            on("tabCapacity","click", () => alert("Còn chỗ = ExpectedTeams - SuccessCount (team)."));

            on("btnSearch","click", () => {
              const key = ($id("q")?.value || "").trim().toLowerCase();
              const body = $id("body");
              if(!body) return;

              const filtered = (CACHE.items || []).filter(x =>
                (x.player1Name||"").toLowerCase().includes(key) ||
                (x.player2Name||"").toLowerCase().includes(key) ||
                (x.regCode||"").toLowerCase().includes(key)
              );

              body.innerHTML = filtered.length
                ? filtered.map(rowHtml).join("")
                : `<tr><td colspan="9" class="text-center text-muted">No results</td></tr>`;
            });

            on("btnOpenCreate","click", () => {
              clearCreateErr();
              $id("formCreate")?.reset();

              if($id("p1Type")) $id("p1Type").value = "USER";
              if($id("p2Type")) $id("p2Type").value = "USER";
              applyPlayerTypeUI(1);
              applyPlayerTypeUI(2);

              setAvatarBox("p1AvatarBox", null);
              setAvatarBox("p2AvatarBox", null);

              if($id("doubleMode")) $id("doubleMode").value = "PAIR";
              applyModeUI();

              $("#modalCreate").modal("show");
            });

            on("gameType","change", applyModeUI);
            on("doubleMode","change", applyModeUI);

            on("p1Type","change", () => applyPlayerTypeUI(1));
            on("p2Type","change", () => applyPlayerTypeUI(2));

            on("btnP1Check","click", () => checkUser(1));
            on("btnP2Check","click", () => checkUser(2));

            on("p1GuestAvatarFile","change", () => previewGuestAvatar(1));
            on("p2GuestAvatarFile","change", () => previewGuestAvatar(2));

            on("formPair","submit", async (e) => {
              e.preventDefault();
              const baseId = Number($id("pairBaseId")?.value || 0);
              const withId = Number($id("pairWith")?.value || 0);
              try{
                await axios.post(`/api/admin/registrations/${baseId}/pair`, { withWaitingRegistrationId: withId });
                $("#modalPair").modal("hide");
                await load(CURRENT_TAB);
              } catch(err){
                const msg = err?.response?.data?.message || err?.message || "Pair failed.";
                const box = $id("pairErr");
                if(box){
                  box.textContent = msg;
                  box.classList.remove("d-none");
                }
              }
            });

                   on("formCreate","submit", async (e) => {
          e.preventDefault();
          clearCreateErr();

          const btn = $id("btnCreateSubmit");
          if(btn){
            btn.disabled = true;
            btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Saving...`;
          }

          try{
            const fd = buildFormData();

            await axios.post(`/api/admin/tournaments/${TOURNAMENT_ID}/registrations`, fd, {
              // axios tự set boundary khi gửi FormData, KHÔNG cần set Content-Type
              // headers: { "Content-Type": "multipart/form-data" }
            });

            // đóng modal cho đẹp (optional)
            $("#modalCreate").modal("hide");

            // refresh trang luôn
            window.location.reload();

          } catch(err){
            const msg = err?.response?.data?.message || err?.message || "Create failed.";
            showCreateErr(msg);
          } finally {
            if(btn){
              btn.disabled = false;
              btn.innerHTML = `<i class="fas fa-save"></i> Create`;
            }
          }
        });

            await load("SUCCESS");
          });
        })();
    </script>
}