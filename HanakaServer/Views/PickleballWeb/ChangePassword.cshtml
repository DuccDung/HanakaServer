@model HanakaServer.ViewModels.PickleballWeb.PickleballWebAuthPageViewModel
@{
    Layout = "_PickleballWebLayout";
    ViewData["Title"] = $"{Model.Title} | Hanaka Sport";
    ViewData["Description"] = "Màn đổi mật khẩu Hanaka Sport trên mobile web, đồng bộ theo profile hiện tại của người dùng.";
}

@section Styles {
    <link href="~/pickleball-web/css/account.css" asp-append-version="true" rel="stylesheet" />
}

<div class="account-screen account-screen--password" data-account-page="change-password">
    <header class="account-header">
        <div class="container mobile-web-screen__container">
            <div class="account-header__bar">
                <a class="account-header__back"
                   href="@Model.BackHref"
                   aria-label="@Model.BackLabel"
                   onclick="if (window.history.length > 1) { window.history.back(); return false; }">
                    <ion-icon name="arrow-back"></ion-icon>
                </a>

                <h1>@Model.Title</h1>

                <span class="account-header__spacer" aria-hidden="true"></span>
            </div>
        </div>
    </header>

    <main class="change-password-body">
        <div class="container mobile-web-screen__container">
            <section class="change-password-profile">
                <div class="change-password-profile__avatar" data-change-avatar hidden>
                    <img src="" alt="Ảnh đại diện tài khoản" data-change-avatar-image />
                </div>

                <div class="change-password-profile__avatar-fallback" data-change-avatar-fallback>
                    <ion-icon name="person-circle-outline"></ion-icon>
                </div>

                <div class="change-password-profile__copy">
                    <strong data-change-profile-name>Đang tải tài khoản</strong>
                    <span data-change-profile-email>Vui lòng chờ đồng bộ dữ liệu</span>
                </div>
            </section>

            <section class="change-password-card">
                <label class="account-label" for="account-current-password">
                    Mật khẩu hiện tại <span>*</span>
                </label>
                <div class="change-password-input">
                    <input id="account-current-password"
                           type="password"
                           placeholder="Nhập mật khẩu hiện tại"
                           autocomplete="current-password"
                           data-change-current-password />
                    <button type="button" data-change-toggle-password="current" aria-label="Hiện mật khẩu hiện tại">
                        <ion-icon name="eye-outline"></ion-icon>
                    </button>
                </div>

                <label class="account-label account-label--spacing" for="account-new-password">
                    Mật khẩu mới <span>*</span>
                </label>
                <div class="change-password-input">
                    <input id="account-new-password"
                           type="password"
                           placeholder="Nhập mật khẩu mới"
                           autocomplete="new-password"
                           data-change-new-password />
                    <button type="button" data-change-toggle-password="new" aria-label="Hiện mật khẩu mới">
                        <ion-icon name="eye-outline"></ion-icon>
                    </button>
                </div>

                <div class="change-password-rule">
                    <p>Mật khẩu cần thỏa mãn:</p>
                    <div>
                        <ion-icon name="ellipse-outline" data-change-rule-icon></ion-icon>
                        <span>Tối thiểu 8 ký tự</span>
                    </div>
                </div>

                <label class="account-label account-label--spacing" for="account-confirm-password">
                    Xác nhận mật khẩu <span>*</span>
                </label>
                <div class="change-password-input">
                    <input id="account-confirm-password"
                           type="password"
                           placeholder="Nhập xác nhận mật khẩu"
                           autocomplete="new-password"
                           data-change-confirm-password />
                    <button type="button" data-change-toggle-password="confirm" aria-label="Hiện xác nhận mật khẩu">
                        <ion-icon name="eye-outline"></ion-icon>
                    </button>
                </div>

                <div class="account-inline-error" data-change-error hidden>
                    <p data-change-error-text></p>
                </div>

                <button class="change-password-submit" type="button" data-change-submit disabled>
                    <span data-change-submit-text>Thay đổi</span>
                </button>
            </section>
        </div>
    </main>
</div>

@section Scripts {
    <script src="~/pickleball-web/js/account.js" asp-append-version="true"></script>
}
