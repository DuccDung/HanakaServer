@model HanakaServer.ViewModels.PickleballWeb.PickleballWebPageViewModel
@{
    Layout = "_PickleballWebLayout";
    ViewData["Title"] = $"{Model.Title} | Hanaka Sport";
    ViewData["Description"] = Model.Description;
}

<div class="native-page-screen native-page-screen--@Model.PageKind" data-native-page-kind="@Model.PageKind">
    <header class="native-page-header">
        <div class="container mobile-web-screen__container">
            <div class="native-page-header__top">
                <a class="native-page-header__back"
                   href="@Model.BackHref"
                   aria-label="@Model.BackLabel"
                   onclick="if (window.history.length > 1) { window.history.back(); return false; }">
                    <ion-icon name="arrow-back"></ion-icon>
                </a>

                <h1 class="native-page-header__title">@Model.Title</h1>

                <button class="native-page-header__action" type="button" data-native-page-action hidden></button>
                <span class="native-page-header__spacer" data-native-page-spacer aria-hidden="true"></span>
            </div>

            <div class="native-page-header__extra" data-native-page-header-extra></div>
        </div>
    </header>

    <main class="native-page-main">
        <div class="container mobile-web-screen__container">
            <div class="native-page-error" data-native-page-error hidden>
                <p data-native-page-error-text></p>
                <button type="button" data-native-page-retry hidden>Thử lại</button>
            </div>

            <div class="native-page-loading" data-native-page-loading>
                <span class="members-app-spinner" aria-hidden="true"></span>
            </div>

            <div class="native-page-list" data-native-page-list></div>

            <div class="native-page-empty" data-native-page-empty hidden>
                <p data-native-page-empty-text>Chưa có dữ liệu phù hợp.</p>
            </div>

            <div class="native-page-loading native-page-loading--more" data-native-page-loading-more hidden>
                <span class="members-app-spinner" aria-hidden="true"></span>
            </div>

            <div class="native-page-sentinel" data-native-page-sentinel aria-hidden="true"></div>
        </div>
    </main>

    <nav class="mobile-tabbar mobile-tabbar--page" aria-label="Điều hướng app mobile">
        <a class="mobile-tabbar__item @(Model.ActiveTab == "home" ? "is-active" : string.Empty)" href="/">
            <ion-icon name="home"></ion-icon>
            <span>Trang Chủ</span>
        </a>
        <a class="mobile-tabbar__item @(Model.ActiveTab == "tournaments" ? "is-active" : string.Empty)" href="/PickleballWeb/Tournaments">
            <ion-icon name="trophy-outline"></ion-icon>
            <span>Giải Đấu</span>
        </a>
        <a class="mobile-tabbar__item @(Model.ActiveTab == "courts" ? "is-active" : string.Empty)" href="/PickleballWeb/Courts">
            <ion-icon name="location-outline"></ion-icon>
            <span>Sân Bãi</span>
        </a>
    </nav>
</div>
