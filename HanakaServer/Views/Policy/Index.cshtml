<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chính sách quyền riêng tư</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="~/css/policy.css" asp-append-version=true rel="stylesheet" />
    
</head>

<body>
    <!-- Hero -->
    <section class="hero-section">
        <div class="container">
            <div class="card hero-card shadow-lg">
                <div class="card-body">
                    <div class="mb-3">
                        <span class="badge-soft">
                            <i class="bi bi-shield-lock me-2"></i>Privacy Policy
                        </span>
                    </div>

                    <h1 class="display-5 fw-bold mb-3">Chính sách quyền riêng tư</h1>

                    <p class="lead mb-4 text-white-50">
                        Chính sách này giải thích cách hệ thống của chúng tôi thu thập, sử dụng
                        và bảo vệ thông tin khi bạn đăng nhập bằng Google và thiết lập hồ sơ
                        người dùng bao gồm họ tên, số điện thoại và địa chỉ Gmail.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge-soft">Đăng nhập: Google Sign-In</span>
                        <span class="badge-soft">Dữ liệu hồ sơ: Họ tên, số điện thoại, Gmail</span>
                        <span class="badge-soft" id="updatedAt">Cập nhật lần cuối: --/--/----</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main -->
    <main class="pb-5">
        <div class="container">
            <div class="row g-4">
                <!-- Sidebar -->
                <div class="col-lg-4 col-xl-3">
                    <div class="card sidebar-card">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3">Nội dung chính</h5>

                            <nav class="nav flex-column">
                                <a class="toc-link" href="#overview">1. Tổng quan</a>
                                <a class="toc-link" href="#data">2. Dữ liệu chúng tôi thu thập</a>
                                <a class="toc-link" href="#usage">3. Mục đích sử dụng dữ liệu</a>
                                <a class="toc-link" href="#google">4. Đăng nhập bằng Google</a>
                                <a class="toc-link" href="#sharing">5. Chia sẻ dữ liệu</a>
                                <a class="toc-link" href="#storage">6. Lưu trữ và bảo mật</a>
                                <a class="toc-link" href="#rights">7. Quyền của người dùng</a>
                                <a class="toc-link" href="#contact">8. Liên hệ</a>
                            </nav>

                            <div class="mt-4 p-3 rounded-4 border bg-light">
                                <div class="fw-semibold mb-1">Lưu ý</div>
                                <small class="text-secondary">
                                    Chính sách có thể được cập nhật để phù hợp với thay đổi dịch vụ hoặc
                                    yêu cầu pháp lý.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Content -->
                <div class="col-lg-8 col-xl-9">
                    <div class="card content-card">
                        <div class="card-body p-4 p-lg-5">
                            <div class="notice-box p-3 p-lg-4 mb-4">
                                <div class="d-flex align-items-start">
                                    <i class="bi bi-info-circle-fill me-3 fs-5"></i>
                                    <div>
                                        Chúng tôi cam kết chỉ thu thập và xử lý thông tin cần thiết để
                                        phục vụ việc đăng nhập, quản lý tài khoản và hỗ trợ người dùng.
                                    </div>
                                </div>
                            </div>

                            <section class="section-block" id="overview">
                                <h2 class="section-title">1. Tổng quan</h2>
                                <p>
                                    Chúng tôi cam kết tôn trọng quyền riêng tư của người dùng. Chính
                                    sách này mô tả cách chúng tôi thu thập, sử dụng, lưu trữ và bảo vệ
                                    dữ liệu cá nhân khi bạn sử dụng website hoặc ứng dụng của chúng tôi.
                                </p>
                                <p class="mb-0">
                                    Bằng việc sử dụng dịch vụ, bạn đồng ý với các nội dung được nêu
                                    trong Chính sách quyền riêng tư này.
                                </p>
                            </section>

                            <section class="section-block" id="data">
                                <h2 class="section-title">2. Dữ liệu chúng tôi thu thập</h2>
                                <p>
                                    Khi bạn sử dụng hệ thống, chúng tôi có thể thu thập các thông tin
                                    sau:
                                </p>

                                <div class="row g-3 mt-1">
                                    <div class="col-md-6">
                                        <div class="info-box p-4">
                                            <h5 class="fw-bold">Thông tin đăng nhập</h5>
                                            <p class="text-secondary mb-0">
                                                Địa chỉ Gmail, tên hiển thị và thông tin cơ bản được cung cấp
                                                từ tài khoản Google khi bạn đăng nhập.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-box p-4">
                                            <h5 class="fw-bold">Thông tin hồ sơ</h5>
                                            <p class="text-secondary mb-0">
                                                Họ tên, số điện thoại và email mà bạn cung cấp hoặc cập nhật
                                                trong phần thiết lập thông tin người dùng.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <p class="mt-3 mb-0">
                                    Chúng tôi không chủ động yêu cầu các dữ liệu nhạy cảm ngoài phạm vi
                                    cần thiết để cung cấp dịch vụ, trừ khi được thông báo riêng.
                                </p>
                            </section>

                            <section class="section-block" id="usage">
                                <h2 class="section-title">3. Mục đích sử dụng dữ liệu</h2>
                                <ul class="mb-0">
                                    <li>Xác thực tài khoản và cho phép bạn đăng nhập an toàn bằng Google.</li>
                                    <li>Tạo và quản lý hồ sơ người dùng trong hệ thống.</li>
                                    <li>
                                        Liên hệ với bạn khi cần hỗ trợ, xác minh hoặc gửi thông báo liên
                                        quan đến tài khoản.
                                    </li>
                                    <li>
                                        Cải thiện trải nghiệm sử dụng, bảo mật hệ thống và xử lý lỗi kỹ
                                        thuật.
                                    </li>
                                </ul>
                            </section>

                            <section class="section-block" id="google">
                                <h2 class="section-title">4. Đăng nhập bằng Google</h2>
                                <p>
                                    Hệ thống của chúng tôi sử dụng Google Sign-In để xác thực người
                                    dùng. Khi bạn chọn đăng nhập bằng Google, chúng tôi có thể nhận được
                                    một số thông tin từ tài khoản Google của bạn theo phạm vi quyền mà
                                    bạn đã đồng ý cấp.
                                </p>
                                <p class="mb-0">
                                    Chúng tôi chỉ sử dụng dữ liệu đó cho mục đích đăng nhập, nhận diện
                                    tài khoản và quản lý hồ sơ người dùng trong hệ thống. Chúng tôi
                                    không đăng bài, gửi email hoặc truy cập dữ liệu khác trong tài khoản
                                    Google của bạn nếu không có sự cho phép rõ ràng.
                                </p>
                            </section>

                            <section class="section-block" id="sharing">
                                <h2 class="section-title">5. Chia sẻ dữ liệu</h2>
                                <p>
                                    Chúng tôi không bán hoặc cho thuê thông tin cá nhân của bạn cho bên
                                    thứ ba.
                                </p>
                                <p>Dữ liệu của bạn chỉ có thể được chia sẻ trong các trường hợp cần thiết sau:</p>
                                <ul class="mb-0">
                                    <li>
                                        Với nhà cung cấp dịch vụ hạ tầng hoặc công nghệ phục vụ vận hành hệ thống.
                                    </li>
                                    <li>Khi có yêu cầu hợp pháp từ cơ quan nhà nước có thẩm quyền.</li>
                                    <li>
                                        Khi cần bảo vệ quyền lợi hợp pháp, an toàn hoặc tính toàn vẹn của
                                        hệ thống và người dùng.
                                    </li>
                                </ul>
                            </section>

                            <section class="section-block" id="storage">
                                <h2 class="section-title">6. Lưu trữ và bảo mật</h2>
                                <p>
                                    Chúng tôi áp dụng các biện pháp kỹ thuật và tổ chức hợp lý để bảo vệ
                                    thông tin người dùng khỏi truy cập trái phép, mất mát, lạm dụng hoặc
                                    tiết lộ không phù hợp.
                                </p>
                                <p class="mb-0">
                                    Dữ liệu được lưu trữ trong thời gian cần thiết để cung cấp dịch vụ,
                                    tuân thủ nghĩa vụ pháp lý hoặc giải quyết tranh chấp nếu có.
                                </p>
                            </section>

                            <section class="section-block" id="rights">
                                <h2 class="section-title">7. Quyền của người dùng</h2>
                                <p>Bạn có thể yêu cầu:</p>
                                <ul class="mb-0">
                                    <li>Truy cập và xem lại thông tin cá nhân của mình.</li>
                                    <li>Chỉnh sửa hoặc cập nhật dữ liệu không chính xác.</li>
                                    <li>
                                        Yêu cầu xóa tài khoản hoặc thông tin cá nhân theo chính sách áp
                                        dụng của hệ thống.
                                    </li>
                                    <li>
                                        Rút lại sự đồng ý đối với một số hoạt động xử lý dữ liệu, trong
                                        phạm vi pháp luật cho phép.
                                    </li>
                                </ul>
                            </section>

                            <section class="section-block" id="contact">
                                <h2 class="section-title">8. Liên hệ</h2>
                                <p>
                                    Nếu bạn có câu hỏi hoặc yêu cầu liên quan đến Chính sách quyền riêng
                                    tư này, vui lòng liên hệ với chúng tôi qua thông tin dưới đây.
                                </p>

                                <div class="contact-box p-4">
                                    <p class="mb-2"><strong>Đơn vị vận hành:</strong> Hanaka Sport</p>
                                    <p class="mb-2">
                                        <strong>Website:</strong>
                                        <a href="https://hanaka.com.vn/"
                                           target="_blank"
                                           rel="noreferrer">
                                            https://hanaka.com.vn/
                                        </a>
                                    </p>
                                    <p class="mb-0">
                                        <strong>Địa chỉ:</strong> Khu công nghiệp Hanaka, Phường Đồng
                                        Nguyên, Tỉnh Bắc Ninh, Việt Nam.
                                    </p>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer py-4">
        <div class="container text-center">
            © <span id="year"></span> Hanaka Sport. All rights reserved.
        </div>
    </footer>

    <script>
        const now = new Date();
        const formatter = new Intl.DateTimeFormat("vi-VN", {
          day: "2-digit",
          month: "2-digit",
          year: "numeric",
        });

        document.getElementById("updatedAt").textContent =
          `Cập nhật lần cuối: ${formatter.format(now)}`;
        document.getElementById("year").textContent = now.getFullYear();

        // Active TOC on scroll
        const sections = document.querySelectorAll(".section-block");
        const navLinks = document.querySelectorAll(".toc-link");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                navLinks.forEach((link) => link.classList.remove("active"));
                const activeLink = document.querySelector(
                  `.toc-link[href="#${entry.target.id}"]`
                );
                if (activeLink) activeLink.classList.add("active");
              }
            });
          },
          {
            rootMargin: "-20% 0px -60% 0px",
            threshold: 0.1,
          }
        );

        sections.forEach((section) => observer.observe(section));
    </script>
</body>
</html>