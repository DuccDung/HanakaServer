@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Links";
}

<div class="container-fluid" id="pageRoot">
    <div class="d-sm-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Links</h1>
            <div class="small text-muted">Quản lý link cho app</div>
        </div>

        <div class="d-flex" style="gap:8px">
            <button class="btn btn-sm btn-primary shadow-sm" type="button" id="btnOpenCreate">
                <i class="fas fa-plus fa-sm text-white-50"></i> Add Link
            </button>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">List</h6>

            <div class="d-flex" style="gap:8px; align-items:center;">
                <input id="q" class="form-control form-control-sm" style="width: 220px;" placeholder="Tìm link / type ..." />
                <button class="btn btn-sm btn-outline-primary" type="button" id="btnSearch">Search</button>
                <button class="btn btn-sm btn-outline-secondary" type="button" id="btnReload">Reload</button>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width:90px">ID</th>
                            <th>Link</th>
                            <th style="width:180px">Type</th>
                            <th style="width:160px">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="body">
                        <tr><td colspan="4" class="text-center text-muted">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="formCreate">
                <div class="modal-header">
                    <h5 class="modal-title">Add Link</h5>
                    <button class="close" type="button" data-dismiss="modal"><span aria-hidden="true">×</span></button>
                </div>

                <div class="modal-body">
                    <div id="createErr" class="alert alert-danger d-none"></div>

                    <div class="form-group">
                        <label>Link</label>
                        <input class="form-control" id="createLink" placeholder="https://example.com/..." />
                    </div>

                    <div class="form-group mb-0">
                        <label>Type</label>
                        <input class="form-control" id="createType" placeholder="guide / contact / support" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit" id="btnCreateSubmit">
                        <i class="fas fa-save"></i> Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="modalEdit" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="formEdit">
                <input type="hidden" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Link</h5>
                    <button class="close" type="button" data-dismiss="modal"><span aria-hidden="true">×</span></button>
                </div>

                <div class="modal-body">
                    <div id="editErr" class="alert alert-danger d-none"></div>

                    <div class="form-group">
                        <label>Link</label>
                        <input class="form-control" id="editLink" placeholder="https://example.com/..." />
                    </div>

                    <div class="form-group mb-0">
                        <label>Type</label>
                        <input class="form-control" id="editType" placeholder="guide / contact / support" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit" id="btnEditSubmit">
                        <i class="fas fa-save"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        (() => {
            const $id = (id) => document.getElementById(id);
            const on = (id, evt, handler) => {
                const el = $id(id);
                if (el) el.addEventListener(evt, handler);
            };

            const API = "/api/admin/links";
            let CACHE = [];

            const esc = (s) => String(s || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;");

            function showCreateErr(msg) {
                const box = $id("createErr");
                if (!box) return;
                box.textContent = msg || "Error";
                box.classList.remove("d-none");
            }

            function clearCreateErr() {
                const box = $id("createErr");
                if (!box) return;
                box.textContent = "";
                box.classList.add("d-none");
            }

            function showEditErr(msg) {
                const box = $id("editErr");
                if (!box) return;
                box.textContent = msg || "Error";
                box.classList.remove("d-none");
            }

            function clearEditErr() {
                const box = $id("editErr");
                if (!box) return;
                box.textContent = "";
                box.classList.add("d-none");
            }

            function rowHtml(item) {
                return `
                    <tr>
                        <td>${item.linkId}</td>
                        <td>
                            <a href="${esc(item.link)}" target="_blank">${esc(item.link)}</a>
                        </td>
                        <td>
                            <span class="badge badge-info">${esc(item.type)}</span>
                        </td>
                        <td>
                            <div class="d-flex" style="gap:6px">
                                <button class="btn btn-sm btn-outline-primary" type="button" onclick="openEdit(${item.linkId})">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" type="button" onclick="deleteItem(${item.linkId})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }

            async function load() {
                const body = $id("body");
                if (body) {
                    body.innerHTML = `<tr><td colspan="4" class="text-center text-muted">Loading...</td></tr>`;
                }

                const res = await axios.get(API);
                CACHE = res.data.items || [];

                renderRows(CACHE);
            }

            function renderRows(items) {
                const body = $id("body");
                if (!body) return;

                if (!items.length) {
                    body.innerHTML = `<tr><td colspan="4" class="text-center text-muted">No links</td></tr>`;
                    return;
                }

                body.innerHTML = items.map(rowHtml).join("");
            }

            async function openEdit(id) {
                clearEditErr();

                try {
                    const res = await axios.get(`${API}/${id}`);
                    const item = res.data;

                    $id("editId").value = item.linkId;
                    $id("editLink").value = item.link || "";
                    $id("editType").value = item.type || "";

                    $("#modalEdit").modal("show");
                } catch (err) {
                    alert(err?.response?.data?.message || err?.message || "Load detail failed.");
                }
            }

            async function deleteItem(id) {
                if (!confirm("Xóa link này?")) return;

                try {
                    await axios.delete(`${API}/${id}`);
                    await load();
                } catch (err) {
                    alert(err?.response?.data?.message || err?.message || "Delete failed.");
                }
            }

            window.openEdit = openEdit;
            window.deleteItem = deleteItem;

            document.addEventListener("DOMContentLoaded", async () => {
                on("btnReload", "click", load);

                on("btnSearch", "click", () => {
                    const key = ($id("q")?.value || "").trim().toLowerCase();

                    const filtered = CACHE.filter(x =>
                        (x.link || "").toLowerCase().includes(key) ||
                        (x.type || "").toLowerCase().includes(key)
                    );

                    renderRows(filtered);
                });

                on("btnOpenCreate", "click", () => {
                    clearCreateErr();
                    $id("formCreate")?.reset();
                    $("#modalCreate").modal("show");
                });

                on("formCreate", "submit", async (e) => {
                    e.preventDefault();
                    clearCreateErr();

                    const btn = $id("btnCreateSubmit");
                    if (btn) {
                        btn.disabled = true;
                        btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Saving...`;
                    }

                    try {
                        await axios.post(API, {
                            link: $id("createLink")?.value || "",
                            type: $id("createType")?.value || ""
                        });

                        $("#modalCreate").modal("hide");
                        await load();
                    } catch (err) {
                        showCreateErr(err?.response?.data?.message || err?.message || "Create failed.");
                    } finally {
                        if (btn) {
                            btn.disabled = false;
                            btn.innerHTML = `<i class="fas fa-save"></i> Create`;
                        }
                    }
                });

                on("formEdit", "submit", async (e) => {
                    e.preventDefault();
                    clearEditErr();

                    const id = Number($id("editId")?.value || 0);
                    const btn = $id("btnEditSubmit");

                    if (btn) {
                        btn.disabled = true;
                        btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Saving...`;
                    }

                    try {
                        await axios.put(`${API}/${id}`, {
                            link: $id("editLink")?.value || "",
                            type: $id("editType")?.value || ""
                        });

                        $("#modalEdit").modal("hide");
                        await load();
                    } catch (err) {
                        showEditErr(err?.response?.data?.message || err?.message || "Update failed.");
                    } finally {
                        if (btn) {
                            btn.disabled = false;
                            btn.innerHTML = `<i class="fas fa-save"></i> Save`;
                        }
                    }
                });

                await load();
            });
        })();
    </script>
}