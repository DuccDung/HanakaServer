@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trận đấu";
    var groupId = (long)(ViewBag.GroupId ?? 0L);
    var tournamentId = (long)(ViewBag.TournamentId ?? 0L);
}

<style>
    .match-card {
        border: 1px solid #eee;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0,0,0,.03);
    }

        .match-card.completed {
            background: #28a745;
            border-color: #28a745;
            color: #fff;
        }

    .team-name {
        font-weight: 700;
        font-size: 15px;
    }

    .team-code {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .4px;
        opacity: .8;
    }

    .team-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        max-width: 38%;
    }

        .team-name.winner {
            color: #ffc107;
        }

    .score {
        font-weight: 800;
        font-size: 18px;
        letter-spacing: .5px;
    }

    .meta {
        font-size: 12px;
        opacity: .95;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .video-link-light a {
        color: #fff !important;
        text-decoration: underline;
    }

    .referee-box {
        border: 1px dashed #ced4da;
        border-radius: 8px;
        padding: 10px 12px;
        background: #fafafa;
    }

    .match-team-selector {
        border: 1px solid #e3e6f0;
        border-radius: 12px;
        padding: 12px;
        background: #fafbff;
        height: 100%;
    }

    .team-select-summary {
        min-height: 122px;
        border: 1px dashed #ced4da;
        border-radius: 10px;
        padding: 12px;
        background: #fff;
    }

        .team-select-summary.empty {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
        }

    .team-select-code {
        font-size: 12px;
        font-weight: 700;
        color: #4e73df;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 6px;
    }

    .team-select-name {
        font-size: 15px;
        font-weight: 700;
        color: #2e3a59;
        margin-bottom: 6px;
    }

    .team-select-meta {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .team-search-note {
        font-size: 11px;
    }

    .team-picker-overlay {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 1080;
    }

        .team-picker-overlay.active {
            display: block;
        }

    .team-picker-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, .25);
    }

    .team-picker-drawer {
        position: absolute;
        top: 0;
        right: 0;
        width: min(560px, 100%);
        height: 100%;
        background: #fff;
        box-shadow: -10px 0 30px rgba(0, 0, 0, .15);
        transform: translateX(100%);
        transition: transform .2s ease;
        display: flex;
        flex-direction: column;
    }

    .team-picker-overlay.active .team-picker-drawer {
        transform: translateX(0);
    }

    .team-picker-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 18px;
        border-bottom: 1px solid #e9ecef;
    }

    .team-picker-body {
        padding: 16px 18px;
        overflow-y: auto;
    }

    .team-picker-list {
        display: grid;
        gap: 12px;
    }

    .team-picker-card {
        border: 1px solid #e3e6f0;
        border-radius: 12px;
        padding: 12px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0, 0, 0, .03);
    }

        .team-picker-card.is-selected {
            border-color: #4e73df;
            box-shadow: 0 0 0 2px rgba(78, 115, 223, .12);
        }

        .team-picker-card.is-disabled {
            opacity: .7;
        }

    .team-picker-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 8px;
    }

    .team-picker-card-code {
        font-size: 12px;
        font-weight: 700;
        color: #4e73df;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 4px;
    }

    .team-picker-card-name {
        font-size: 15px;
        font-weight: 700;
        color: #2e3a59;
    }

    .team-picker-player,
    .team-picker-card-meta {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .team-picker-empty {
        border: 1px dashed #ced4da;
        border-radius: 12px;
        padding: 18px;
        text-align: center;
        color: #6c757d;
        background: #fafafa;
    }

    @@media (max-width: 992px) {
        .grid {
            grid-template-columns: 1fr;
        }

        .team-picker-drawer {
            width: 100%;
        }
    }
</style>

<div class="container-fluid" id="pageRoot"
     data-group-id="@groupId"
     data-tournament-id="@tournamentId">

    <div class="d-sm-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Trận đấu</h1>
            <div class="small text-muted">
                @ViewBag.TournamentTitle • @ViewBag.TournamentStatus • Loại game: @ViewBag.TournamentGameType
            </div>
            <div class="small text-muted">
                Vòng: <b>@ViewBag.RoundKey</b> • @ViewBag.RoundLabel • Bảng: <b>@ViewBag.GroupName</b> • Mã bảng: #@groupId
            </div>
        </div>

        <div class="d-flex" style="gap:8px">
            <button class="btn btn-sm btn-primary shadow-sm" type="button" id="btnOpenCreate">
                <i class="fas fa-plus fa-sm text-white-50"></i> Tạo trận đấu
            </button>

            <button class="btn btn-sm btn-outline-success" type="button" id="btnFilterCompleted">
                <i class="fas fa-filter"></i> Người thắng
            </button>

            <a class="btn btn-sm btn-outline-secondary" href="/TournamentRoundGroups/Index?roundMapId=@ViewBag.RoundMapId">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div id="errBox" class="alert alert-danger d-none"></div>

    <div id="cards" class="grid">
        <div class="text-muted">Đang tải...</div>
    </div>
</div>

<!-- Modal Tạo/Sửa trận đấu -->
<div class="modal fade" id="modalMatch" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form id="formMatch">
                <input type="hidden" id="mode" value="create" />
                <input type="hidden" id="editingId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Tạo trận đấu</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="formErr" class="alert alert-danger d-none"></div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Đội 1 (Đăng ký)</label>
                            <div class="match-team-selector">
                                <div class="input-group mb-2">
                                    <input class="form-control"
                                           id="team1CodeSearch"
                                           placeholder="Nhập mã đăng ký, ví dụ: 3-0001"
                                           autocomplete="off" />
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-info" type="button" id="btnFindTeam1">
                                            <i class="fas fa-search"></i> Tìm
                                        </button>
                                        <button class="btn btn-outline-primary" type="button" id="btnBrowseTeam1">
                                            <i class="fas fa-list"></i> Danh sách
                                        </button>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted team-search-note">Có thể nhập mã đăng ký hoặc tên đội để tìm nhanh.</small>
                                    <button class="btn btn-link btn-sm p-0" type="button" id="btnClearTeam1">Bỏ chọn</button>
                                </div>
                                <div class="team-select-summary empty" id="team1Summary">Chưa chọn đội 1.</div>
                                <select class="form-control d-none" id="team1"></select>
                            </div>
                        </div>
                        <div class="form-group col-md-6">
                            <label>Đội 2 (Đăng ký)</label>
                            <div class="match-team-selector">
                                <div class="input-group mb-2">
                                    <input class="form-control"
                                           id="team2CodeSearch"
                                           placeholder="Nhập mã đăng ký, ví dụ: 3-0002"
                                           autocomplete="off" />
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-info" type="button" id="btnFindTeam2">
                                            <i class="fas fa-search"></i> Tìm
                                        </button>
                                        <button class="btn btn-outline-primary" type="button" id="btnBrowseTeam2">
                                            <i class="fas fa-list"></i> Danh sách
                                        </button>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted team-search-note">Có thể nhập mã đăng ký hoặc tên đội để tìm nhanh.</small>
                                    <button class="btn btn-link btn-sm p-0" type="button" id="btnClearTeam2">Bỏ chọn</button>
                                </div>
                                <div class="team-select-summary empty" id="team2Summary">Chưa chọn đội 2.</div>
                                <select class="form-control d-none" id="team2"></select>
                            </div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Thời gian bắt đầu</label>
                            <input type="datetime-local" class="form-control" id="startAt" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Sân đấu</label>
                            <input class="form-control" id="courtText" placeholder="Sân 1" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ</label>
                        <input class="form-control" id="addressText" placeholder="Địa chỉ..." />
                    </div>

                    <div class="form-group">
                        <label>Liên kết video</label>
                        <input class="form-control" id="videoUrl" placeholder="https://youtube.com/... hoặc liên kết video khác" />
                        <small class="text-muted">Dán liên kết video trận đấu nếu có.</small>
                    </div>

                    <hr />

                    <div class="form-group mb-2">
                        <label>Gán trọng tài theo UserId <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="refereeUserIdInput" placeholder="Nhập UserId trọng tài hợp lệ" min="1" />
                            <div class="input-group-append">
                                <button class="btn btn-outline-info" type="button" id="btnFindReferee">
                                    <i class="fas fa-search"></i> Tìm
                                </button>
                                <button class="btn btn-outline-secondary" type="button" id="btnClearReferee">
                                    Bỏ chọn
                                </button>
                            </div>
                        </div>
                        <input type="hidden" id="refereeUserId" />
                    </div>

                    <div id="refereeInfo" class="referee-box small text-muted mb-2">
                        Chưa chọn trọng tài.
                    </div>

                    <small class="text-muted">Bắt buộc chọn trọng tài hợp lệ trước khi lưu trận đấu.</small>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Hủy</button>
                    <button class="btn btn-primary" type="submit" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="team-picker-overlay" id="teamPickerOverlay" aria-hidden="true">
    <div class="team-picker-backdrop" id="teamPickerBackdrop"></div>
    <div class="team-picker-drawer">
        <div class="team-picker-header">
            <div>
                <h5 class="mb-1" id="teamPickerTitle">Chọn đội đăng ký</h5>
                <div class="small text-muted" id="teamPickerSubtitle">Danh sách đội đăng ký thành công của giải.</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" id="btnCloseTeamPicker">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="team-picker-body">
            <div class="input-group mb-2">
                <input class="form-control"
                       id="teamPickerSearch"
                       placeholder="Tìm theo mã đăng ký, tên đội hoặc tên người chơi..."
                       autocomplete="off" />
                <div class="input-group-append">
                    <button class="btn btn-outline-info" type="button" id="btnApplyTeamPickerSearch">
                        <i class="fas fa-search"></i> Lọc
                    </button>
                </div>
            </div>

            <div class="small text-muted mb-3" id="teamPickerHint">
                Có thể tìm theo mã đăng ký, tên đội hoặc tên người chơi.
            </div>

            <div class="team-picker-list" id="teamPickerList"></div>
        </div>
    </div>
</div>

<!-- Modal nhập tỷ số -->
<div class="modal fade" id="modalScore" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="formScore">
                <input type="hidden" id="scoreMatchId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title">Nhập tỷ số</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="scoreErr" class="alert alert-danger d-none"></div>

                    <div class="d-flex justify-content-between mb-2">
                        <div class="font-weight-bold" id="scoreTeam1Name">Đội 1</div>
                        <div class="font-weight-bold" id="scoreTeam2Name">Đội 2</div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Tỷ số đội 1</label>
                            <input type="number" class="form-control" id="score1" value="0" min="0" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Tỷ số đội 2</label>
                            <input type="number" class="form-control" id="score2" value="0" min="0" />
                        </div>
                    </div>

                    <div class="form-group mb-0">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="isCompleted" checked />
                            <label class="custom-control-label" for="isCompleted">Kết thúc trận đấu</label>
                        </div>
                    </div>

                    <small class="text-muted">Không hỗ trợ kết quả hòa.</small>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Hủy</button>
                    <button class="btn btn-success" type="submit">
                        <i class="fas fa-check"></i> Áp dụng
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        (() => {
            const $id = (id) => document.getElementById(id);
            const root = $id("pageRoot");

            const GROUP_ID = Number(root?.dataset?.groupId || 0);
            const TOURNAMENT_ID = Number(root?.dataset?.tournamentId || 0);

            const API = `/api/admin/groups/${GROUP_ID}/matches`;
            const API_REGS = `/api/admin/tournaments/${TOURNAMENT_ID}/registrations`;
            const API_FIND_REFEREE = `/api/admin/referees/find-by-user-id`;

            let CACHE = {
                items: [],
                regs: []
            };

            let SHOW_ONLY_COMPLETED = false;
            let TEAM_PICKER_TARGET_SLOT = 1;
            let TEAM_PICKER_KEYWORD = "";

            const esc = (s) => String(s || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const normalizeSearch = (value) => String(value || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .trim();

            const fmt = (dt) => {
                if (!dt) return "—";

                const d = new Date(dt);
                if (isNaN(d.getTime())) return "—";

                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");

                return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
            };

            const toLocalInput = (iso) => {
                if (!iso) return "";

                const d = new Date(iso);
                if (isNaN(d.getTime())) return "";

                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");

                return `${yyyy}-${mm}-${dd}T${hh}:${mi}`;
            };

            const formatDecimal = (value) => {
                const num = Number(value ?? 0);
                return Number.isFinite(num) ? num.toFixed(2) : "0.00";
            };

            function showErr(msg) {
                const box = $id("errBox");
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideErr() {
                const box = $id("errBox");
                box.classList.add("d-none");
                box.textContent = "";
            }

            function showFormErr(msg, boxId) {
                const box = $id(boxId);
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideFormErr(boxId) {
                const box = $id(boxId);
                box.classList.add("d-none");
                box.textContent = "";
            }

            function setRefereeInfo(u) {
                if (!u) {
                    $id("refereeUserId").value = "";
                    $id("refereeInfo").innerHTML = `Chưa chọn trọng tài.`;
                    return;
                }

                $id("refereeUserId").value = String(u.userId);
                $id("refereeInfo").innerHTML = `
                    <div><b>${esc(u.fullName)}</b> (UserId: ${u.userId})</div>
                    <div>${esc(u.phone || "—")} • ${esc(u.email || "—")} • ${esc(u.city || "—")}</div>
                    <div>Hồ sơ trọng tài: ${u.refereeVerified ? "Hợp lệ" : "Chưa xác minh"} • Loại: ${esc(u.refereeType || "REFEREE")} • Hoạt động: ${u.isActive ? "Có" : "Không"}</div>
                `;
            }

            async function findRefereeByUserId() {
                hideFormErr("formErr");

                const userId = Number($id("refereeUserIdInput").value || 0);
                if (!userId) {
                    showFormErr("Vui lòng nhập UserId trọng tài.", "formErr");
                    return;
                }

                try {
                    const res = await axios.get(`${API_FIND_REFEREE}/${userId}`);
                    setRefereeInfo(res.data);
                } catch (err) {
                    setRefereeInfo(null);
                    showFormErr(
                        err?.response?.data?.message || err?.message || "Không tìm thấy trọng tài.",
                        "formErr"
                    );
                }
            }

            function buildTeamText(reg) {
                if (!reg) return "";
                return reg.player2Name
                    ? `${reg.player1Name} & ${reg.player2Name}`
                    : `${reg.player1Name}`;
            }

            function buildPlayerMeta(label, name, pickedLevel, verified, singleLevel, doubleLevel) {
                if (!name) return "";

                return `
                    <div class="team-select-meta">
                        ${esc(label)}: <b>${esc(name)}</b>
                        • Level dùng giải: ${formatDecimal(pickedLevel)}
                        • Single: ${formatDecimal(singleLevel)}
                        • Double: ${formatDecimal(doubleLevel)}
                        • ${verified ? "Đã xác minh" : "Chưa xác minh"}
                    </div>
                `;
            }

            function getRegistrationById(registrationId) {
                return (CACHE.regs || []).find(x => x.registrationId === registrationId) || null;
            }

            function getRegCode(registrationId) {
                const reg = getRegistrationById(registrationId);
                return reg?.regCode || `#${registrationId}`;
            }

            function buildTeamSummaryHtml(reg) {
                if (!reg) return "";

                return `
                    <div class="team-select-code">${esc(reg.regCode || "")}</div>
                    <div class="team-select-name">${esc(buildTeamText(reg))}</div>
                    ${buildPlayerMeta("VĐV 1", reg.player1Name, reg.player1Level, reg.player1Verified, reg.player1LevelSingle, reg.player1LevelDouble)}
                    ${buildPlayerMeta("VĐV 2", reg.player2Name, reg.player2Level, reg.player2Verified, reg.player2LevelSingle, reg.player2LevelDouble)}
                    <div class="team-select-meta">Điểm: <b>${formatDecimal(reg.points)}</b> • Thanh toán: ${reg.paid ? "Đã thanh toán" : "Chưa thanh toán"}</div>
                    <div class="team-select-meta">BT Code: ${esc(reg.btCode || "—")} • Đăng ký: ${fmt(reg.regTime || reg.createdAt)}</div>
                `;
            }

            function setTeamSummary(slot, reg) {
                const box = $id(`team${slot}Summary`);
                if (!box) return;

                if (!reg) {
                    box.classList.add("empty");
                    box.textContent = `Chưa chọn đội ${slot}.`;
                    return;
                }

                box.classList.remove("empty");
                box.innerHTML = buildTeamSummaryHtml(reg);
            }

            function clearTeamSelection(slot) {
                const select = $id(`team${slot}`);
                const search = $id(`team${slot}CodeSearch`);

                if (select) select.value = "";
                if (search) search.value = "";

                setTeamSummary(slot, null);
            }

            function setTeamSelection(slot, registrationId) {
                hideFormErr("formErr");

                const normalizedId = Number(registrationId || 0);
                if (!normalizedId) {
                    clearTeamSelection(slot);
                    return true;
                }

                const otherSlot = slot === 1 ? 2 : 1;
                const otherId = Number($id(`team${otherSlot}`).value || 0);
                if (otherId && otherId === normalizedId) {
                    showFormErr(`Đội này đang được chọn ở Đội ${otherSlot}. Vui lòng chọn đội khác.`, "formErr");
                    return false;
                }

                const reg = getRegistrationById(normalizedId);
                if (!reg) {
                    showFormErr("Không tìm thấy đội đăng ký tương ứng.", "formErr");
                    return false;
                }

                $id(`team${slot}`).value = String(normalizedId);
                $id(`team${slot}CodeSearch`).value = reg.regCode || "";
                setTeamSummary(slot, reg);
                return true;
            }

            function buildRegistrationSearchText(reg) {
                return normalizeSearch([
                    reg?.regCode,
                    buildTeamText(reg),
                    reg?.player1Name,
                    reg?.player2Name,
                    reg?.btCode
                ].filter(Boolean).join(" "));
            }

            function findMatchingRegs(keyword) {
                const normalized = normalizeSearch(keyword);
                const regs = CACHE.regs || [];
                if (!normalized) return regs;

                return regs.filter(reg => buildRegistrationSearchText(reg).includes(normalized));
            }

            function buildPickerCardHtml(reg, slot, otherSlotValue, currentValue) {
                const selected = currentValue === reg.registrationId;
                const disabled = otherSlotValue === reg.registrationId;
                const cardClasses = [
                    "team-picker-card",
                    selected ? "is-selected" : "",
                    disabled ? "is-disabled" : ""
                ].filter(Boolean).join(" ");

                const actionHtml = disabled
                    ? `<button class="btn btn-sm btn-outline-secondary" type="button" disabled>Đang ở Đội ${slot === 1 ? 2 : 1}</button>`
                    : `<button class="btn btn-sm ${selected ? "btn-primary" : "btn-outline-primary"}" type="button" onclick="pickTeam(${reg.registrationId})">
                            ${selected ? "Đã chọn" : "Chọn đội này"}
                       </button>`;

                return `
                    <div class="${cardClasses}">
                        <div class="team-picker-card-header">
                            <div>
                                <div class="team-picker-card-code">${esc(reg.regCode || "")}</div>
                                <div class="team-picker-card-name">${esc(buildTeamText(reg))}</div>
                            </div>
                            ${actionHtml}
                        </div>

                        <div class="team-picker-player">VĐV 1: <b>${esc(reg.player1Name || "—")}</b> • Level giải: ${formatDecimal(reg.player1Level)} • Single: ${formatDecimal(reg.player1LevelSingle)} • Double: ${formatDecimal(reg.player1LevelDouble)}</div>
                        ${reg.player2Name
                            ? `<div class="team-picker-player">VĐV 2: <b>${esc(reg.player2Name)}</b> • Level giải: ${formatDecimal(reg.player2Level)} • Single: ${formatDecimal(reg.player2LevelSingle)} • Double: ${formatDecimal(reg.player2LevelDouble)}</div>`
                            : `<div class="team-picker-player">VĐV 2: <b>Chưa có</b></div>`}
                        <div class="team-picker-card-meta">Điểm: <b>${formatDecimal(reg.points)}</b> • Thanh toán: ${reg.paid ? "Đã thanh toán" : "Chưa thanh toán"} • BT Code: ${esc(reg.btCode || "—")}</div>
                        <div class="team-picker-card-meta">Đăng ký: ${fmt(reg.regTime || reg.createdAt)} • Trạng thái: ${reg.success ? "Hợp lệ" : "Chưa hợp lệ"}</div>
                    </div>
                `;
            }

            function renderTeamPickerList() {
                const box = $id("teamPickerList");
                const slot = TEAM_PICKER_TARGET_SLOT;
                const currentValue = Number($id(`team${slot}`).value || 0);
                const otherSlotValue = Number($id(`team${slot === 1 ? 2 : 1}`).value || 0);
                const items = findMatchingRegs(TEAM_PICKER_KEYWORD);

                if (!items.length) {
                    box.innerHTML = `<div class="team-picker-empty">Không tìm thấy đội nào khớp với từ khóa hiện tại.</div>`;
                    return;
                }

                box.innerHTML = items.map(reg => buildPickerCardHtml(reg, slot, otherSlotValue, currentValue)).join("");
            }

            function openTeamPicker(slot, keyword = "") {
                TEAM_PICKER_TARGET_SLOT = slot;
                TEAM_PICKER_KEYWORD = (keyword || $id(`team${slot}CodeSearch`).value || "").trim();

                $id("teamPickerTitle").textContent = `Chọn đội cho Đội ${slot}`;
                $id("teamPickerSubtitle").textContent = `Danh sách đội đăng ký thành công của giải.`;
                $id("teamPickerSearch").value = TEAM_PICKER_KEYWORD;
                $id("teamPickerHint").textContent = TEAM_PICKER_KEYWORD
                    ? `Đang lọc theo từ khóa: "${TEAM_PICKER_KEYWORD}".`
                    : "Có thể tìm theo mã đăng ký, tên đội hoặc tên người chơi.";

                renderTeamPickerList();

                const overlay = $id("teamPickerOverlay");
                overlay.classList.add("active");
                overlay.setAttribute("aria-hidden", "false");

                setTimeout(() => $id("teamPickerSearch").focus(), 10);
            }

            function closeTeamPicker() {
                const overlay = $id("teamPickerOverlay");
                overlay.classList.remove("active");
                overlay.setAttribute("aria-hidden", "true");
            }

            function findTeamByCode(slot) {
                hideFormErr("formErr");

                const keyword = ($id(`team${slot}CodeSearch`).value || "").trim();
                if (!keyword) {
                    showFormErr(`Vui lòng nhập mã đăng ký hoặc tên đội cho Đội ${slot}.`, "formErr");
                    return;
                }

                const normalized = normalizeSearch(keyword);
                const regs = CACHE.regs || [];
                const exactCodeMatches = regs.filter(reg => normalizeSearch(reg.regCode) === normalized);
                const startsWithCodeMatches = regs.filter(reg => normalizeSearch(reg.regCode).startsWith(normalized));
                const generalMatches = findMatchingRegs(keyword);
                const matches = exactCodeMatches.length
                    ? exactCodeMatches
                    : startsWithCodeMatches.length
                        ? startsWithCodeMatches
                        : generalMatches;

                if (!matches.length) {
                    showFormErr("Không tìm thấy đội phù hợp với từ khóa đã nhập.", "formErr");
                    openTeamPicker(slot, keyword);
                    return;
                }

                if (matches.length === 1) {
                    setTeamSelection(slot, matches[0].registrationId);
                    return;
                }

                showFormErr(`Có ${matches.length} đội phù hợp. Hãy chọn trong danh sách bên phải.`, "formErr");
                openTeamPicker(slot, keyword);
            }

            function fillTeamsSelects(selected1, selected2) {
                const s1 = $id("team1");
                const s2 = $id("team2");

                const opts = [`<option value="">-- Chọn đội --</option>`].concat((CACHE.regs || []).map(r => {
                    const name = buildTeamText(r);
                    return `<option value="${r.registrationId}">${esc(r.regCode)} — ${esc(name)}</option>`;
                }));

                s1.innerHTML = opts.join("");
                s2.innerHTML = opts.join("");

                if (selected1) {
                    setTeamSelection(1, selected1);
                } else {
                    clearTeamSelection(1);
                }

                if (selected2) {
                    setTeamSelection(2, selected2);
                } else {
                    clearTeamSelection(2);
                }
            }

            function cardHtml(m) {
                const completed = !!m.isCompleted;
                const scoreTeam1 = Number(m.scoreTeam1 || 0);
                const scoreTeam2 = Number(m.scoreTeam2 || 0);
                const hasStartedByScore = scoreTeam1 !== 0 || scoreTeam2 !== 0;
                const winnerId = m.winnerRegistrationId;
                const t1Winner = completed && winnerId && winnerId === m.team1RegistrationId;
                const t2Winner = completed && winnerId && winnerId === m.team2RegistrationId;
                const cardCls = `match-card ${completed ? "completed" : ""}`;
                const team1RegCode = getRegCode(m.team1RegistrationId);
                const team2RegCode = getRegCode(m.team2RegistrationId);
                const statusBadgeHtml = completed
                    ? `<span class="badge badge-light">ĐÃ KẾT THÚC</span>`
                    : hasStartedByScore
                        ? `<span class="badge badge-info">ĐANG DIỄN RA</span>`
                        : `<span class="badge badge-secondary">CHƯA DIỄN RA</span>`;

                const videoLine = m.videoUrl
                    ? `<div class="meta mt-1 ${completed ? "video-link-light" : ""}">
                            Video:
                            <a href="${esc(m.videoUrl)}" target="_blank" rel="noopener noreferrer">Mở liên kết</a>
                       </div>`
                    : "";

                const refereeLine = m.refereeUserId
                    ? `<div class="meta mt-1">
                            Trọng tài: <b>${esc(m.refereeName || ("User #" + m.refereeUserId))}</b>
                            ${m.refereePhone ? " • " + esc(m.refereePhone) : ""}
                       </div>`
                    : `<div class="meta mt-1">Trọng tài: <span class="text-warning">Chưa gán</span></div>`;

                return `
                    <div class="${cardCls}" data-id="${m.matchId}">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="meta mb-1"><span class="badge badge-dark">Mã trận #${m.matchId}</span></div>
                                <div class="meta">
                                    Bắt đầu: ${fmt(m.startAt)}${m.courtText ? " • " + esc(m.courtText) : ""}
                                </div>
                                <div class="meta">Địa chỉ: ${esc(m.addressText || "—")}</div>
                                ${videoLine}
                                ${refereeLine}
                            </div>

                            <div class="d-flex" style="gap:6px">
                                <button class="btn btn-sm ${completed ? "btn-light" : "btn-outline-success"}"
                                        type="button"
                                        onclick="openScore(${m.matchId})"
                                        title="Nhập tỷ số">
                                    <i class="fas fa-clipboard-check"></i>
                                </button>

                                <button class="btn btn-sm ${completed ? "btn-light" : "btn-outline-primary"}"
                                        type="button"
                                        onclick="openEdit(${m.matchId})"
                                        title="Chỉnh sửa">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <button class="btn btn-sm ${completed ? "btn-light" : "btn-outline-danger"}"
                                        type="button"
                                        onclick="delMatch(${m.matchId})"
                                        title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <hr style="opacity:.35" />

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="team-block">
                                <div class="team-code">Mã ĐK: ${esc(team1RegCode)}</div>
                                <div class="team-name ${t1Winner ? "winner" : ""}">${esc(m.team1Text)}</div>
                            </div>
                            <div class="score">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                            <div class="team-block text-right align-items-end">
                                <div class="team-code">Mã ĐK: ${esc(team2RegCode)}</div>
                                <div class="team-name ${t2Winner ? "winner" : ""}">${esc(m.team2Text)}</div>
                            </div>
                        </div>

                        <div class="mt-2 meta">
                            ${statusBadgeHtml}
                            ${completed && winnerId
                                ? `<span class="ml-2 badge badge-warning">NGƯỜI THẮNG: Đội ${m.winnerTeam}</span>`
                                : ``}
                        </div>
                    </div>
                `;
            }

            function render() {
                const box = $id("cards");
                let items = CACHE.items || [];

                if (SHOW_ONLY_COMPLETED) {
                    items = items.filter(x => x.isCompleted);
                }

                if (!items.length) {
                    box.innerHTML = `<div class="text-muted">Không có trận đấu nào</div>`;
                    return;
                }

                box.innerHTML = items.map(cardHtml).join("");
            }

            async function load() {
                hideErr();

                try {
                    const res = await axios.get(API);
                    CACHE.items = res.data?.items || [];

                    const regsRes = await axios.get(API_REGS, {
                        params: { tab: "SUCCESS" }
                    });
                    CACHE.regs = regsRes.data?.items || [];

                    render();
                } catch (err) {
                    showErr(err?.response?.data?.message || err?.message || "Tải dữ liệu thất bại.");
                }
            }

            function resetMatchForm() {
                hideFormErr("formErr");

                $id("mode").value = "create";
                $id("editingId").value = "";
                $id("modalTitle").textContent = "Tạo trận đấu";

                $id("startAt").value = "";
                $id("addressText").value = "";
                $id("courtText").value = "";
                $id("videoUrl").value = "";

                $id("refereeUserIdInput").value = "";
                setRefereeInfo(null);

                fillTeamsSelects(null, null);
                closeTeamPicker();
            }

            function openCreate() {
                resetMatchForm();
                $("#modalMatch").modal("show");
            }

            window.openEdit = (matchId) => {
                hideFormErr("formErr");

                const m = (CACHE.items || []).find(x => x.matchId === matchId);
                if (!m) return;

                $id("mode").value = "edit";
                $id("editingId").value = String(matchId);
                $id("modalTitle").textContent = "Chỉnh sửa trận đấu";

                fillTeamsSelects(m.team1RegistrationId, m.team2RegistrationId);

                $id("startAt").value = toLocalInput(m.startAt);
                $id("addressText").value = m.addressText || "";
                $id("courtText").value = m.courtText || "";
                $id("videoUrl").value = m.videoUrl || "";

                $id("refereeUserIdInput").value = m.refereeUserId ? String(m.refereeUserId) : "";

                if (m.refereeUserId) {
                    setRefereeInfo({
                        userId: m.refereeUserId,
                        fullName: m.refereeName || "",
                        phone: m.refereePhone || "",
                        email: m.refereeEmail || "",
                        city: m.refereeCity || "",
                        refereeVerified: m.refereeVerified || false,
                        refereeType: m.refereeType || "REFEREE",
                        isActive: m.refereeIsActive ?? true
                    });
                } else {
                    setRefereeInfo(null);
                }

                $("#modalMatch").modal("show");
            };

            window.delMatch = async (matchId) => {
                if (!confirm("Bạn có chắc muốn xóa trận đấu này không?")) return;

                try {
                    await axios.delete(`${API}/${matchId}`);
                    await load();
                } catch (err) {
                    alert(err?.response?.data?.message || err?.message || "Xóa thất bại.");
                }
            };

            window.openScore = (matchId) => {
                hideFormErr("scoreErr");

                const m = (CACHE.items || []).find(x => x.matchId === matchId);
                if (!m) return;

                $id("scoreMatchId").value = String(matchId);
                $id("scoreTeam1Name").textContent = m.team1Text || "Đội 1";
                $id("scoreTeam2Name").textContent = m.team2Text || "Đội 2";
                $id("score1").value = String(m.scoreTeam1 ?? 0);
                $id("score2").value = String(m.scoreTeam2 ?? 0);
                $id("isCompleted").checked = !!m.isCompleted || true;

                $("#modalScore").modal("show");
            };

            $id("formMatch").addEventListener("submit", async (e) => {
                e.preventDefault();
                hideFormErr("formErr");

                const mode = $id("mode").value;
                const editingId = $id("editingId").value;

                const team1 = Number($id("team1").value || 0);
                const team2 = Number($id("team2").value || 0);

                if (!team1 || !team2) {
                    showFormErr("Vui lòng chọn đủ hai đội.", "formErr");
                    return;
                }

                if (team1 === team2) {
                    showFormErr("Đội 1 và Đội 2 không được trùng nhau.", "formErr");
                    return;
                }

                const videoUrl = ($id("videoUrl").value || "").trim();
                if (videoUrl && !/^https?:\/\//i.test(videoUrl)) {
                    showFormErr("Liên kết video phải bắt đầu bằng http:// hoặc https://", "formErr");
                    return;
                }

                const refereeUserId = Number($id("refereeUserId").value || 0) || null;
                if (!refereeUserId) {
                    showFormErr("Trận đấu bắt buộc phải có trọng tài hợp lệ.", "formErr");
                    return;
                }

                const startAtLocal = $id("startAt").value;
                const startAtIso = startAtLocal ? new Date(startAtLocal).toISOString() : null;

                const payloadCreate = {
                    team1RegistrationId: team1,
                    team2RegistrationId: team2,
                    startAt: startAtIso,
                    addressText: $id("addressText").value || null,
                    courtText: $id("courtText").value || null,
                    videoUrl: videoUrl || null,
                    refereeUserId: refereeUserId
                };

                const payloadUpdate = {
                    team1RegistrationId: team1,
                    team2RegistrationId: team2,
                    startAtSet: true,
                    startAt: startAtIso,
                    addressText: $id("addressText").value || null,
                    courtText: $id("courtText").value || null,
                    videoUrl: videoUrl || null,
                    refereeUserId: refereeUserId
                };

                const btn = $id("btnSubmit");
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                try {
                    if (mode === "create") {
                        await axios.post(API, payloadCreate);
                    } else {
                        await axios.put(`${API}/${editingId}`, payloadUpdate);
                    }

                    $("#modalMatch").modal("hide");
                    await load();
                } catch (err) {
                    showFormErr(err?.response?.data?.message || err?.message || "Lưu thất bại.", "formErr");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = `<i class="fas fa-save"></i> Lưu`;
                }
            });

            $id("formScore").addEventListener("submit", async (e) => {
                e.preventDefault();
                hideFormErr("scoreErr");

                const matchId = Number($id("scoreMatchId").value || 0);
                const s1 = Number($id("score1").value || 0);
                const s2 = Number($id("score2").value || 0);
                const completed = !!$id("isCompleted").checked;

                try {
                    const res = await axios.put(`${API}/${matchId}/score`, {
                        scoreTeam1: s1,
                        scoreTeam2: s2,
                        isCompleted: completed
                    });

                    $("#modalScore").modal("hide");

                    const idx = (CACHE.items || []).findIndex(x => x.matchId === matchId);
                    if (idx >= 0) {
                        CACHE.items[idx].scoreTeam1 = res.data.scoreTeam1;
                        CACHE.items[idx].scoreTeam2 = res.data.scoreTeam2;
                        CACHE.items[idx].isCompleted = res.data.isCompleted;
                        CACHE.items[idx].winnerRegistrationId = res.data.winnerRegistrationId;
                        CACHE.items[idx].winnerTeam = res.data.winnerTeam;
                    }

                    render();
                } catch (err) {
                    showFormErr(
                        err?.response?.data?.message || err?.message || "Cập nhật tỷ số thất bại.",
                        "scoreErr"
                    );
                }
            });

            $id("btnOpenCreate").addEventListener("click", openCreate);

            $id("btnFilterCompleted").addEventListener("click", () => {
                SHOW_ONLY_COMPLETED = !SHOW_ONLY_COMPLETED;
                $id("btnFilterCompleted").className = SHOW_ONLY_COMPLETED
                    ? "btn btn-sm btn-success"
                    : "btn btn-sm btn-outline-success";
                render();
            });

            $id("btnFindReferee").addEventListener("click", findRefereeByUserId);

            $id("btnClearReferee").addEventListener("click", () => {
                $id("refereeUserIdInput").value = "";
                setRefereeInfo(null);
            });

            $id("btnFindTeam1").addEventListener("click", () => findTeamByCode(1));
            $id("btnFindTeam2").addEventListener("click", () => findTeamByCode(2));

            $id("btnBrowseTeam1").addEventListener("click", () => openTeamPicker(1));
            $id("btnBrowseTeam2").addEventListener("click", () => openTeamPicker(2));

            $id("btnClearTeam1").addEventListener("click", () => clearTeamSelection(1));
            $id("btnClearTeam2").addEventListener("click", () => clearTeamSelection(2));

            $id("team1CodeSearch").addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    findTeamByCode(1);
                }
            });

            $id("team2CodeSearch").addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    findTeamByCode(2);
                }
            });

            $id("btnApplyTeamPickerSearch").addEventListener("click", () => {
                TEAM_PICKER_KEYWORD = ($id("teamPickerSearch").value || "").trim();
                $id("teamPickerHint").textContent = TEAM_PICKER_KEYWORD
                    ? `Đang lọc theo từ khóa: "${TEAM_PICKER_KEYWORD}".`
                    : "Có thể tìm theo mã đăng ký, tên đội hoặc tên người chơi.";
                renderTeamPickerList();
            });

            $id("teamPickerSearch").addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    TEAM_PICKER_KEYWORD = ($id("teamPickerSearch").value || "").trim();
                    $id("teamPickerHint").textContent = TEAM_PICKER_KEYWORD
                        ? `Đang lọc theo từ khóa: "${TEAM_PICKER_KEYWORD}".`
                        : "Có thể tìm theo mã đăng ký, tên đội hoặc tên người chơi.";
                    renderTeamPickerList();
                }
            });

            $id("btnCloseTeamPicker").addEventListener("click", closeTeamPicker);
            $id("teamPickerBackdrop").addEventListener("click", closeTeamPicker);

            window.pickTeam = (registrationId) => {
                const ok = setTeamSelection(TEAM_PICKER_TARGET_SLOT, registrationId);
                if (ok) closeTeamPicker();
            };

            $("#modalMatch").on("hidden.bs.modal", closeTeamPicker);

            document.addEventListener("DOMContentLoaded", load);
        })();
    </script>
}
