@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trận đấu được phân công";
}

<style>
    .match-card {
        border: 1px solid #eee;
        border-radius: 14px;
        padding: 14px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0,0,0,.03);
        margin-bottom: 16px;
    }

        .match-card.completed {
            background: #28a745;
            border-color: #28a745;
            color: #fff;
        }

    .team-name {
        font-weight: 700;
        font-size: 15px;
    }

        .team-name.winner {
            color: #ffc107;
        }

    .score {
        font-weight: 800;
        font-size: 18px;
        letter-spacing: .5px;
    }

    .meta {
        font-size: 12px;
        opacity: .95;
    }

    .history-box {
        margin-top: 14px;
        border-top: 1px dashed rgba(0,0,0,.15);
        padding-top: 12px;
    }

    .history-item {
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 8px;
        background: #f8f9fa;
        color: #212529;
    }

    .history-title {
        font-weight: 700;
        margin-bottom: 4px;
    }

    .history-meta {
        font-size: 12px;
        color: #6c757d;
    }

    .history-score {
        font-size: 16px;
        font-weight: 700;
        margin: 4px 0;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    @@media (max-width: 992px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid" id="pageRoot">
    <div class="d-sm-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Các trận đấu tôi phụ trách</h1>
            <div class="small text-muted">
                Trước giờ thi đấu chỉ được xem. Đến giờ thi đấu mới được chấm điểm.
            </div>
        </div>
    </div>

    <div id="errBox" class="alert alert-danger d-none"></div>

    <div id="cards">
        <div class="text-muted">Đang tải...</div>
    </div>
</div>

<div class="modal fade" id="modalScore" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="formScore">
                <input type="hidden" id="scoreMatchId" value="" />

                <div class="modal-header">
                    <h5 class="modal-title">Chấm điểm trận đấu</h5>
                    <button class="close" type="button" data-dismiss="modal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div id="scoreErr" class="alert alert-danger d-none"></div>

                    <div class="d-flex justify-content-between mb-2">
                        <div class="font-weight-bold" id="scoreTeam1Name">Đội 1</div>
                        <div class="font-weight-bold" id="scoreTeam2Name">Đội 2</div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Tỷ số đội 1</label>
                            <input type="number" class="form-control" id="score1" value="0" min="0" />
                        </div>
                        <div class="form-group col-md-6">
                            <label>Tỷ số đội 2</label>
                            <input type="number" class="form-control" id="score2" value="0" min="0" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Ghi chú</label>
                        <textarea class="form-control" id="scoreNote" rows="3" placeholder="Ghi chú lần chấm điểm này (nếu có)"></textarea>
                    </div>

                    <div class="form-group mb-0">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="isCompleted" checked />
                            <label class="custom-control-label" for="isCompleted">Kết thúc trận đấu</label>
                        </div>
                    </div>

                    <small class="text-muted">Không hỗ trợ kết quả hòa khi kết thúc trận.</small>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Hủy</button>
                    <button class="btn btn-success" type="submit" id="btnSubmitScore">
                        <i class="fas fa-check"></i> Lưu điểm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        (() => {
            const $id = (id) => document.getElementById(id);
            const API = `/api/referee/matches`;

            let CACHE = { items: [] };

            const esc = (s) => String(s || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const fmt = (dt) => {
                if (!dt) return "—";
                const d = new Date(dt);
                if (isNaN(d.getTime())) return "—";
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                const hh = String(d.getHours()).padStart(2, "0");
                const mi = String(d.getMinutes()).padStart(2, "0");
                return `${yyyy}-${mm}-${dd} ${hh}:${mi}`;
            };

            function showErr(msg) {
                const box = $id("errBox");
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideErr() {
                const box = $id("errBox");
                box.classList.add("d-none");
                box.textContent = "";
            }

            function showFormErr(msg) {
                const box = $id("scoreErr");
                box.textContent = msg || "Đã xảy ra lỗi";
                box.classList.remove("d-none");
            }

            function hideFormErr() {
                const box = $id("scoreErr");
                box.classList.add("d-none");
                box.textContent = "";
            }

            function historyHtml(histories, completedCard) {
                if (!histories || !histories.length) {
                    return `
                        <div class="history-box">
                            <div class="meta ${completedCard ? "" : "text-muted"}">Chưa có lịch sử chấm điểm.</div>
                        </div>
                    `;
                }

                return `
                    <div class="history-box">
                        <div class="font-weight-bold mb-2 ${completedCard ? "" : "text-dark"}">Lịch sử chấm điểm</div>
                        ${histories.map(h => `
                            <div class="history-item">
                                <div class="history-title">
                                    ${h.isCompleted ? "Chấm điểm kết thúc trận" : "Cập nhật điểm tạm thời"}
                                </div>
                                <div class="history-score">
                                    ${Number(h.scoreTeam1 || 0)} - ${Number(h.scoreTeam2 || 0)}
                                    ${h.winnerTeam ? `<span class="badge badge-warning ml-2">Đội thắng: ${h.winnerTeam}</span>` : ""}
                                </div>
                                <div class="history-meta">
                                    Trọng tài: ${esc(h.refereeName || ("User #" + h.refereeUserId))} • ${fmt(h.createdAt)}
                                </div>
                                ${h.note ? `<div class="mt-1">${esc(h.note)}</div>` : ""}
                            </div>
                        `).join("")}
                    </div>
                `;
            }

            function cardHtml(m) {
                const completed = !!m.isCompleted;
                const winnerId = m.winnerRegistrationId;
                const t1Winner = completed && winnerId && winnerId === m.team1RegistrationId;
                const t2Winner = completed && winnerId && winnerId === m.team2RegistrationId;
                const cardCls = `match-card ${completed ? "completed" : ""}`;

                const editBtn = m.canEditScore
                    ? `<button class="btn btn-sm ${completed ? "btn-light" : "btn-outline-success"}"
                                type="button"
                                onclick="openScore(${m.matchId})">
                            <i class="fas fa-clipboard-check"></i> Chấm điểm
                       </button>`
                    : `<button class="btn btn-sm btn-outline-secondary" type="button" disabled>
                            <i class="fas fa-lock"></i> Chưa đến giờ đấu
                       </button>`;

                return `
                    <div class="${cardCls}" data-id="${m.matchId}">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="meta"><b>${esc(m.tournamentTitle)}</b></div>
                                <div class="meta">Vòng: ${esc(m.roundKey)} • ${esc(m.roundLabel)} • Bảng: ${esc(m.groupName)}</div>
                                <div class="meta">Bắt đầu: ${fmt(m.startAt)}${m.courtText ? " • " + esc(m.courtText) : ""}</div>
                                <div class="meta">Địa chỉ: ${esc(m.addressText || "—")}</div>
                            </div>

                            <div>${editBtn}</div>
                        </div>

                        <hr style="opacity:.35" />

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="team-name ${t1Winner ? "winner" : ""}">${esc(m.team1Text)}</div>
                            <div class="score">${Number(m.scoreTeam1 || 0)} - ${Number(m.scoreTeam2 || 0)}</div>
                            <div class="team-name text-right ${t2Winner ? "winner" : ""}">${esc(m.team2Text)}</div>
                        </div>

                        <div class="mt-2 meta">
                            ${completed
                                ? `<span class="badge badge-light">ĐÃ KẾT THÚC</span>`
                                : `<span class="badge badge-secondary">CHƯA KẾT THÚC</span>`}
                            ${completed && m.winnerTeam
                                ? `<span class="ml-2 badge badge-warning">NGƯỜI THẮNG: Đội ${m.winnerTeam}</span>`
                                : ``}
                        </div>

                        ${historyHtml(m.scoreHistories, completed)}
                    </div>
                `;
            }

            function render() {
                const box = $id("cards");
                const items = CACHE.items || [];

                if (!items.length) {
                    box.innerHTML = `<div class="text-muted">Bạn chưa được phân công trận đấu nào.</div>`;
                    return;
                }

                box.innerHTML = items.map(cardHtml).join("");
            }

            async function load() {
                hideErr();
                try {
                    const res = await axios.get(API);
                    CACHE.items = res.data?.items || [];
                    render();
                } catch (err) {
                    showErr(err?.response?.data?.message || err?.message || "Tải dữ liệu thất bại.");
                }
            }

            window.openScore = (matchId) => {
                hideFormErr();

                const m = (CACHE.items || []).find(x => x.matchId === matchId);
                if (!m) return;

                if (!m.canEditScore) {
                    showErr("Chưa đến giờ thi đấu, bạn chỉ được phép xem trận.");
                    return;
                }

                $id("scoreMatchId").value = String(matchId);
                $id("scoreTeam1Name").textContent = m.team1Text || "Đội 1";
                $id("scoreTeam2Name").textContent = m.team2Text || "Đội 2";
                $id("score1").value = String(m.scoreTeam1 ?? 0);
                $id("score2").value = String(m.scoreTeam2 ?? 0);
                $id("scoreNote").value = "";
                $id("isCompleted").checked = !!m.isCompleted || true;

                $("#modalScore").modal("show");
            };

            $id("formScore").addEventListener("submit", async (e) => {
                e.preventDefault();
                hideFormErr();

                const matchId = Number($id("scoreMatchId").value || 0);
                const s1 = Number($id("score1").value || 0);
                const s2 = Number($id("score2").value || 0);
                const completed = !!$id("isCompleted").checked;
                const note = ($id("scoreNote").value || "").trim();

                const btn = $id("btnSubmitScore");
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Đang lưu...`;

                try {
                    const res = await axios.put(`${API}/${matchId}/score`, {
                        scoreTeam1: s1,
                        scoreTeam2: s2,
                        isCompleted: completed,
                        note: note || null
                    });

                    $("#modalScore").modal("hide");

                    const idx = (CACHE.items || []).findIndex(x => x.matchId === matchId);
                    if (idx >= 0) {
                        CACHE.items[idx].scoreTeam1 = res.data.scoreTeam1;
                        CACHE.items[idx].scoreTeam2 = res.data.scoreTeam2;
                        CACHE.items[idx].isCompleted = res.data.isCompleted;
                        CACHE.items[idx].winnerRegistrationId = res.data.winnerRegistrationId;
                        CACHE.items[idx].winnerTeam = res.data.winnerTeam;

                        if (!Array.isArray(CACHE.items[idx].scoreHistories)) {
                            CACHE.items[idx].scoreHistories = [];
                        }

                        CACHE.items[idx].scoreHistories.unshift(res.data.history);
                    }

                    render();
                } catch (err) {
                    showFormErr(err?.response?.data?.message || err?.message || "Chấm điểm thất bại.");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = `<i class="fas fa-check"></i> Lưu điểm`;
                }
            });

            document.addEventListener("DOMContentLoaded", load);
        })();
    </script>
}